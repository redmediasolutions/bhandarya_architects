---
const principles = [
  {
    title: "Natural Daylight",
    number: "01",
    text: "Abundant daylight improves concentration, wellbeing and overall learning outcomes."
  },
  {
    title: "Flexible Spaces",
    number: "02",
    text: "Adaptable classrooms and collaborative areas evolve with changing educational needs."
  },
  {
    title: "Student Wellbeing",
    number: "03",
    text: "Healthy, comfortable environments encourage creativity, focus and social interaction."
  },
  {
    title: "Collaboration",
    number: "04",
    text: "Open learning environments encourage discussion, teamwork and shared experiences."
  },
  {
    title: "Technology",
    number: "05",
    text: "Integrated digital infrastructure supports modern teaching and hybrid learning."
  },
  {
    title: "Sustainability",
    number: "06",
    text: "Energy-efficient design, natural ventilation and landscape reduce environmental impact."
  }
];
---

<section class="learning-environment section">

    <div class="grid-bg"></div>
    <div class="glow"></div>

    <div class="container">

        <div class="section-heading">

            <span class="small-title">
                Learning Environment
            </span>

            <h2>
                Spaces That Help
                <br>
                Students Thrive
            </h2>

            <p>
                Every educational environment is designed around
                comfort, curiosity and collaboration, creating
                places where learning naturally happens.
            </p>

        </div>

        <div class="principles-grid">

            {
                principles.map((item,index)=>(

                    <article
                        class={`principle ${index % 2 ? "down" : ""}`}
                        style={`--delay:${index*.12}s`}
                    >

                        <div class="number">

                            {item.number}

                        </div>

                        <h3>

                            {item.title}

                        </h3>

                        <p>

                            {item.text}

                        </p>

                    </article>

                ))
            }

        </div>

    </div>

</section>

<style>

.learning-environment{

    position:relative;

    overflow:hidden;

    background:white;

}

/* ================================= */

.grid-bg{

    position:absolute;

    inset:0;

    background-image:
        linear-gradient(rgba(0,0,0,.025) 1px,transparent 1px),
        linear-gradient(90deg,rgba(0,0,0,.025) 1px,transparent 1px);

    background-size:70px 70px;

    animation:gridMove 18s linear infinite;

}

.glow{

    position:absolute;

    left:-220px;

    top:-220px;

    width:850px;

    height:850px;

    border-radius:50%;

    background:
        radial-gradient(rgba(76,175,80,.12),transparent 70%);

    filter:blur(120px);

}

/* ================================= */

.container{

    position:relative;

    z-index:2;

}

.section-heading{

    max-width:760px;

    margin:0 auto 90px;

    text-align:center;

}

.section-heading h2{

    margin:18px 0;

}

.section-heading p{

    color:#666;

}

/* ================================= */

.principles-grid{

    display:grid;

    grid-template-columns:repeat(3,1fr);

    gap:35px;

    align-items:start;

}

.principle{

    position:relative;

    padding:40px;

    background:#fff;

    border-radius:22px;

    border:1px solid rgba(0,0,0,.06);

    transition:.45s;

    opacity:0;

    transform:translateY(50px);

    box-shadow:0 18px 45px rgba(0,0,0,.04);

}

.learning-environment.visible .principle{

    opacity:1;

    transform:none;

    transition-delay:var(--delay);

}

.principle.down{

    margin-top:70px;

}

.principle:hover{

    transform:translateY(-10px);

    box-shadow:0 30px 70px rgba(0,0,0,.08);

}

/* subtle blueprint */

.principle::before{

    content:"";

    position:absolute;

    inset:0;

    background-image:
        linear-gradient(rgba(0,0,0,.03) 1px,transparent 1px),
        linear-gradient(90deg,rgba(0,0,0,.03) 1px,transparent 1px);

    background-size:32px 32px;

    opacity:.25;

    pointer-events:none;

}

/* green glow */

.principle::after{

    content:"";

    position:absolute;

    inset:-35%;

    background:
        radial-gradient(circle,
            rgba(76,175,80,.12),
            transparent 70%);

    opacity:0;

    transition:.45s;

}

.principle:hover::after{

    opacity:1;

}

.number{

    position:relative;

    z-index:2;

    font-size:64px;

    line-height:1;

    font-weight:700;

    color:rgba(76,175,80,.18);

    margin-bottom:20px;

}

.principle h3{

    position:relative;

    z-index:2;

    margin-bottom:18px;

}

.principle p{

    position:relative;

    z-index:2;

    color:#666;

    line-height:1.8;

}

/* ================================= */

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:70px 70px;

    }

}

/* ================================= */

@media(max-width:991px){

    .principles-grid{

        grid-template-columns:repeat(2,1fr);

    }

    .principle.down{

        margin-top:0;

    }

}

@media(max-width:768px){

    .principles-grid{

        grid-template-columns:1fr;

    }

    .principle{

        padding:34px;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const section=document.querySelector(".learning-environment");

    if(!section) return;

    const observer=new IntersectionObserver((entries)=>{

        if(entries[0].isIntersecting){

            section.classList.add("visible");

            observer.disconnect();

        }

    },{

        threshold:.2

    });

    observer.observe(section);

});

</script>