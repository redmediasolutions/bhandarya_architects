---
const zones = [
    {
        title: "Academic Block",
        number: "01",
        text: "Flexible classrooms and collaborative learning environments."
    },
    {
        title: "Central Plaza",
        number: "02",
        text: "The social heart of the campus encouraging interaction."
    },
    {
        title: "Library",
        number: "03",
        text: "Knowledge centre with quiet and collaborative study areas."
    },
    {
        title: "Innovation Labs",
        number: "04",
        text: "Research, experimentation and future-focused learning."
    },
    {
        title: "Student Hub",
        number: "05",
        text: "Dining, recreation and informal gathering spaces."
    },
    {
        title: "Hostels",
        number: "06",
        text: "Comfortable residential environments fostering community."
    }
];
---

<section class="campus-planning section">

    <div class="grid-bg"></div>
    <div class="glow"></div>

    <div class="container">

        <div class="section-heading">

            <span class="small-title">

                Campus Planning

            </span>

            <h2>

                Master Planning
                <br>

                For Better Learning

            </h2>

            <p>

                Every campus is designed as an interconnected
                ecosystem where movement, landscape and
                academic spaces work together.

            </p>

        </div>

        <div class="campus-map">

            <div class="connection horizontal"></div>
            <div class="connection vertical"></div>

            {
                zones.map((zone,index)=>(

                    <article
                        class={`node node-${index+1}`}
                    >

                        <div class="circle">

                            {zone.number}

                        </div>

                        <h3>

                            {zone.title}

                        </h3>

                        <p>

                            {zone.text}

                        </p>

                    </article>

                ))
            }

        </div>

    </div>

</section>

<style>

.campus-planning{

    position:relative;

    overflow:hidden;

    background:#faf8f5;

}

/* ================================= */

.grid-bg{

    position:absolute;

    inset:0;

    background-image:
        linear-gradient(rgba(0,0,0,.025) 1px,transparent 1px),
        linear-gradient(90deg,rgba(0,0,0,.025) 1px,transparent 1px);

    background-size:70px 70px;

    animation:gridMove 20s linear infinite;

}

.glow{

    position:absolute;

    width:850px;

    height:850px;

    right:-200px;

    bottom:-200px;

    border-radius:50%;

    background:
        radial-gradient(rgba(76,175,80,.12),transparent 70%);

    filter:blur(120px);

}

.container{

    position:relative;

    z-index:2;

}

.section-heading{

    text-align:center;

    max-width:760px;

    margin:0 auto 90px;

}

/* ================================= */

.campus-map{

    position:relative;

    display:grid;

    grid-template-columns:repeat(3,1fr);

    gap:70px;

    max-width:1200px;

    margin:auto;

}

.connection{

    position:absolute;

    background:#d6d6d6;

}

.connection.horizontal{

    top:110px;

    left:12%;

    right:12%;

    height:2px;

}

.connection.vertical{

    left:50%;

    top:110px;

    bottom:120px;

    width:2px;

    transform:translateX(-50%);

}

/* ================================= */

.node{

    position:relative;

    text-align:center;

    background:white;

    padding:80px 30px 35px;

    border-radius:20px;

    border:1px solid rgba(0,0,0,.06);

    transition:.4s;

}

.node:hover{

    transform:translateY(-10px);

    box-shadow:0 25px 60px rgba(0,0,0,.08);

}

.circle{

    position:absolute;

    left:50%;

    top:0;

    transform:translate(-50%,-50%);

    width:82px;

    height:82px;

    border-radius:50%;

    background:white;

    border:3px solid #4CAF50;

    color:#4CAF50;

    font-size:24px;

    font-weight:700;

    display:flex;

    align-items:center;

    justify-content:center;

    transition:.35s;

}

.node:hover .circle{

    background:#4CAF50;

    color:white;

    transform:translate(-50%,-50%) scale(1.08);

}

.node h3{

    margin-bottom:18px;

}

.node p{

    color:#666;

    line-height:1.8;

}

/* ================================= */

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:70px 70px;

    }

}

@media(max-width:991px){

    .campus-map{

        grid-template-columns:repeat(2,1fr);

    }

    .connection{

        display:none;

    }

}

@media(max-width:768px){

    .campus-map{

        grid-template-columns:1fr;

        gap:55px;

    }

}

</style>