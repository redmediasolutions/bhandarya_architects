---
const stats = [
    {
        number: "20+",
        label: "Educational Projects",
        text: "Schools, colleges and university campuses delivered."
    },
    {
        number: "2M+",
        label: "Sq.ft Designed",
        text: "Purpose-built educational environments across Karnataka."
    },
    {
        number: "25+",
        label: "Years Experience",
        text: "Designing institutions that inspire generations of learners."
    },
    {
        number: "50K+",
        label: "Students Impacted",
        text: "Learning environments used by thousands of students every year."
    }
];
---

<section class="education-stats section">

    <div class="background-grid"></div>

    <div class="glow"></div>

    <div class="container">

        <div class="heading">

            <span class="small-title">

                By The Numbers

            </span>

            <h2>

                Building Better
                <br>

                Learning Environments

            </h2>

            <p>

                Every educational project is measured not just
                by its scale, but by the positive impact it has
                on students, educators and communities.

            </p>

        </div>

        <div class="stats-grid">

            {
                stats.map((stat,index)=>(

                    <article
                        class="stat-card"
                        style={`--delay:${index*.15}s`}
                    >

                        <div class="stat-number">

                            {stat.number}

                        </div>

                        <h3>

                            {stat.label}

                        </h3>

                        <p>

                            {stat.text}

                        </p>

                        <div class="line"></div>

                    </article>

                ))
            }

        </div>

    </div>

</section>

<style>

.education-stats{

    position:relative;

    overflow:hidden;

    background:#f9f8f4;

}

/* ================================= */

.background-grid{

    position:absolute;

    inset:0;

    background-image:

        linear-gradient(rgba(0,0,0,.02) 1px,transparent 1px),

        linear-gradient(90deg,rgba(0,0,0,.02) 1px,transparent 1px);

    background-size:70px 70px;

    animation:gridMove 20s linear infinite;

}

.glow{

    position:absolute;

    width:900px;

    height:900px;

    right:-250px;

    top:-250px;

    border-radius:50%;

    background:

        radial-gradient(

            rgba(76,175,80,.12),

            transparent 70%

        );

    filter:blur(120px);

}

/* ================================= */

.container{

    position:relative;

    z-index:2;

}

.heading{

    text-align:center;

    max-width:760px;

    margin:0 auto 80px;

}

.heading h2{

    margin:18px 0;

}

.heading p{

    color:#666;

}

/* ================================= */

.stats-grid{

    display:grid;

    grid-template-columns:repeat(4,1fr);

    gap:30px;

}

/* ================================= */

.stat-card{

    position:relative;

    background:white;

    border-radius:20px;

    padding:45px;

    border:1px solid rgba(0,0,0,.06);

    overflow:hidden;

    transition:.45s;

    opacity:0;

    transform:translateY(60px);

}

.education-stats.visible .stat-card{

    opacity:1;

    transform:none;

    transition-delay:var(--delay);

}

.stat-card::before{

    content:"";

    position:absolute;

    inset:0;

    background-image:

        linear-gradient(rgba(0,0,0,.03) 1px,transparent 1px),

        linear-gradient(90deg,rgba(0,0,0,.03) 1px,transparent 1px);

    background-size:36px 36px;

    opacity:.3;

}

.stat-card::after{

    content:"";

    position:absolute;

    inset:-40%;

    background:

        radial-gradient(

            circle,

            rgba(76,175,80,.12),

            transparent 70%

        );

    opacity:0;

    transition:.45s;

}

.stat-card:hover{

    transform:translateY(-10px);

    box-shadow:0 30px 70px rgba(0,0,0,.08);

}

.stat-card:hover::after{

    opacity:1;

}

/* ================================= */

.stat-number{

    position:relative;

    z-index:2;

    font-size:72px;

    line-height:1;

    font-weight:700;

    color:rgba(76,175,80,.22);

    margin-bottom:24px;

}

.stat-card h3{

    position:relative;

    z-index:2;

    margin-bottom:18px;

    font-size:26px;

}

.stat-card p{

    position:relative;

    z-index:2;

    color:#666;

    line-height:1.8;

}

.line{

    position:relative;

    z-index:2;

    width:0;

    height:2px;

    margin-top:28px;

    background:#4CAF50;

    transition:.45s;

}

.stat-card:hover .line{

    width:90px;

}

/* ================================= */

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:70px 70px;

    }

}

/* ================================= */

@media(max-width:1100px){

    .stats-grid{

        grid-template-columns:repeat(2,1fr);

    }

}

@media(max-width:768px){

    .stats-grid{

        grid-template-columns:1fr;

    }

    .stat-card{

        padding:36px;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const section=document.querySelector(".education-stats");

    if(!section) return;

    const observer=new IntersectionObserver((entries)=>{

        if(entries[0].isIntersecting){

            section.classList.add("visible");

            observer.disconnect();

        }

    },{

        threshold:.2

    });

    observer.observe(section);

});

</script>