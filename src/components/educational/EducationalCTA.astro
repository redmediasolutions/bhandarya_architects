---
import { img } from "../../consts";

const background = img("2026/05/Copy-of-01.webp");
---

<section class="education-cta">

    <div
        class="cta-background"
        style={`background-image:url('${background}')`}
    ></div>

    <div class="overlay"></div>

    <div class="grid"></div>

    <div class="glow"></div>

    <div class="container">

        <div class="cta-content">

            <span class="small-title">

                Let's Build The Future

            </span>

            <h2>

                Designing Inspiring
                <br>

                Campuses For The
                <br>

                Next Generation

            </h2>

            <p>

                Whether you're planning a new school,
                expanding a university campus or creating
                future-ready educational spaces, our team
                is ready to help bring your vision to life.

            </p>

            <div class="cta-buttons">

                <a
                    href="/contact"
                    class="btn"
                >

                    Start Your Project

                </a>

                <a
                    href="/projects"
                    class="secondary-btn"
                >

                    View Our Projects

                </a>

            </div>

        </div>

    </div>

</section>

<style>

.education-cta{

    position:relative;

    overflow:hidden;

    min-height:75vh;

    display:flex;

    align-items:center;

    background:#111;

}

/* ================================= */

.cta-background{

    position:absolute;

    inset:0;

    background-size:cover;

    background-position:center;

    transform:scale(1.08);

    transition:transform 10s ease;

}

.education-cta:hover .cta-background{

    transform:scale(1.15);

}

.overlay{

    position:absolute;

    inset:0;

    background:

        linear-gradient(

            90deg,

            rgba(0,0,0,.82),

            rgba(0,0,0,.45)

        );

}

/* ================================= */

.grid{

    position:absolute;

    inset:0;

    background-image:

        linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),

        linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);

    background-size:70px 70px;

    animation:gridMove 20s linear infinite;

}

/* ================================= */

.glow{

    position:absolute;

    width:900px;

    height:900px;

    right:-250px;

    top:-250px;

    border-radius:50%;

    background:

        radial-gradient(

            rgba(76,175,80,.18),

            transparent 70%

        );

    filter:blur(120px);

}

/* ================================= */

.container{

    position:relative;

    z-index:2;

}

.cta-content{

    max-width:760px;

}

.cta-content h2{

    color:white;

    margin:22px 0;

    font-size:clamp(48px,6vw,84px);

    line-height:1;

}

.cta-content p{

    color:rgba(255,255,255,.78);

    max-width:620px;

    line-height:1.9;

    font-size:18px;

}

/* ================================= */

.cta-buttons{

    display:flex;

    flex-wrap:wrap;

    gap:18px;

    margin-top:50px;

}

.secondary-btn{

    display:inline-flex;

    align-items:center;

    justify-content:center;

    padding:16px 34px;

    border-radius:999px;

    border:1px solid rgba(255,255,255,.2);

    color:white;

    text-decoration:none;

    text-transform:uppercase;

    letter-spacing:2px;

    font-size:12px;

    font-weight:600;

    transition:.35s;

}

.secondary-btn:hover{

    background:white;

    color:#111;

}

/* ================================= */

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:70px 70px;

    }

}

/* ================================= */

@media(max-width:768px){

    .education-cta{

        min-height:65vh;

    }

    .cta-content h2{

        font-size:46px;

    }

    .cta-content p{

        font-size:16px;

    }

    .cta-buttons{

        flex-direction:column;

        align-items:flex-start;

    }

}

</style>