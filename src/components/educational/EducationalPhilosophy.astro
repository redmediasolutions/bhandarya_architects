---
import { img } from "../../consts";

const philosophy = [
    {
        title: "Learning First",
        text: "Every space is planned to encourage curiosity, interaction and academic excellence."
    },
    {
        title: "Community",
        text: "Shared spaces strengthen relationships between students, teachers and the wider campus."
    },
    {
        title: "Nature",
        text: "Natural light, ventilation and landscape create healthier learning environments."
    },
    {
        title: "Future Ready",
        text: "Flexible classrooms and adaptable planning allow institutions to evolve over time."
    }
];

const image = img("2026/05/Copy-of-01.webp");
---

<section class="educational-philosophy section">

    <div class="background-grid"></div>

    <div class="glow"></div>

    <div class="container">

        <div class="philosophy-grid">

            <div class="content">

                <span class="small-title">

                    Our Philosophy

                </span>

                <h2>

                    Architecture Is
                    <br>

                    The Silent
                    <br>

                    Teacher.

                </h2>

                <p>

                    Educational architecture goes far beyond
                    classrooms. We believe every courtyard,
                    corridor, library and gathering space
                    should inspire learning, encourage
                    collaboration and create a lifelong
                    connection between people and place.

                </p>

                <div class="principles">

                    {
                        philosophy.map((item,index)=>(

                            <article
                                class="principle"
                                style={`--delay:${index*.15}s`}
                            >

                                <h3>

                                    {item.title}

                                </h3>

                                <p>

                                    {item.text}

                                </p>

                            </article>

                        ))
                    }

                </div>

            </div>

            <div class="image">

                <img
                    src={image}
                    alt="Educational Campus"
                />

            </div>

        </div>

    </div>

</section>

<style>

.educational-philosophy{

    position:relative;

    overflow:hidden;

    background:#faf8f5;

}

/* ================================= */

.background-grid{

    position:absolute;

    inset:0;

    background-image:
        linear-gradient(rgba(0,0,0,.025) 1px,transparent 1px),
        linear-gradient(90deg,rgba(0,0,0,.025) 1px,transparent 1px);

    background-size:70px 70px;

    animation:gridMove 20s linear infinite;

}

.glow{

    position:absolute;

    left:-220px;

    top:-220px;

    width:850px;

    height:850px;

    border-radius:50%;

    background:
        radial-gradient(
            rgba(70,180,120,.12),
            transparent 70%
        );

    filter:blur(120px);

}

/* ================================= */

.container{

    position:relative;

    z-index:2;

}

.philosophy-grid{

    display:grid;

    grid-template-columns:1.1fr .9fr;

    gap:80px;

    align-items:center;

}

/* ================================= */

.content h2{

    margin:20px 0 30px;

}

.content>p{

    color:#666;

    line-height:1.9;

    max-width:640px;

}

/* ================================= */

.principles{

    display:grid;

    grid-template-columns:repeat(2,1fr);

    gap:24px;

    margin-top:50px;

}

.principle{

    padding:28px;

    background:white;

    border-radius:18px;

    border:1px solid rgba(0,0,0,.06);

    transition:.35s;

    opacity:0;

    transform:translateY(50px);

}

.educational-philosophy.visible .principle{

    opacity:1;

    transform:none;

    transition-delay:var(--delay);

}

.principle:hover{

    transform:translateY(-8px);

    box-shadow:0 25px 60px rgba(0,0,0,.08);

}

.principle h3{

    margin-bottom:14px;

    color:var(--accent);

}

.principle p{

    color:#666;

    line-height:1.8;

}

/* ================================= */

.image{

    position:relative;

    overflow:hidden;

    border-radius:24px;

    box-shadow:0 35px 80px rgba(0,0,0,.12);

    opacity:0;

    transform:translateX(60px);

    transition:1s;

}

.image img{

    width:100%;

    display:block;

    transform:scale(1.08);

    transition:transform 2s;

}

.image:hover img{

    transform:scale(1.15);

}

.educational-philosophy.visible .image{

    opacity:1;

    transform:none;

}

/* ================================= */

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:70px 70px;

    }

}

/* ================================= */

@media(max-width:991px){

    .philosophy-grid{

        grid-template-columns:1fr;

    }

}

@media(max-width:768px){

    .principles{

        grid-template-columns:1fr;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const section=document.querySelector(".educational-philosophy");

    if(!section) return;

    const observer=new IntersectionObserver((entries)=>{

        if(entries[0].isIntersecting){

            section.classList.add("visible");

            observer.disconnect();

        }

    },{

        threshold:.2

    });

    observer.observe(section);

});

</script>