---
import HeroBackground from "./HeroBackground.astro";
import HeroContent from "./HeroContent.astro";

import { slides } from "./heroData";

const totalSlides = String(slides.length).padStart(2, "0");
---

<section
    class="hero"
    id="hero"
>

    <!-- Background Images -->

    <HeroBackground slides={slides} />

    <!-- Overlay -->

    <div class="hero-overlay"></div>

    <!-- Content -->

    <div class="hero-inner">

        <div class="container">

            <HeroContent slide={slides[0]} />

        </div>

    </div>

    <!-- Bottom UI -->
    
    <div class="hero-bottom">
        
        <div class="container">
            
            <div class="hero-bottom-inner">
                
                <!-- Counter -->
                <div class="hero-counter">
                    <span id="hero-current">01</span>
                    <span class="divider">/</span>
                    <span id="hero-total">{totalSlides}</span>
                </div>

                <!-- Progress Bar -->
                <div class="hero-progress">
                    <div class="hero-progress-fill" id="hero-progress-fill"></div>
                </div>

                <!-- Navigation Controls -->
                <div class="hero-controls">
                    <button id="hero-prev" class="hero-nav-btn" aria-label="Previous Slide">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="19" y1="12" x2="5" y2="12"></line>
                            <polyline points="12 19 5 12 12 5"></polyline>
                        </svg>
                    </button>
                    
                    <button id="hero-next" class="hero-nav-btn" aria-label="Next Slide">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </button>
                </div>

            </div>

        </div>

    </div>

</section>

<script>
    // Astro will automatically bundle this when using a standard script tag
    import "./hero";
</script>

<style>

.hero{

    position:relative;

    min-height:70vh;

    overflow:hidden;

    background:#111;

    color:white;

}

/* -------------------------------- */

.hero-overlay{

    position:absolute;

    inset:0;

    z-index:2;

    background:
        linear-gradient(
            90deg,
            rgba(0,0,0,.78),
            rgba(0,0,0,.45),
            rgba(0,0,0,.12)
        );

}

/* -------------------------------- */

.hero-inner{

    position:relative;

    z-index:5;

    display:flex;

    align-items:center;

    min-height:100vh;

}

/* -------------------------------- */

.hero-bottom{

    position:absolute;

    left:0;

    right:0;

    bottom:0;

    z-index:8;

    backdrop-filter:blur(12px);
    -webkit-backdrop-filter:blur(12px);

    background:rgba(0,0,0,.35);

    border-top:1px solid rgba(255,255,255,.12);

}

/* -------------------------------- */

.hero-bottom-inner{

    display:flex;

    justify-content:space-between;

    align-items:center;

    gap:40px;

    padding:28px 0;

}

/* -------------------------------- */
/* Bottom UI Elements */
/* -------------------------------- */

.hero-counter {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 2px;
    display: flex;
    align-items: center;
    gap: 8px;
    color: white;
}

.hero-counter .divider {
    color: rgba(255, 255, 255, 0.4);
}

#hero-total {
    color: rgba(255, 255, 255, 0.6);
}

/* -------------------------------- */

.hero-progress {
    flex-grow: 1;
    height: 2px;
    background: rgba(255, 255, 255, 0.15);
    position: relative;
    max-width: 400px; /* Adjust max-width as needed */
    overflow: hidden;
}

.hero-progress-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0%;
    background: white;
    transform-origin: left;
}

/* -------------------------------- */

.hero-controls{

    display:flex;

    align-items:center;

    gap:20px;

}

.hero-nav-btn {
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    color: white;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
}

.hero-nav-btn:hover {
    background: white;
    color: black;
    border-color: white;
}

/* -------------------------------- */
/* Media Queries */
/* -------------------------------- */

@media(max-width:991px){

    .hero-bottom-inner{

        flex-direction:row;

        flex-wrap: wrap;

        align-items:center;

        gap:20px;

    }

    .hero-progress {
        order: -1; /* Move progress bar to the top on tablet */
        max-width: 100%;
        width: 100%;
    }

}

@media(max-width:768px){

    .hero{

        min-height:700px;

    }

    .hero-bottom{

        position:relative;

    }

    .hero-bottom-inner{

        padding:24px 0;

    }

    .hero-controls{

        gap: 12px;

    }

    .hero-nav-btn {
        width: 40px;
        height: 40px;
    }

}

</style>