---
const year = new Date().getFullYear();
---

<div class="footer-brand">

    <a
        href="/"
        class="footer-logo"
    >

        <img
            src="/images/logo-white.svg"
            alt="Bhandary Architects"
        />

    </a>

    <p class="footer-description">

        Designing timeless residential, commercial and hospitality spaces
        through thoughtful architecture, refined interiors and sustainable
        planning.

    </p>

    <div class="footer-stats">

        <div class="stat">

            <span class="number">30+</span>

            <span class="label">
                Years
            </span>

        </div>

        <div class="divider"></div>

        <div class="stat">

            <span class="number">500+</span>

            <span class="label">
                Projects
            </span>

        </div>

        <div class="divider"></div>

        <div class="stat">

            <span class="number">1995</span>

            <span class="label">
                Established
            </span>

        </div>

    </div>

    <div class="footer-tag">

        <span></span>

        <small>

            Architecture • Interiors • Planning

        </small>

    </div>

</div>

<style>

.footer-brand{

    position:relative;

    z-index:2;

}

.footer-logo{

    display:inline-block;

    margin-bottom:32px;

}

.footer-logo img{

    height:64px;

    width:auto;

    display:block;

    transition:

        transform .6s ease,

        filter .6s ease;

}

.footer-logo:hover img{

    transform:translateY(-3px);

    filter:

        drop-shadow(0 0 18px rgba(255,120,0,.35));

}

/* ---------------------------- */

.footer-description{

    max-width:430px;

    color:rgba(255,255,255,.72);

    line-height:1.9;

    margin-bottom:42px;

}

/* ---------------------------- */

.footer-stats{

    display:flex;

    align-items:center;

    gap:26px;

    margin-bottom:42px;

}

.stat{

    display:flex;

    flex-direction:column;

    gap:6px;

}

.number{

    font-size:32px;

    font-weight:700;

    color:var(--accent);

    line-height:1;

}

.label{

    font-size:11px;

    letter-spacing:3px;

    text-transform:uppercase;

    color:rgba(255,255,255,.5);

}

.divider{

    width:1px;

    height:42px;

    background:rgba(255,255,255,.08);

}

/* ---------------------------- */

.footer-tag{

    display:flex;

    align-items:center;

    gap:16px;

}

.footer-tag span{

    width:80px;

    height:2px;

    background:linear-gradient(

        90deg,

        var(--accent),

        transparent

    );

    transform-origin:left;

    animation:drawLine 2s ease infinite alternate;

}

.footer-tag small{

    color:rgba(255,255,255,.6);

    text-transform:uppercase;

    letter-spacing:3px;

    font-size:11px;

}

/* ---------------------------- */

@keyframes drawLine{

    from{

        transform:scaleX(.2);

        opacity:.4;

    }

    to{

        transform:scaleX(1);

        opacity:1;

    }

}

/* ---------------------------- */

@media(max-width:768px){

    .footer-logo img{

        height:54px;

    }

    .footer-stats{

        flex-wrap:wrap;

        gap:18px;

    }

    .divider{

        display:none;

    }

    .footer-tag{

        flex-direction:column;

        align-items:flex-start;

        gap:14px;

    }

}

</style>