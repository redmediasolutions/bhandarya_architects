---
const year = new Date().getFullYear();
---

<div class="footer-bottom">

    <div class="copyright">

        <span>

            © {year}

        </span>

        <span>

            Bhandary Architects

        </span>

    </div>

    <div class="footer-center">

        <div class="blueprint-line">

            <span></span>

        </div>

    </div>

    <div class="footer-credit">

        Developed by

        <a
            href="https://redmediasolutions.in"
            target="_blank"
            rel="noopener noreferrer"
        >

            Red Media Solutions

        </a>

    </div>

</div>

<style>

.footer-bottom{

    margin-top:90px;

    padding-top:36px;

    border-top:1px solid rgba(255,255,255,.08);

    display:grid;

    grid-template-columns:1fr auto 1fr;

    align-items:center;

    gap:40px;

}

/* ---------------------------- */

.copyright{

    display:flex;

    gap:14px;

    align-items:center;

    color:rgba(255,255,255,.55);

    font-size:13px;

    letter-spacing:.5px;

}

/* ---------------------------- */

.footer-credit{

    text-align:right;

    color:rgba(255,255,255,.45);

    font-size:13px;

}

.footer-credit a{

    color:white;

    text-decoration:none;

    transition:.35s;

}

.footer-credit a:hover{

    color:var(--accent);

}

/* ---------------------------- */

.blueprint-line{

    width:220px;

    height:18px;

    display:flex;

    align-items:center;

    justify-content:center;

}

.blueprint-line span{

    width:100%;

    height:2px;

    background:linear-gradient(

        90deg,

        transparent,

        var(--accent),

        transparent

    );

    animation:linePulse 3s ease-in-out infinite;

}

@keyframes linePulse{

    0%{

        transform:scaleX(.3);

        opacity:.35;

    }

    50%{

        transform:scaleX(1);

        opacity:1;

    }

    100%{

        transform:scaleX(.3);

        opacity:.35;

    }

}

/* ---------------------------- */

@media(max-width:900px){

    .footer-bottom{

        grid-template-columns:1fr;

        text-align:center;

        gap:24px;

    }

    .copyright{

        justify-content:center;

    }

    .footer-credit{

        text-align:center;

    }

    .blueprint-line{

        width:160px;

        margin:auto;

    }

}

</style>