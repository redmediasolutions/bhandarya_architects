---
const sectors = [
  {
    title: "Residences",
    count: "68",
    text: "Private homes, villas and premium residences crafted for modern living.",
    href: "/projects/residences",
  },
  {
    title: "Commercial",
    count: "31",
    text: "Corporate offices, retail environments and mixed-use developments.",
    href: "/projects/commercial",
  },
  {
    title: "Interior",
    count: "21",
    text: "Luxury interior environments tailored to each client.",
    href: "/projects/interior",
  },
  {
    title: "Educational Institutions",
    count: "21",
    text: "Learning environments designed for the next generation.",
    href: "/projects/educational",
  },
];
---

<section class="projects-intro section">

    <div class="background-word">

        PROJECTS

    </div>

    <div class="intro-container">

        <div class="intro-header">

            <span class="small-title">

                Featured Work

            </span>

            <h2>

                Every project tells
                <br>
                a different story.

            </h2>

            <p>

                Over two decades of architecture across
                residential, commercial and hospitality
                sectors, shaped by thoughtful design and
                timeless craftsmanship.

            </p>

        </div>

        <div class="stats">

            <div class="stat">

                <strong>120+</strong>

                <span>Projects</span>

            </div>

            <div class="stat">

                <strong>25+</strong>

                <span>Years</span>

            </div>

            <div class="stat">

                <strong>3.5M+</strong>

                <span>Sq.ft Designed</span>

            </div>

        </div>

        <div class="sector-grid">

            {
                sectors.map((sector,index)=>(

                    <article
    class="sector-card"
    style={`--delay:${index * 0.15}s`}
>
    <div class="sector-scan"></div>

<div class="corner tl"></div>
<div class="corner tr"></div>
<div class="corner bl"></div>
<div class="corner br"></div>
    <div class="sector-number">
        {sector.count}
    </div>

    <h3>
        {sector.title}
    </h3>

    <p>
        {sector.text}
    </p>

    <a
        href={sector.href}
        class="sector-button"
    >

        Explore

        <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
        >
            <path d="M5 12H19"/>
            <path d="M12 5L19 12L12 19"/>
        </svg>

    </a>

</article>

                ))
            }

        </div>

    </div>

</section>

<style>
.projects-intro{

    position:relative;

    overflow:hidden;

    background:#f7f5f2;

}

/* ================================================= */
/* Layout */
/* ================================================= */

.intro-container{

    width:min(1600px,92vw);

    margin:0 auto;

    position:relative;

    z-index:2;

}

.background-word{

    position:absolute;

    top:40px;

    left:50%;

    transform:translateX(-50%);

    font-size:220px;

    font-weight:700;

    letter-spacing:10px;

    color:rgba(0,0,0,.03);

    white-space:nowrap;

    pointer-events:none;

}

/* ================================================= */
/* Header */
/* ================================================= */

.intro-header{

    max-width:900px;

    margin:0 auto;

    text-align:center;

}

.intro-header h2{

    margin:18px 0 24px;

}

.intro-header p{

    max-width:720px;

    margin:auto;

}

/* ================================================= */
/* Statistics */
/* ================================================= */

.stats{

    margin:90px auto;

    display:grid;

    grid-template-columns:repeat(3,1fr);

    gap:50px;

    max-width:1000px;

    text-align:center;

}

.stat strong{

    display:block;

    font-size:70px;

    line-height:1;

    color:var(--accent);

}

.stat span{

    display:block;

    margin-top:12px;

    text-transform:uppercase;

    letter-spacing:2px;

    font-size:12px;

    color:#666;

}

/* ================================================= */
/* Grid */
/* ================================================= */

.sector-grid{

    display:grid;

    grid-template-columns:repeat(4,minmax(320px,1fr));

    gap:34px;

    margin-top:80px;

}

/* ================================================= */
/* Cards */
/* ================================================= */

.sector-card{

    position:relative;

    display:flex;

    flex-direction:column;

    justify-content:flex-end;

    min-height:420px;

    padding:50px;

    overflow:hidden;

    border-radius:22px;

    background:#111;

    color:#fff;

    border:1px solid rgba(255,255,255,.08);

    isolation:isolate;

    opacity:0;

    transform:translateY(60px);

    transition:
        opacity .8s ease,
        transform .6s cubic-bezier(.22,1,.36,1),
        box-shadow .45s,
        border-color .45s;

}

/* reveal */

.projects-intro.visible .sector-card{

    opacity:1;

    transform:none;

    transition-delay:var(--delay);

}

/* orange glow */

.sector-card::before{

    content:"";

    position:absolute;

    inset:-35%;

    background:

        radial-gradient(

            circle,

            rgba(255,120,0,.18),

            transparent 70%

        );

    opacity:.18;

    transition:.6s;

    z-index:0;

}

/* blueprint grid */

.sector-card::after{

    content:"";

    position:absolute;

    inset:0;

    background-image:

        linear-gradient(rgba(255,255,255,.04) 1px,transparent 1px),

        linear-gradient(90deg,rgba(255,255,255,.04) 1px,transparent 1px);

    background-size:40px 40px;

    animation:gridMove 16s linear infinite;

    opacity:.08;

    z-index:0;

}

/* scan animation */

.sector-scan{

    position:absolute;

    inset:0;

    overflow:hidden;

    z-index:1;

    pointer-events:none;

}

.sector-scan::before{

    content:"";

    position:absolute;

    top:-120%;

    left:0;

    width:100%;

    height:150%;

    background:

        linear-gradient(

            transparent,

            rgba(255,120,0,.08),

            transparent

        );

    animation:scanLine 7s linear infinite;

}

/* keep content above overlays */

.sector-number,
.sector-card h3,
.sector-card p,
.sector-button{

    position:relative;

    z-index:3;

}

.corner{

    position:absolute;

    width:34px;

    height:34px;

    border-color:var(--accent);

    opacity:.35;

    transition:.35s;

    z-index:4;

}

.tl{

    top:18px;

    left:18px;

    border-top:2px solid;

    border-left:2px solid;

}

.tr{

    top:18px;

    right:18px;

    border-top:2px solid;

    border-right:2px solid;

}

.bl{

    left:18px;

    bottom:18px;

    border-left:2px solid;

    border-bottom:2px solid;

}

.br{

    right:18px;

    bottom:18px;

    border-right:2px solid;

    border-bottom:2px solid;

}

.sector-card:hover .corner{

    opacity:1;

    transform:scale(1.15);

}

/* hover */

.sector-card:hover{

    transform:translateY(-12px);

    border-color:rgba(255,120,0,.35);

    box-shadow:

        0 35px 80px rgba(0,0,0,.28);

}

.sector-card:hover::before{

    opacity:.45;

}

/* ================================================= */
/* Typography */
/* ================================================= */

.sector-number{

    font-size:74px;

    line-height:1;

    font-weight:700;

    color:rgba(255,120,0,.18);

    margin-bottom:24px;

}

.sector-card h3{

    color:#fff;

    font-size:30px;

    margin-bottom:18px;

}

.sector-card p{

    color:rgba(255,255,255,.68);

    line-height:1.8;

    margin-bottom:36px;

}

/* ================================================= */
/* Button */
/* ================================================= */

.sector-button{

    position:relative;

    display:inline-flex;

    align-items:center;

    gap:12px;

    align-self:flex-start;

    overflow:hidden;

    padding:15px 28px;

    margin-top:auto;

    border-radius:999px;

    background:var(--accent);

    color:#fff;

    text-decoration:none;

    text-transform:uppercase;

    letter-spacing:2px;

    font-size:12px;

    font-weight:600;

    transition:.35s;

}

.sector-button::before{

    content:"";

    position:absolute;

    inset:0;

    background:

        linear-gradient(

            120deg,

            transparent,

            rgba(255,255,255,.35),

            transparent

        );

    transform:translateX(-180%);

}

.sector-button:hover::before{

    animation:buttonShine .8s forwards;

}

.sector-button:hover{

    background:#fff;

    color:#111;

    transform:translateY(-2px);

    box-shadow:0 12px 30px rgba(255,120,0,.35);

}

.sector-button svg{

    width:18px;

    height:18px;

    transition:.35s;

}

.sector-button:hover svg{

    transform:translateX(6px);

}

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:36px 36px;

    }

}

@keyframes scanLine{

    from{

        transform:translateY(-120%);

    }

    to{

        transform:translateY(220%);

    }

}

@keyframes buttonShine{

    to{

        transform:translateX(180%);

    }

}

/* ================================================= */
/* Responsive */
/* ================================================= */

@media(max-width:1400px){

    .sector-grid{

        grid-template-columns:repeat(2,1fr);

    }

}

@media(max-width:991px){

    .stats{

        grid-template-columns:1fr;

        gap:30px;

    }

    .sector-grid{

        grid-template-columns:1fr;

    }

}

@media(max-width:768px){

    .intro-container{

        width:92vw;

    }

    .background-word{

        font-size:110px;

    }

    .sector-card{

        padding:36px;

        min-height:auto;

    }

    .sector-number{

        font-size:56px;

    }

    .sector-card h3{

        font-size:24px;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const section=document.querySelector(".projects-intro");

    if(!section) return;

    const observer=new IntersectionObserver((entries)=>{

        if(entries[0].isIntersecting){

            section.classList.add("visible");

            observer.disconnect();

        }

    },{

        threshold:.2

    });

    observer.observe(section);

});

</script>