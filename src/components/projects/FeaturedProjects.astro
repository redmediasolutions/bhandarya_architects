---
import residential from "../../content/residential";
import commercial from "../../content/commercial";
import interior from "../../content/interiors";
import educational from "../../content/educational";

import { getResidentialImages } from "../../lib/residentialImages";
import { getCommercialImages } from "../../lib/commercialImages";
import { getInteriorImages } from "../../lib/interiorImages";
import { getEducationalImages } from "../../lib/educationalImages";

const projects = [

    ...residential.map(project => ({

        title: project.title,

        category: "Residential",

        image: getResidentialImages(project.folder).hero.src,

        href: `/projects/residences/${project.slug}`,

    })),

    ...commercial.map(project => ({

        title: project.title,

        category: "Commercial",

        image: getCommercialImages(project.folder).hero.src,

        href: `/projects/commercial/${project.slug}`,

    })),

    ...interior.map(project => ({

        title: project.title,

        category: "Interior",

        image: getInteriorImages(project.folder).hero.src,

        href: `/projects/interiors/${project.slug}`,

    })),

    ...educational.map(project => ({

        title: project.title,

        category: "Educational",

        image: getEducationalImages(project.folder).hero.src,

        href: `/projects/educational/${project.slug}`,

    }))

];
---

<section class="featured-projects section" id="featured">

    <div class="container">

        <div class="section-heading">

            <span class="small-title">

                Featured Projects

            </span>

            <h2>

                Our Projects

            </h2>

            <p>

                Every project reflects our pursuit of timeless
                architecture, thoughtful planning and enduring
                craftsmanship.

            </p>

        </div>

        <div class="featured-grid">

    {
        projects.map((project, index) => (

            <a
                href={project.href}
                class={`featured-card ${index === 0 ? "hero-card" : ""}`}
                style={`--delay:${index * .08}s`}
            >

                <img
                    src={project.image}
                    alt={project.title}
                    loading="lazy"
                />

                <div class="overlay">

                    <span>

                        {project.category}

                    </span>

                    <h3>

                        {project.title}

                    </h3>

                    <div class="line"></div>

                </div>

            </a>

        ))
    }

</div>

    </div>

</section>

<style>
  .featured-projects{

    background:var(--white);

    position:relative;

    overflow:hidden;

}

.section-heading{

    max-width:760px;

    margin:0 auto 80px;

    text-align:center;

}

.section-heading h2{

    margin:18px 0 24px;

}

.section-heading p{

    max-width:620px;

    margin:auto;

    color:#666;

}

/* ===================================== */
/* Grid */
/* ===================================== */

.featured-grid{

    display:grid;

    grid-template-columns:repeat(12,minmax(0,1fr));

    gap:26px;

}

.hero-card{

    grid-column:span 8;

    min-height:620px;

}

.featured-card:not(.hero-card){

    grid-column:span 4;

    min-height:360px;

}

/* ===================================== */

.featured-card{

    position:relative;

    display:block;

    overflow:hidden;

    isolation:isolate;

    border-radius:18px;

    background:#111;

    cursor:pointer;

    box-shadow:

        0 20px 60px rgba(0,0,0,.08);

    opacity:0;

    transform:

        translateY(60px)

        scale(.98);

    transition:

        opacity .8s,

        transform .8s cubic-bezier(.22,1,.36,1),

        box-shadow .45s;

}

.featured-projects.visible .featured-card{

    opacity:1;

    transform:none;

    transition-delay:var(--delay);

}

/* ===================================== */
/* Image */
/* ===================================== */

.featured-card img{

    position:absolute;

    inset:0;

    width:100%;

    height:100%;

    object-fit:cover;

    transform:scale(1.08);

    filter:

        brightness(.9)

        saturate(.9);

    transition:

        transform 2s cubic-bezier(.22,1,.36,1),

        filter .6s;

}

.hero-card img{

    animation:

        heroKenBurns 18s ease-in-out infinite alternate;

}

.featured-card:hover img{

    transform:scale(1.12);

    filter:

        brightness(1)

        saturate(1);

}

/* ===================================== */
/* Hover */
/* ===================================== */

.featured-card::before{

    content:"";

    position:absolute;

    inset:-35%;

    background:

        radial-gradient(

            circle,

            rgba(255,120,0,.18),

            transparent 72%

        );

    opacity:0;

    transition:.6s;

    z-index:2;

}

.featured-card:hover::before{

    opacity:1;

}

.featured-card::after{

    content:"";

    position:absolute;

    inset:18px;

    border:1px solid rgba(255,140,0,.35);

    opacity:0;

    transform:scale(.96);

    transition:.45s;

    z-index:4;

}

.featured-card:hover::after{

    opacity:1;

    transform:scale(1);

}

/* ===================================== */
/* Overlay */
/* ===================================== */

.overlay{

    position:absolute;

    inset:0;

    z-index:5;

    display:flex;

    flex-direction:column;

    justify-content:flex-end;

    padding:34px;

    background:

        linear-gradient(

            transparent 25%,

            rgba(0,0,0,.82)

        );

    transition:.45s;

}

.featured-card:hover .overlay{

    background:

        linear-gradient(

            transparent 15%,

            rgba(0,0,0,.92)

        );

}

.overlay span{

    display:block;

    margin-bottom:10px;

    color:rgba(255,255,255,.72);

    font-size:11px;

    letter-spacing:3px;

    text-transform:uppercase;

    transform:translateY(14px);

    opacity:0;

    transition:.45s;

}

.overlay h3{

    color:#fff;

    margin:0;

    font-size:clamp(26px,2vw,40px);

    line-height:1.2;

    transform:translateY(24px);

    transition:.55s cubic-bezier(.22,1,.36,1);

}

.featured-card:hover span{

    opacity:1;

    transform:none;

}

.featured-card:hover h3{

    transform:none;

}

.line{

    width:0;

    height:2px;

    margin-top:18px;

    background:var(--accent);

    transition:.55s;

}

.featured-card:hover .line{

    width:90px;

}

.featured-card:hover{

    transform:

        translateY(-8px);

    box-shadow:

        0 30px 70px rgba(0,0,0,.15);

}

/* ===================================== */

@keyframes heroKenBurns{

    from{

        transform:scale(1.05);

    }

    to{

        transform:

            scale(1.12)

            translateY(-16px);

    }

}

/* ===================================== */
/* Responsive */
/* ===================================== */

@media(max-width:1200px){

    .hero-card{

        grid-column:span 12;

    }

    .featured-card:not(.hero-card){

        grid-column:span 6;

    }

}

@media(max-width:991px){

    .featured-grid{

        grid-template-columns:repeat(2,1fr);

    }

    .hero-card{

        grid-column:1/-1;

        min-height:500px;

    }

    .featured-card:not(.hero-card){

        grid-column:auto;

        min-height:320px;

    }

}

@media(max-width:768px){

    .section-heading{

        margin-bottom:50px;

    }

    .featured-grid{

        grid-template-columns:1fr;

        gap:20px;

    }

    .hero-card,

    .featured-card{

        grid-column:auto;

        min-height:300px;

    }

    .hero-card{

        min-height:380px;

    }

    .overlay{

        padding:24px;

    }

    .overlay h3{

        font-size:24px;

    }

}
</style>

<script is:inline>

const featured=document.querySelector(".featured-projects");

const observer=new IntersectionObserver((entries)=>{

    if(entries[0].isIntersecting){

        featured.classList.add("visible");

        observer.disconnect();

    }

},{threshold:.2});

observer.observe(featured);

</script>