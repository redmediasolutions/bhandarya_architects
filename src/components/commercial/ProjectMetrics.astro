---
const metrics = [
  {
    value: 120,
    suffix: "+",
    label: "Projects Completed",
    description: "Commercial, residential and institutional developments."
  },
  {
    value: 3500000,
    suffix: "+",
    format: "million",
    label: "Sq.ft Designed",
    description: "Thoughtfully planned spaces across Karnataka."
  },
  {
    value: 25,
    suffix: "+",
    label: "Years Experience",
    description: "Delivering architecture with lasting value."
  },
  {
    value: 98,
    suffix: "%",
    label: "Client Satisfaction",
    description: "Built through collaboration and trust."
  }
];
---

<section class="project-metrics">

    <div class="grid-bg"></div>

    <div class="glow"></div>

    <div class="container">

        <div class="section-heading">

            <span class="small-title">

                By The Numbers

            </span>

            <h2>

                Building Confidence
                <br />
                Through Experience

            </h2>

            <p>

                Every commercial project contributes to a
                legacy of thoughtful planning, enduring
                architecture and long-term client relationships.

            </p>

        </div>

        <div class="metrics-grid">

            {
                metrics.map((metric,index)=>(

                    <article
                        class="metric-card"
                        style={`--delay:${index*.15}s`}
                    >

                        <h3
                            class="counter"
                            data-value={metric.value}
                            data-format={metric.format || ""}
                            data-suffix={metric.suffix}
                        >

                            0

                        </h3>

                        <h4>

                            {metric.label}

                        </h4>

                        <p>

                            {metric.description}

                        </p>

                    </article>

                ))
            }

        </div>

    </div>

</section>

<style>

.project-metrics{

    position:relative;

    overflow:hidden;

    background:#0e0e0e;

    padding:140px 0;

}

/* ====================== */

.grid-bg{

    position:absolute;

    inset:0;

    background-image:

        linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),

        linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);

    background-size:70px 70px;

    animation:gridMove 20s linear infinite;

}

.glow{

    position:absolute;

    width:850px;

    height:850px;

    left:-200px;

    bottom:-200px;

    border-radius:50%;

    background:

        radial-gradient(

            rgba(255,120,0,.16),

            transparent 70%

        );

    filter:blur(110px);

}

/* ====================== */

.container{

    position:relative;

    z-index:2;

}

.section-heading{

    text-align:center;

    max-width:760px;

    margin:0 auto 90px;

}

.section-heading h2{

    color:#fff;

    margin:18px 0;

}

.section-heading p{

    color:rgba(255,255,255,.72);

}

/* ====================== */

.metrics-grid{

    display:grid;

    grid-template-columns:repeat(4,1fr);

    gap:30px;

}

/* ====================== */

.metric-card{

    position:relative;

    padding:50px 40px;

    background:rgba(255,255,255,.03);

    border:1px solid rgba(255,255,255,.05);

    border-radius:20px;

    backdrop-filter:blur(12px);

    transition:.45s;

    opacity:0;

    transform:translateY(60px);

}

.project-metrics.visible .metric-card{

    opacity:1;

    transform:none;

    transition-delay:var(--delay);

}

.metric-card:hover{

    transform:translateY(-8px);

    border-color:rgba(255,120,0,.35);

    box-shadow:

        0 25px 60px rgba(0,0,0,.3);

}

.metric-card::before{

    content:"";

    position:absolute;

    inset:0;

    background:

        radial-gradient(

            circle at top right,

            rgba(255,120,0,.18),

            transparent 70%

        );

    opacity:0;

    transition:.5s;

}

.metric-card:hover::before{

    opacity:1;

}

/* ====================== */

.counter{

    font-size:68px;

    line-height:1;

    color:var(--accent);

    margin-bottom:18px;

}

.metric-card h4{

    color:white;

    margin-bottom:16px;

}

.metric-card p{

    color:rgba(255,255,255,.65);

    line-height:1.8;

}

/* ====================== */

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:70px 70px;

    }

}

/* ====================== */

@media(max-width:991px){

    .metrics-grid{

        grid-template-columns:repeat(2,1fr);

    }

}

@media(max-width:768px){

    .metrics-grid{

        grid-template-columns:1fr;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const section=document.querySelector(".project-metrics");

    if(!section) return;

    const counters=section.querySelectorAll(".counter");

    const observer=new IntersectionObserver((entries)=>{

        if(entries[0].isIntersecting){

            section.classList.add("visible");

            counters.forEach(counter=>{

                const target=parseInt(counter.dataset.value);

                const suffix=counter.dataset.suffix || "";

                const format=counter.dataset.format;

                let current=0;

                const increment=target/80;

                const update=()=>{

                    current+=increment;

                    if(current>=target){

                        if(format==="million"){

                            counter.textContent=(target/1000000).toFixed(1)+suffix;

                        }else{

                            counter.textContent=Math.round(target)+suffix;

                        }

                        return;

                    }

                    if(format==="million"){

                        counter.textContent=(current/1000000).toFixed(1)+suffix;

                    }else{

                        counter.textContent=Math.round(current)+suffix;

                    }

                    requestAnimationFrame(update);

                };

                update();

            });

            observer.disconnect();

        }

    },{

        threshold:.25

    });

    observer.observe(section);

});

</script>