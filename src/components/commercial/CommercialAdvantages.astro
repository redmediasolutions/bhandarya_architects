---
const advantages = [
  {
    title: "Business First",
    text: "Every design decision begins with understanding your operational goals, brand identity and long-term business strategy.",
    icon: "▣"
  },
  {
    title: "Efficient Planning",
    text: "Thoughtful circulation, optimized layouts and flexible planning improve usability while reducing operational costs.",
    icon: "◫"
  },
  {
    title: "Timeless Architecture",
    text: "Buildings designed to remain relevant, functional and visually distinguished for decades.",
    icon: "◧"
  },
  {
    title: "Sustainable Design",
    text: "Passive strategies, natural daylight and environmentally responsible materials integrated from concept stage.",
    icon: "◎"
  },
  {
    title: "Technical Expertise",
    text: "Close coordination with consultants ensures precision throughout planning, documentation and execution.",
    icon: "⬢"
  },
  {
    title: "End-to-End Delivery",
    text: "From concept design to construction supervision, every stage is managed with architectural clarity.",
    icon: "◈"
  }
];
---

<section class="commercial-advantages">

    <div class="background-grid"></div>
    <div class="background-glow"></div>

    <div class="container">

        <div class="section-heading">

            <span class="small-title">

                Why Businesses Choose Us

            </span>

            <h2>

                Architecture That Creates
                <br />
                Long-Term Value

            </h2>

            <p>

                Commercial buildings should strengthen brands,
                improve productivity and create lasting value.
                Our approach combines design excellence with
                practical business thinking.

            </p>

        </div>

        <div class="advantages-grid">

            {
                advantages.map((item,index)=>(

                    <article
                        class="advantage-card"
                        style={`--delay:${index*.12}s`}
                    >

                        <div class="icon">

                            {item.icon}

                        </div>

                        <h3>

                            {item.title}

                        </h3>

                        <p>

                            {item.text}

                        </p>

                        <div class="accent-line"></div>

                    </article>

                ))
            }

        </div>

    </div>

</section>

<style>

.commercial-advantages{

    position:relative;

    overflow:hidden;

    background:#111;

    padding:140px 0;

}

/* ======================= */

.background-grid{

    position:absolute;

    inset:0;

    background-image:
        linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),
        linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);

    background-size:60px 60px;

    animation:gridMove 20s linear infinite;

}

.background-glow{

    position:absolute;

    width:900px;

    height:900px;

    right:-250px;

    top:-250px;

    border-radius:50%;

    background:

        radial-gradient(

            rgba(255,120,0,.16),

            transparent 70%

        );

    filter:blur(120px);

}

/* ======================= */

.container{

    position:relative;

    z-index:2;

}

.section-heading{

    text-align:center;

    max-width:760px;

    margin:0 auto 80px;

}

.section-heading h2{

    color:white;

    margin:18px 0;

}

.section-heading p{

    color:rgba(255,255,255,.72);

}

/* ======================= */

.advantages-grid{

    display:grid;

    grid-template-columns:repeat(3,1fr);

    gap:30px;

}

/* ======================= */

.advantage-card{

    position:relative;

    overflow:hidden;

    padding:45px;

    border-radius:20px;

    background:rgba(255,255,255,.03);

    border:1px solid rgba(255,255,255,.05);

    backdrop-filter:blur(10px);

    transition:.5s;

    opacity:0;

    transform:translateY(60px);

}

.commercial-advantages.visible .advantage-card{

    opacity:1;

    transform:none;

    transition-delay:var(--delay);

}

/* ======================= */

.advantage-card::before{

    content:"";

    position:absolute;

    inset:0;

    background:

        radial-gradient(

            circle at top right,

            rgba(255,120,0,.18),

            transparent 70%

        );

    opacity:0;

    transition:.5s;

}

.advantage-card:hover{

    transform:translateY(-10px);

    border-color:rgba(255,120,0,.35);

    box-shadow:

        0 30px 70px rgba(0,0,0,.28);

}

.advantage-card:hover::before{

    opacity:1;

}

/* ======================= */

.icon{

    width:74px;

    height:74px;

    border-radius:50%;

    display:flex;

    align-items:center;

    justify-content:center;

    background:rgba(255,120,0,.12);

    border:1px solid rgba(255,120,0,.35);

    color:var(--accent);

    font-size:28px;

    margin-bottom:28px;

}

.advantage-card h3{

    color:white;

    margin-bottom:18px;

    font-size:28px;

}

.advantage-card p{

    color:rgba(255,255,255,.68);

    line-height:1.8;

}

.accent-line{

    width:0;

    height:2px;

    margin-top:28px;

    background:var(--accent);

    transition:.45s;

}

.advantage-card:hover .accent-line{

    width:90px;

}

/* ======================= */

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:60px 60px;

    }

}

/* ======================= */

@media(max-width:991px){

    .advantages-grid{

        grid-template-columns:repeat(2,1fr);

    }

}

@media(max-width:768px){

    .advantages-grid{

        grid-template-columns:1fr;

    }

    .advantage-card{

        padding:35px;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const section=document.querySelector(".commercial-advantages");

    if(!section) return;

    const observer=new IntersectionObserver((entries)=>{

        if(entries[0].isIntersecting){

            section.classList.add("visible");

            observer.disconnect();

        }

    },{

        threshold:.2

    });

    observer.observe(section);

});

</script>