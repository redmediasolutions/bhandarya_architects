---
import { img } from "../../consts";

const projects = [
  {
    title: "Corporate Headquarters",
    category: "Corporate Office",
    location: "Mangalore",
    area: "48,500 sq.ft",
    year: "2025",
    image: img("2026/05/Copy-of-01.webp"),
    href: "/projects/corporate-headquarters"
  },
  {
    title: "Retail Experience Centre",
    category: "Retail",
    location: "Udupi",
    area: "18,200 sq.ft",
    year: "2024",
    image: img("2026/05/Copy-of-01.png"),
    href: "#"
  },
  {
    title: "Business Park",
    category: "Commercial Campus",
    location: "Bangalore",
    area: "72,000 sq.ft",
    year: "2023",
    image: img("2026/03/Screenshot-2026-03-25-154852.png"),
    href: "#"
  },
  {
    title: "Educational Campus",
    category: "Institutional",
    location: "Mangalore",
    area: "96,000 sq.ft",
    year: "2022",
    image: img("2026/05/Copy-of-01.webp"),
    href: "#"
  }
];
---

<section class="commercial-projects">

    <div class="container">

        <div class="section-heading">

            <span class="small-title">

                Portfolio

            </span>

            <h2>

                Selected Commercial Projects

            </h2>

            <p>

                Spaces that combine functionality, flexibility
                and architectural excellence.

            </p>

        </div>

        <div class="projects-list">

            {
                projects.map((project,index)=>(

                    <article
                        class={`project-row ${index%2 ? "reverse" : ""}`}
                    >

                        <a
                            href={project.href}
                            class="project-image"
                        >

                            <img
                                src={project.image}
                                alt={project.title}
                            />

                        </a>

                        <div class="project-content">

                            <span class="project-category">

                                {project.category}

                            </span>

                            <h3>

                                {project.title}

                            </h3>

                            <p>

                                Thoughtfully designed to balance
                                operational efficiency with timeless
                                architectural expression, creating
                                spaces that elevate both business and
                                user experience.

                            </p>

                            <div class="meta">

                                <div>

                                    <small>

                                        Location

                                    </small>

                                    <strong>

                                        {project.location}

                                    </strong>

                                </div>

                                <div>

                                    <small>

                                        Area

                                    </small>

                                    <strong>

                                        {project.area}

                                    </strong>

                                </div>

                                <div>

                                    <small>

                                        Year

                                    </small>

                                    <strong>

                                        {project.year}

                                    </strong>

                                </div>

                            </div>

                            <a
                                href={project.href}
                                class="project-link"
                            >

                                View Project →

                            </a>

                        </div>

                    </article>

                ))
            }

        </div>

    </div>

</section>

<style>

.commercial-projects{

    padding:140px 0;

    background:#faf8f5;

}

.section-heading{

    max-width:760px;

    margin:0 auto 90px;

    text-align:center;

}

.section-heading h2{

    margin:18px 0;

}

/* ============================ */

.projects-list{

    display:flex;

    flex-direction:column;

    gap:120px;

}

/* ============================ */

.project-row{

    display:grid;

    grid-template-columns:1.15fr .85fr;

    gap:70px;

    align-items:center;

}

.project-row.reverse{

    grid-template-columns:.85fr 1.15fr;

}

.project-row.reverse .project-image{

    order:2;

}

.project-row.reverse .project-content{

    order:1;

}

/* ============================ */

.project-image{

    position:relative;

    overflow:hidden;

    border-radius:20px;

    display:block;

}

.project-image img{

    width:100%;

    display:block;

    transform:scale(1.08);

    transition:2s cubic-bezier(.22,1,.36,1);

}

.project-image:hover img{

    transform:scale(1.15);

}

.project-image::before{

    content:"";

    position:absolute;

    inset:0;

    background:

        linear-gradient(

            transparent,

            rgba(0,0,0,.12)

        );

}

.project-image::after{

    content:"";

    position:absolute;

    inset:20px;

    border:1px solid rgba(255,255,255,.35);

    opacity:0;

    transform:scale(.95);

    transition:.5s;

}

.project-image:hover::after{

    opacity:1;

    transform:scale(1);

}

/* ============================ */

.project-category{

    color:var(--accent);

    letter-spacing:2px;

    text-transform:uppercase;

    font-size:12px;

    font-weight:600;

}

.project-content h3{

    margin:16px 0 24px;

    font-size:48px;

}

.project-content p{

    color:#666;

    line-height:1.9;

    margin-bottom:36px;

}

/* ============================ */

.meta{

    display:grid;

    grid-template-columns:repeat(3,1fr);

    gap:24px;

    padding:34px 0;

    border-top:1px solid rgba(0,0,0,.08);

    border-bottom:1px solid rgba(0,0,0,.08);

    margin-bottom:34px;

}

.meta small{

    display:block;

    margin-bottom:8px;

    font-size:11px;

    text-transform:uppercase;

    letter-spacing:2px;

    color:#888;

}

.meta strong{

    font-size:16px;

}

/* ============================ */

.project-link{

    color:var(--accent);

    text-decoration:none;

    text-transform:uppercase;

    letter-spacing:2px;

    font-size:12px;

    font-weight:600;

    transition:.35s;

}

.project-link:hover{

    letter-spacing:3px;

}

/* ============================ */
/* Reveal Animation */
/* ============================ */

.project-row{

    opacity:0;

    transform:translateY(70px);

    transition:.9s cubic-bezier(.22,1,.36,1);

}

.commercial-projects.visible .project-row{

    opacity:1;

    transform:none;

}

.commercial-projects.visible .project-row:nth-child(1){

    transition-delay:.1s;

}

.commercial-projects.visible .project-row:nth-child(2){

    transition-delay:.25s;

}

.commercial-projects.visible .project-row:nth-child(3){

    transition-delay:.4s;

}

.commercial-projects.visible .project-row:nth-child(4){

    transition-delay:.55s;

}

/* ============================ */

@media(max-width:991px){

    .project-row,

    .project-row.reverse{

        grid-template-columns:1fr;

        gap:40px;

    }

    .project-row.reverse .project-image,

    .project-row.reverse .project-content{

        order:initial;

    }

}

@media(max-width:768px){

    .project-content h3{

        font-size:34px;

    }

    .meta{

        grid-template-columns:1fr;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const section=document.querySelector(".commercial-projects");

    if(!section) return;

    const observer=new IntersectionObserver((entries)=>{

        if(entries[0].isIntersecting){

            section.classList.add("visible");

            observer.disconnect();

        }

    },{

        threshold:.2

    });

    observer.observe(section);

});

</script>