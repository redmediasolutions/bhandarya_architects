---
const faqs = [
  {
    question: "What types of commercial projects do you undertake?",
    answer:
      "We design corporate offices, retail spaces, educational institutions, hospitality projects, healthcare facilities, mixed-use developments and other commercial environments tailored to each client's operational needs."
  },
  {
    question: "Can you manage projects from concept to completion?",
    answer:
      "Yes. We provide end-to-end architectural services including feasibility studies, concept design, planning approvals, construction documentation, consultant coordination and site supervision."
  },
  {
    question: "Do you incorporate sustainable design strategies?",
    answer:
      "Absolutely. Passive cooling, daylight optimisation, energy-efficient systems, locally sourced materials and environmentally responsible planning are integrated wherever appropriate."
  },
  {
    question: "How long does a commercial project typically take?",
    answer:
      "Project duration depends on scale and complexity. Smaller commercial developments may take a few months while larger campuses and institutional projects can extend over multiple phases."
  },
  {
    question: "Do you work outside Mangalore?",
    answer:
      "Yes. While our studio is based in Mangalore, we undertake projects throughout Karnataka and across India."
  }
];
---

<section class="commercial-faq">

    <div class="background-grid"></div>

    <div class="container">

        <div class="section-heading">

            <span class="small-title">

                Frequently Asked Questions

            </span>

            <h2>

                Questions We
                <br />
                Often Receive

            </h2>

            <p>

                Everything you need to know before starting your
                commercial architecture project.

            </p>

        </div>

        <div class="faq-list">

            {
                faqs.map((faq)=>(
                    <article class="faq-item">

                        <button class="faq-question">

                            <span>

                                {faq.question}

                            </span>

                            <div class="icon">

                                +

                            </div>

                        </button>

                        <div class="faq-answer">

                            <p>

                                {faq.answer}

                            </p>

                        </div>

                    </article>
                ))
            }

        </div>

    </div>

</section>

<style>

.commercial-faq{

    position:relative;

    overflow:hidden;

    background:#fff;

    padding:140px 0;

}

/* ================================= */

.background-grid{

    position:absolute;

    inset:0;

    background-image:

        linear-gradient(rgba(0,0,0,.02) 1px,transparent 1px),

        linear-gradient(90deg,rgba(0,0,0,.02) 1px,transparent 1px);

    background-size:70px 70px;

    animation:gridMove 18s linear infinite;

}

/* ================================= */

.container{

    position:relative;

    z-index:2;

}

.section-heading{

    max-width:760px;

    margin:0 auto 70px;

    text-align:center;

}

.section-heading h2{

    margin:18px 0;

}

/* ================================= */

.faq-list{

    max-width:950px;

    margin:auto;

}

.faq-item{

    border-bottom:1px solid rgba(0,0,0,.08);

}

.faq-question{

    width:100%;

    padding:34px 0;

    display:flex;

    justify-content:space-between;

    align-items:center;

    background:none;

    border:none;

    cursor:pointer;

    text-align:left;

    font:inherit;

}

.faq-question span{

    font-size:24px;

    font-weight:500;

    color:#111;

    transition:.35s;

}

.icon{

    width:44px;

    height:44px;

    border-radius:50%;

    display:flex;

    align-items:center;

    justify-content:center;

    background:#f5f5f5;

    color:var(--accent);

    font-size:24px;

    transition:.35s;

}

.faq-item.active .icon{

    transform:rotate(45deg);

    background:var(--accent);

    color:white;

}

.faq-item.active .faq-question span{

    color:var(--accent);

}

/* ================================= */

.faq-answer{

    max-height:0;

    overflow:hidden;

    transition:max-height .45s ease;

}

.faq-answer p{

    padding:0 0 30px;

    color:#666;

    line-height:1.9;

    max-width:760px;

}

/* ================================= */

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:70px 70px;

    }

}

/* ================================= */

@media(max-width:768px){

    .faq-question{

        gap:20px;

        align-items:flex-start;

    }

    .faq-question span{

        font-size:20px;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    document.querySelectorAll(".faq-item").forEach(item=>{

        const button=item.querySelector(".faq-question");

        const answer=item.querySelector(".faq-answer");

        button.addEventListener("click",()=>{

            const open=item.classList.contains("active");

            document.querySelectorAll(".faq-item").forEach(i=>{

                i.classList.remove("active");

                i.querySelector(".faq-answer").style.maxHeight=null;

            });

            if(!open){

                item.classList.add("active");

                answer.style.maxHeight=answer.scrollHeight+"px";

            }

        });

    });

});

</script>