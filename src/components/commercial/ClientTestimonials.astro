---
import { img } from "../../consts";

const testimonials = [
  {
    quote:
      "Bhandary Architects transformed our vision into a workplace that not only reflects our brand but significantly improved collaboration across departments.",
    client: "Rajesh Shetty",
    role: "Managing Director",
    company: "Confidential Corporate Client",
    image: img("2026/05/Copy-of-01.webp")
  },
  {
    quote:
      "Their understanding of commercial planning, circulation and execution made the entire process effortless from concept to completion.",
    client: "Anita Rao",
    role: "Director",
    company: "Retail Development Group",
    image: img("2026/05/Copy-of-01.png")
  },
  {
    quote:
      "Professional, detail-oriented and deeply collaborative. The building continues to exceed our expectations even years after completion.",
    client: "Vivek Bhat",
    role: "Chairman",
    company: "Educational Institution",
    image: img("2026/03/Screenshot-2026-03-25-154852.png")
  }
];
---

<section class="client-testimonials">

    <div class="grid-bg"></div>
    <div class="glow"></div>

    <div class="container">

        <div class="section-heading">

            <span class="small-title">

                Client Stories

            </span>

            <h2>

                Trusted By Businesses
                <br>
                Across Karnataka

            </h2>

        </div>

        <div class="testimonial-slider">

            {
                testimonials.map((item,index)=>(

                    <article
                        class={`testimonial ${index===0 ? "active" : ""}`}
                    >

                        <div class="testimonial-image">

                            <img
                                src={item.image}
                                alt={item.company}
                            />

                        </div>

                        <div class="testimonial-content">

                            <div class="quote-mark">

                                “

                            </div>

                            <blockquote>

                                {item.quote}

                            </blockquote>

                            <div class="client">

                                <strong>

                                    {item.client}

                                </strong>

                                <span>

                                    {item.role}

                                </span>

                                <small>

                                    {item.company}

                                </small>

                            </div>

                        </div>

                    </article>

                ))
            }

        </div>

        <div class="slider-nav">

            {
                testimonials.map((_,index)=>(

                    <button
                        class={`dot ${index===0 ? "active" : ""}`}
                        data-slide={index}
                    ></button>

                ))
            }

        </div>

    </div>

</section>

<style>

.client-testimonials{

    position:relative;

    overflow:hidden;

    background:#111;

    padding:140px 0;

}

/* ================================= */

.grid-bg{

    position:absolute;

    inset:0;

    background-image:
        linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),
        linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);

    background-size:70px 70px;

    animation:gridMove 18s linear infinite;

}

.glow{

    position:absolute;

    width:900px;

    height:900px;

    right:-250px;

    top:-250px;

    border-radius:50%;

    background:
        radial-gradient(
            rgba(255,120,0,.16),
            transparent 70%
        );

    filter:blur(120px);

}

.container{

    position:relative;

    z-index:2;

}

.section-heading{

    text-align:center;

    margin-bottom:70px;

}

.section-heading h2{

    color:white;

    margin-top:18px;

}

/* ================================= */

.testimonial-slider{

    position:relative;

    min-height:520px;

}

.testimonial{

    position:absolute;

    inset:0;

    display:grid;

    grid-template-columns:1fr 1fr;

    gap:70px;

    align-items:center;

    opacity:0;

    visibility:hidden;

    transition:.7s;

}

.testimonial.active{

    opacity:1;

    visibility:visible;

}

.testimonial-image{

    overflow:hidden;

    border-radius:22px;

}

.testimonial-image img{

    width:100%;

    display:block;

    height:100%;

    object-fit:cover;

}

/* ================================= */

.quote-mark{

    color:var(--accent);

    font-size:120px;

    line-height:1;

    margin-bottom:20px;

}

blockquote{

    color:white;

    font-size:30px;

    line-height:1.6;

    margin-bottom:50px;

}

.client strong{

    display:block;

    color:white;

    font-size:22px;

}

.client span{

    display:block;

    margin-top:8px;

    color:var(--accent);

}

.client small{

    display:block;

    margin-top:10px;

    color:rgba(255,255,255,.65);

}

/* ================================= */

.slider-nav{

    display:flex;

    justify-content:center;

    gap:14px;

    margin-top:70px;

}

.dot{

    width:12px;

    height:12px;

    border-radius:50%;

    border:none;

    background:#555;

    cursor:pointer;

    transition:.35s;

}

.dot.active{

    background:var(--accent);

    transform:scale(1.3);

}

/* ================================= */

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:70px 70px;

    }

}

/* ================================= */

@media(max-width:991px){

    .testimonial{

        grid-template-columns:1fr;

        gap:40px;

    }

}

@media(max-width:768px){

    blockquote{

        font-size:22px;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const slides=document.querySelectorAll(".testimonial");

    const dots=document.querySelectorAll(".dot");

    let current=0;

    function showSlide(index){

        slides.forEach(s=>s.classList.remove("active"));

        dots.forEach(d=>d.classList.remove("active"));

        slides[index].classList.add("active");

        dots[index].classList.add("active");

        current=index;

    }

    dots.forEach((dot,index)=>{

        dot.addEventListener("click",()=>showSlide(index));

    });

    setInterval(()=>{

        showSlide((current+1)%slides.length);

    },6000);

});

</script>