---
import { img } from "../../consts";

const hero = img("2026/03/Screenshot-2026-03-25-154852.png");
---

<section
    class="commercial-hero"
    style={`background-image:url('${hero}')`}
>

    <div class="hero-overlay"></div>
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>

    <div class="container hero-container">

        <div class="hero-content">

            <span class="small-title reveal">

                Commercial Architecture

            </span>

            <h1 class="reveal delay-1">

                Spaces That
                <br />
                Power Business
                <br />
                Growth.

            </h1>

            <p class="reveal delay-2">

                From corporate headquarters and retail environments
                to institutions and mixed-use developments,
                we create architecture that elevates brands,
                enhances productivity and delivers long-term value.

            </p>

            <div class="hero-buttons reveal delay-3">

                <a
                    href="#featured"
                    class="btn"
                >

                    Explore Projects

                </a>

            </div>

        </div>

        <aside class="hero-stats reveal delay-4">

            <div>

                <strong>31+</strong>

                <span>Commercial Projects</span>

            </div>

            <div>

                <strong>1.2M+</strong>

                <span>Sq.ft Delivered</span>

            </div>

            <div>

                <strong>25+</strong>

                <span>Years Experience</span>

            </div>

        </aside>

    </div>

    <div class="sector-nav">

        <a href="#offices">

            Offices

        </a>

        <a href="#retail">

            Retail

        </a>

        <a href="#institutional">

            Institutional

        </a>

        <a href="#hospitality">

            Hospitality

        </a>

    </div>

    <div class="scroll-indicator">

        <span></span>

    </div>

</section>