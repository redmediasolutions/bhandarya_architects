---
import { img } from "../../consts";

const sectors = [
  {
    title: "Corporate Offices",
    description: "Workspaces that improve collaboration, productivity and brand identity.",
    image: img("2026/03/Screenshot-2026-03-25-154852.png"),
    href:"#offices"
  },
  {
    title: "Retail & Showrooms",
    description: "Customer-focused environments designed to elevate every interaction.",
    image: img("2026/05/Copy-of-01.webp"),
    href:"#retail"
  },
  {
    title: "Educational",
    description: "Learning environments that inspire growth and innovation.",
    image: img("2026/05/Copy-of-01.png"),
    href:"#education"
  },
  {
    title: "Hospitality",
    description: "Hotels, resorts and destination spaces designed around memorable experiences.",
    image: img("2026/05/Copy-of-01.webp"),
    href:"#hospitality"
  }
];
---

<section class="commercial-sectors">

    <div class="container">

        <div class="section-heading">

            <span class="small-title">

                Sectors We Design

            </span>

            <h2>

                Commercial Architecture
                <br />
                Across Every Industry

            </h2>

            <p>

                Every business has unique operational needs.
                Our architecture responds with thoughtful planning,
                efficient circulation and timeless design.

            </p>

        </div>

        <div class="sector-grid">

            {
                sectors.map((sector,index)=>(
                    <a
                        href={sector.href}
                        class={`sector-card ${index===0 ? "large" : ""}`}
                    >

                        <img
                            src={sector.image}
                            alt={sector.title}
                        />

                        <div class="overlay">

                            <span>

                                Commercial Sector

                            </span>

                            <h3>

                                {sector.title}

                            </h3>

                            <p>

                                {sector.description}

                            </p>

                            <div class="line"></div>

                            <div class="link">

                                Explore →

                            </div>

                        </div>

                    </a>
                ))
            }

        </div>

    </div>

</section>

<style>

.commercial-sectors{

    background:#fff;

    padding:120px 0;

}

.section-heading{

    text-align:center;

    max-width:760px;

    margin:0 auto 70px;

}

.section-heading h2{

    margin:18px 0;

}

/* ========================== */

.sector-grid{

    display:grid;

    grid-template-columns:repeat(12,1fr);

    gap:26px;

}

.large{

    grid-column:span 7;

    min-height:620px;

}

.sector-card:not(.large){

    grid-column:span 5;

    min-height:295px;

}

.sector-card{

    position:relative;

    display:block;

    overflow:hidden;

    border-radius:20px;

    isolation:isolate;

    background:#111;

    transition:.5s;

}

/* ========================== */

.sector-card img{

    position:absolute;

    inset:0;

    width:100%;

    height:100%;

    object-fit:cover;

    transform:scale(1.08);

    transition:2s cubic-bezier(.22,1,.36,1);

}

.sector-card:hover img{

    transform:scale(1.15);

}

/* ========================== */

.sector-card::before{

    content:"";

    position:absolute;

    inset:0;

    background-image:

        linear-gradient(rgba(255,255,255,.04) 1px,transparent 1px),

        linear-gradient(90deg,rgba(255,255,255,.04) 1px,transparent 1px);

    background-size:40px 40px;

    opacity:.12;

    animation:gridMove 16s linear infinite;

    z-index:2;

}

.sector-card::after{

    content:"";

    position:absolute;

    inset:-30%;

    background:

        radial-gradient(

            circle,

            rgba(255,120,0,.18),

            transparent 70%

        );

    opacity:0;

    transition:.6s;

    z-index:1;

}

.sector-card:hover::after{

    opacity:1;

}

/* ========================== */

.overlay{

    position:absolute;

    inset:0;

    z-index:5;

    display:flex;

    flex-direction:column;

    justify-content:flex-end;

    padding:42px;

    background:

        linear-gradient(

            transparent,

            rgba(0,0,0,.88)

        );

}

.overlay span{

    color:white;

    text-transform:uppercase;

    letter-spacing:2px;

    font-size:11px;

    opacity:.7;

}

.overlay h3{

    color:white;

    margin:14px 0;

    font-size:34px;

}

.overlay p{

    color:rgba(255,255,255,.72);

    max-width:420px;

    line-height:1.7;

}

.line{

    width:0;

    height:2px;

    margin:24px 0;

    background:var(--accent);

    transition:.55s;

}

.sector-card:hover .line{

    width:90px;

}

.link{

    color:var(--accent);

    font-size:12px;

    text-transform:uppercase;

    letter-spacing:2px;

    font-weight:600;

}

/* ========================== */

.sector-card{

    opacity:0;

    transform:translateY(70px);

}

.commercial-sectors.visible .sector-card{

    opacity:1;

    transform:none;

}

.commercial-sectors.visible .sector-card:nth-child(1){

    transition-delay:.1s;

}

.commercial-sectors.visible .sector-card:nth-child(2){

    transition-delay:.25s;

}

.commercial-sectors.visible .sector-card:nth-child(3){

    transition-delay:.4s;

}

.commercial-sectors.visible .sector-card:nth-child(4){

    transition-delay:.55s;

}

/* ========================== */

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:40px 40px;

    }

}

/* ========================== */

@media(max-width:991px){

    .sector-grid{

        grid-template-columns:1fr;

    }

    .large,

    .sector-card:not(.large){

        grid-column:auto;

        min-height:420px;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const section=document.querySelector(".commercial-sectors");

    if(!section) return;

    const observer=new IntersectionObserver((entries)=>{

        if(entries[0].isIntersecting){

            section.classList.add("visible");

            observer.disconnect();

        }

    },{

        threshold:.2

    });

    observer.observe(section);

});

</script>