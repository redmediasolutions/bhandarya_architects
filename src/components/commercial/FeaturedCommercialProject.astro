---
import projects from "../../content/commercial";
import { getCommercialImages } from "../../lib/commercialImages";

const project =
    projects.find((p) => p.featured) ?? projects[0];

const { hero } = getCommercialImages(project.folder);
---

<section class="featured-commercial">

    <div class="background-grid"></div>

    <div class="container">

        <div class="section-heading">

            <span class="small-title">

                Featured Commercial Project

            </span>

            <h2>

                Featured Project

            </h2>

        </div>

        <div class="project-grid">

            <!-- Content -->

            <div class="project-content">

                <span class="category">

                    {project.subtitle}

                </span>

                <h3>

                    {project.title}

                </h3>

                <div class="accent-line"></div>

                {
                    project.description.slice(0, 2).map((paragraph) => (

                        <p>

                            {paragraph}

                        </p>

                    ))
                }

                <div class="meta-grid">

                    <div>

                        <small>

                            Project Type

                        </small>

                        <strong>

                            {project.subtitle}

                        </strong>

                    </div>

                    <div>

                        <small>

                            Location

                        </small>

                        <strong>

                            {project.location}

                        </strong>

                    </div>

                    {
                        project.area && (

                            <div>

                                <small>

                                    Area

                                </small>

                                <strong>

                                    {project.area}

                                </strong>

                            </div>

                        )
                    }

                    <div>

                        <small>

                            {
                                project.status === "Completed"
                                    ? "Completed"
                                    : "Status"
                            }

                        </small>

                        <strong>

                            {
                                project.status === "Completed"
                                    ? project.year
                                    : project.status
                            }

                        </strong>

                    </div>

                </div>

                <a
                    href={`/projects/commercial/${project.slug}`}
                    class="btn"
                >

                    View Project

                </a>

            </div>

            <!-- Image -->

            <a
                href={`/projects/commercial/${project.slug}`}
                class="project-image"
            >

                <img
                    src={hero.src}
                    alt={project.title}
                    loading="eager"
                />

                <div class="image-overlay"></div>

                <div class="image-tag">

                    Featured Project

                </div>

            </a>

        </div>

    </div>

</section>

<style>

.featured-commercial{

    position:relative;

    overflow:hidden;

    background:#111;

    padding:140px 0;

}

.background-grid{

    position:absolute;

    inset:0;

    background-image:
        linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),
        linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);

    background-size:70px 70px;

    animation:gridMove 18s linear infinite;

}

.container{

    position:relative;

    z-index:2;

}

.section-heading{

    text-align:center;

    margin-bottom:80px;

}

.section-heading h2{

    color:#fff;

    margin-top:18px;

}

/* ================================= */

.project-grid{

    display:grid;

    grid-template-columns:.95fr 1.1fr;

    gap:80px;

    align-items:center;

}

/* ================================= */

.project-content{

    opacity:0;

    transform:translateX(-60px);

    transition:.9s;

}

.featured-commercial.visible .project-content{

    opacity:1;

    transform:none;

}

.category{

    color:var(--accent);

    text-transform:uppercase;

    letter-spacing:3px;

    font-size:12px;

    font-weight:600;

}

.project-content h3{

    color:#fff;

    font-size:clamp(42px,5vw,64px);

    margin:18px 0;

}

.accent-line{

    width:90px;

    height:2px;

    background:var(--accent);

    margin-bottom:32px;

}

.project-content p{

    color:rgba(255,255,255,.72);

    line-height:1.9;

    margin-bottom:24px;

}

.meta-grid{

    display:grid;

    grid-template-columns:repeat(2,1fr);

    gap:30px;

    margin:50px 0;

}

.meta-grid small{

    display:block;

    color:#777;

    text-transform:uppercase;

    letter-spacing:2px;

    font-size:11px;

    margin-bottom:10px;

}

.meta-grid strong{

    color:#fff;

    font-size:18px;

    font-weight:600;

}

/* ================================= */

.project-image{

    position:relative;

    display:block;

    overflow:hidden;

    border-radius:22px;

    aspect-ratio:16/10;

    box-shadow:
        0 40px 90px rgba(0,0,0,.35);

    opacity:0;

    transform:translateX(60px);

    transition:.9s;

}

.featured-commercial.visible .project-image{

    opacity:1;

    transform:none;

    transition-delay:.15s;

}

.project-image img{

    width:100%;

    height:100%;

    object-fit:cover;

    display:block;

    transition:
        transform 2.4s cubic-bezier(.22,1,.36,1);

}

.project-image:hover img{

    transform:scale(1.08);

}

.image-overlay{

    position:absolute;

    inset:0;

    background:
        linear-gradient(
            transparent,
            rgba(0,0,0,.45)
        );

}

.image-tag{

    position:absolute;

    top:30px;

    left:30px;

    padding:12px 20px;

    background:rgba(0,0,0,.75);

    backdrop-filter:blur(10px);

    color:#fff;

    font-size:11px;

    text-transform:uppercase;

    letter-spacing:2px;

    border-left:3px solid var(--accent);

}

.project-image::after{

    content:"";

    position:absolute;

    inset:18px;

    border:1px solid rgba(255,255,255,.22);

    opacity:0;

    transform:scale(.95);

    transition:.55s;

}

.project-image:hover::after{

    opacity:1;

    transform:scale(1);

}

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:70px 70px;

    }

}

@media(max-width:991px){

    .project-grid{

        grid-template-columns:1fr;

        gap:60px;

    }

}

@media(max-width:768px){

    .meta-grid{

        grid-template-columns:1fr;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const section=document.querySelector(".featured-commercial");

    if(!section) return;

    const observer=new IntersectionObserver((entries)=>{

        if(entries[0].isIntersecting){

            section.classList.add("visible");

            observer.disconnect();

        }

    },{

        threshold:.2

    });

    observer.observe(section);

});

</script>