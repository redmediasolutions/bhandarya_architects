---
import projects from "../../content/interiors";
import { getInteriorImages } from "../../lib/interiorImages";

const project =
    projects.find((p) => p.featured) ?? projects[0];

const { hero } = getInteriorImages(project.folder);
---

<section class="featured-interior" id="featured">

    <div class="background-grid"></div>

    <div class="glow"></div>

    <div class="container">

        <div class="section-heading">

            <span class="small-title">

                Signature Interior

            </span>

            <h2>

                Featured Project

            </h2>

        </div>

        <div class="project-wrapper">

            <a
                href={`/projects/interiors/${project.slug}`}
                class="project-image"
            >

                <img
    src={hero.src}
    alt={project.title}
    loading="lazy"
/>

                <div class="image-overlay"></div>

            </a>

            <div class="project-card">

                <span class="project-category">

                   {project.subtitle}

                </span>

                <h3>

                    {project.title}

                </h3>

                <div class="accent-line"></div>

                <p>

                    Designed as a seamless extension of the
                    architecture, the interiors celebrate natural
                    materials, handcrafted detailing and soft,
                    ambient lighting to create a timeless living
                    experience.

                </p>

                <div class="materials">

    {
        project.highlights
            .slice(0, 4)
            .map((highlight) => (

                <span>

                    {highlight}

                </span>

            ))
    }

</div>

                <div class="meta">

    <div>

        <small>

            Location

        </small>

        <strong>

            {project.location}

        </strong>

    </div>

    {
        project.area && (

            <div>

                <small>

                    Area

                </small>

                <strong>

                    {project.area}

                </strong>

            </div>

        )
    }

    <div>

        <small>

            {
                project.status === "Completed"
                    ? "Completed"
                    : "Status"
            }

        </small>

        <strong>

            {
                project.status === "Completed"
                    ? project.year
                    : project.status
            }

        </strong>

    </div>

</div>

                <a
                    href={`/projects/interiors/${project.slug}`}
                    class="btn"
                >

                    View Project

                </a>

            </div>

        </div>

    </div>

</section>

<style>

.featured-interior{

    position:relative;

    overflow:hidden;

    background:#faf8f5;

    padding:140px 0;

}

/* =============================== */

.background-grid{

    position:absolute;

    inset:0;

    background-image:

        linear-gradient(rgba(0,0,0,.025) 1px,transparent 1px),

        linear-gradient(90deg,rgba(0,0,0,.025) 1px,transparent 1px);

    background-size:70px 70px;

    animation:gridMove 18s linear infinite;

}

.glow{

    position:absolute;

    width:850px;

    height:850px;

    right:-200px;

    top:-200px;

    border-radius:50%;

    background:

        radial-gradient(

            rgba(255,140,0,.16),

            transparent 70%

        );

    filter:blur(120px);

}

.container{

    position:relative;

    z-index:2;

}

.section-heading{

    text-align:center;

    margin-bottom:70px;

}

.section-heading h2{

    margin-top:18px;

}

/* =============================== */

.project-wrapper{

    position:relative;

    min-height:760px;

}

/* =============================== */

.project-image{

    display:block;

    overflow:hidden;

    border-radius:28px;

    box-shadow:

        0 40px 90px rgba(0,0,0,.12);

}

.project-image img{

    width:100%;

    display:block;

    transform:scale(1.08);

    transition:transform 2.4s cubic-bezier(.22,1,.36,1);

}

.project-image:hover img{

    transform:scale(1.14);

}

.image-overlay{

    position:absolute;

    inset:0;

    background:

        linear-gradient(

            transparent,

            rgba(0,0,0,.35)

        );

}

/* =============================== */

.project-card{

    position:absolute;

    right:60px;

    bottom:-60px;

    width:min(520px,92vw);

    padding:50px;

    border-radius:24px;

    background:rgba(255,255,255,.82);

    backdrop-filter:blur(20px);

    box-shadow:

        0 30px 80px rgba(0,0,0,.12);

}

/* =============================== */

.project-category{

    color:var(--accent);

    text-transform:uppercase;

    letter-spacing:3px;

    font-size:12px;

    font-weight:600;

}

.project-card h3{

    margin:18px 0;

    font-size:48px;

}

.accent-line{

    width:80px;

    height:2px;

    background:var(--accent);

    margin-bottom:30px;

}

.project-card p{

    color:#666;

    line-height:1.9;

}

/* =============================== */

.materials{

    display:flex;

    flex-wrap:wrap;

    gap:12px;

    margin:35px 0;

}

.materials span{

    padding:10px 18px;

    border-radius:999px;

    background:white;

    font-size:12px;

    letter-spacing:1px;

    border:1px solid rgba(0,0,0,.06);

}

/* =============================== */

.meta{

    display:grid;

    grid-template-columns:repeat(3,1fr);

    gap:20px;

    margin:40px 0;

}

.meta small{

    display:block;

    color:#999;

    margin-bottom:10px;

    text-transform:uppercase;

    letter-spacing:2px;

    font-size:11px;

}

.meta strong{

    font-size:18px;

}

/* =============================== */

.project-card{

    opacity:0;

    transform:translateY(60px);

    transition:.9s;

}

.project-image{

    opacity:0;

    transform:translateY(60px);

    transition:.9s;

}

.featured-interior.visible .project-image,

.featured-interior.visible .project-card{

    opacity:1;

    transform:none;

}

.featured-interior.visible .project-card{

    transition-delay:.2s;

}

/* =============================== */

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:70px 70px;

    }

}

/* =============================== */

@media(max-width:991px){

    .project-wrapper{

        min-height:auto;

    }

    .project-card{

        position:relative;

        right:auto;

        bottom:auto;

        width:100%;

        margin-top:-40px;

    }

}

@media(max-width:768px){

    .meta{

        grid-template-columns:1fr;

    }

    .project-card{

        padding:35px;

    }

    .project-card h3{

        font-size:36px;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const section=document.querySelector(".featured-interior");

    if(!section) return;

    const observer=new IntersectionObserver((entries)=>{

        if(entries[0].isIntersecting){

            section.classList.add("visible");

            observer.disconnect();

        }

    },{

        threshold:.25

    });

    observer.observe(section);

});

</script>