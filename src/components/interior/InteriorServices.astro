---
const services = [
  {
    title: "Living Spaces",
    description:
      "Elegant living rooms designed for comfort, conversation and timeless everyday living.",
    image: "/images/interiors/living.webp",
  },
  {
    title: "Bedrooms",
    description:
      "Private sanctuaries balancing warmth, luxury and restful simplicity.",
    image: "/images/interiors/bedroom.webp",
  },
  {
    title: "Kitchens",
    description:
      "Functional culinary spaces crafted with precision, storage and refined detailing.",
    image: "/images/interiors/kitchen.webp",
  },
  {
    title: "Corporate Interiors",
    description:
      "Workspaces that improve productivity while reflecting your brand identity.",
    image: "/images/interiors/office.webp",
  },
  {
    title: "Hospitality",
    description:
      "Hotels, cafés and lounges designed around memorable guest experiences.",
    image: "/images/interiors/hospitality.webp",
  },
  {
    title: "Retail",
    description:
      "Immersive retail environments that strengthen customer engagement and brand value.",
    image: "/images/interiors/retail.webp",
  },
];
---

<section class="interior-services section">

    <div class="container">

        <div class="section-heading">

            <span class="small-title">

                Design Expertise

            </span>

            <h2>

                Spaces We Design

            </h2>

            <p>

                Every interior is thoughtfully crafted around
                its users, blending aesthetics, functionality
                and enduring craftsmanship.

            </p>

        </div>

        <div class="services-grid">

            {
                services.map((service,index)=>(

                    <article
                        class="service-card"
                        style={`--delay:${index*.12}s`}
                    >

                        <img
                            src={service.image}
                            alt={service.title}
                        />

                        <div class="overlay">

                            <span>

                                Interior Design

                            </span>

                            <h3>

                                {service.title}

                            </h3>

                            <p>

                                {service.description}

                            </p>

                            <div class="line"></div>

                            <div class="link">

                                Explore →

                            </div>

                        </div>

                    </article>

                ))
            }

        </div>

    </div>

</section>

<style>

.interior-services{

    position:relative;

    background:white;

}

/* ============================ */

.section-heading{

    max-width:760px;

    margin:0 auto 80px;

    text-align:center;

}

.section-heading h2{

    margin:18px 0;

}

/* ============================ */

.services-grid{

    display:grid;

    grid-template-columns:repeat(3,1fr);

    gap:28px;

}

/* ============================ */

.service-card{

    position:relative;

    overflow:hidden;

    border-radius:20px;

    aspect-ratio:4/5;

    background:#111;

    cursor:pointer;

    opacity:0;

    transform:translateY(60px);

    transition:

        opacity .8s,

        transform .8s,

        box-shadow .45s;

}

.interior-services.visible .service-card{

    opacity:1;

    transform:none;

    transition-delay:var(--delay);

}

.service-card img{

    width:100%;

    height:100%;

    object-fit:cover;

    transform:scale(1.08);

    transition:

        transform 2s cubic-bezier(.22,1,.36,1),

        filter .6s;

}

.service-card:hover img{

    transform:scale(1.15);

}

/* ============================ */

.service-card::before{

    content:"";

    position:absolute;

    inset:0;

    background:

        linear-gradient(

            transparent 10%,

            rgba(0,0,0,.88)

        );

    z-index:2;

}

.service-card::after{

    content:"";

    position:absolute;

    inset:0;

    background-image:

        linear-gradient(rgba(255,255,255,.04) 1px,transparent 1px),

        linear-gradient(90deg,rgba(255,255,255,.04) 1px,transparent 1px);

    background-size:36px 36px;

    opacity:.08;

    animation:gridMove 18s linear infinite;

}

/* ============================ */

.overlay{

    position:absolute;

    inset:0;

    z-index:4;

    display:flex;

    flex-direction:column;

    justify-content:flex-end;

    padding:38px;

}

.overlay span{

    color:rgba(255,255,255,.72);

    text-transform:uppercase;

    letter-spacing:2px;

    font-size:11px;

}

.overlay h3{

    color:white;

    font-size:32px;

    margin:14px 0;

}

.overlay p{

    color:rgba(255,255,255,.7);

    line-height:1.8;

}

.line{

    width:0;

    height:2px;

    margin:24px 0;

    background:var(--accent);

    transition:.45s;

}

.service-card:hover .line{

    width:90px;

}

.link{

    color:var(--accent);

    text-transform:uppercase;

    letter-spacing:2px;

    font-size:12px;

    font-weight:600;

}

/* ============================ */

.service-card:hover{

    transform:translateY(-10px);

    box-shadow:

        0 35px 80px rgba(0,0,0,.18);

}

/* ============================ */

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:36px 36px;

    }

}

/* ============================ */

@media(max-width:991px){

    .services-grid{

        grid-template-columns:repeat(2,1fr);

    }

}

@media(max-width:768px){

    .services-grid{

        grid-template-columns:1fr;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const section=document.querySelector(".interior-services");

    if(!section) return;

    const observer=new IntersectionObserver((entries)=>{

        if(entries[0].isIntersecting){

            section.classList.add("visible");

            observer.disconnect();

        }

    },{

        threshold:.2

    });

    observer.observe(section);

});

</script>