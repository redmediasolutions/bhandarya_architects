---
import projects from "../../content/interiors";
import { getInteriorImages } from "../../lib/interiorImages";

const interiorProjects = projects.map((project, index) => {

    const { hero } = getInteriorImages(project.folder);

    return {

        ...project,

        image: hero.src,

        href: `/projects/interiors/${project.slug}`,

        featured: index === 0

    };

});
---

<section class="interior-projects section">

    <div class="background-grid"></div>
    <div class="glow"></div>

    <div class="container">

        <div class="section-heading">

            <span class="small-title">

                Portfolio

            </span>

            <h2>

                Interior Projects

            </h2>

            <p>

                A collection of timeless interiors crafted around
                materials, light, detail and everyday living.

            </p>

        </div>

        <div class="projects-grid">

    {
        interiorProjects.map((project, index) => (

            <a
                href={project.href}
                class={`project-card ${project.featured ? "featured" : ""}`}
                style={`--delay:${index * .12}s`}
            >

                <img
                    src={project.image}
                    alt={project.title}
                    loading="lazy"
                />

                <div class="overlay">

                    <span>

                        {project.subtitle}

                    </span>

                    <h3>

                        {project.title}

                    </h3>

                    {
                        project.area && (

                            <small>

                                {project.area}

                            </small>

                        )
                    }

                    <div class="line"></div>

                    <div class="view">

                        View Project →

                    </div>

                </div>

            </a>

        ))
    }

</div>

    </div>

</section>

<style>

.interior-projects{

    position:relative;

    overflow:hidden;

    background:#faf8f5;

}

/* ===================================== */

.background-grid{

    position:absolute;

    inset:0;

    background-image:
        linear-gradient(rgba(0,0,0,.02) 1px,transparent 1px),
        linear-gradient(90deg,rgba(0,0,0,.02) 1px,transparent 1px);

    background-size:70px 70px;

    animation:gridMove 20s linear infinite;

}

.glow{

    position:absolute;

    right:-200px;

    top:-200px;

    width:900px;

    height:900px;

    border-radius:50%;

    background:

        radial-gradient(

            rgba(255,140,0,.12),

            transparent 70%

        );

    filter:blur(120px);

}

/* ===================================== */

.container{

    position:relative;

    z-index:2;

}

.section-heading{

    text-align:center;

    max-width:760px;

    margin:0 auto 80px;

}

.section-heading h2{

    margin:18px 0;

}

/* ===================================== */

.projects-grid{

    display:grid;

    grid-template-columns:repeat(12,1fr);

    gap:28px;

}

.featured{

    grid-column:span 8;

    aspect-ratio:16/10;

}

.project-card:not(.featured){

    grid-column:span 4;

    aspect-ratio:4/5;

}

/* ===================================== */

.project-card{

    position:relative;

    overflow:hidden;

    display:block;

    border-radius:22px;

    background:#111;

    opacity:0;

    transform:translateY(60px);

    transition:

        opacity .8s,

        transform .8s,

        box-shadow .45s;

}

.interior-projects.visible .project-card{

    opacity:1;

    transform:none;

    transition-delay:var(--delay);

}

.project-card img{

    width:100%;

    height:100%;

    object-fit:cover;

    transform:scale(1.08);

    transition:transform 2s cubic-bezier(.22,1,.36,1);

}

.project-card:hover img{

    transform:scale(1.15);

}

/* ===================================== */

.project-card::before{

    content:"";

    position:absolute;

    inset:0;

    background:

        linear-gradient(

            transparent 15%,

            rgba(0,0,0,.88)

        );

    z-index:2;

}

.project-card::after{

    content:"";

    position:absolute;

    inset:18px;

    border:1px solid rgba(255,255,255,.2);

    opacity:0;

    transition:.45s;

    transform:scale(.96);

    z-index:3;

}

.project-card:hover::after{

    opacity:1;

    transform:scale(1);

}

/* ===================================== */

.overlay{

    position:absolute;

    inset:0;

    z-index:5;

    display:flex;

    flex-direction:column;

    justify-content:flex-end;

    padding:40px;

}

.overlay span{

    color:rgba(255,255,255,.7);

    text-transform:uppercase;

    letter-spacing:2px;

    font-size:11px;

}

.overlay h3{

    color:white;

    margin:14px 0;

    font-size:34px;

}

.overlay small{

    color:rgba(255,255,255,.68);

    font-size:13px;

}

.line{

    width:0;

    height:2px;

    margin:22px 0;

    background:var(--accent);

    transition:.45s;

}

.project-card:hover .line{

    width:90px;

}

.view{

    color:var(--accent);

    font-size:12px;

    text-transform:uppercase;

    letter-spacing:2px;

    font-weight:600;

}

/* ===================================== */

.project-card:hover{

    transform:translateY(-10px);

    box-shadow:

        0 35px 80px rgba(0,0,0,.18);

}

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:70px 70px;

    }

}

/* ===================================== */

@media(max-width:991px){

    .projects-grid{

        grid-template-columns:repeat(2,1fr);

    }

    .featured{

        grid-column:span 2;

    }

    .project-card:not(.featured){

        grid-column:auto;

    }

}

@media(max-width:768px){

    .projects-grid{

        grid-template-columns:1fr;

    }

    .featured{

        grid-column:auto;

    }

    .project-card{

        aspect-ratio:16/10 !important;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const section=document.querySelector(".interior-projects");

    if(!section) return;

    const observer=new IntersectionObserver((entries)=>{

        if(entries[0].isIntersecting){

            section.classList.add("visible");

            observer.disconnect();

        }

    },{

        threshold:.2

    });

    observer.observe(section);

});

</script>