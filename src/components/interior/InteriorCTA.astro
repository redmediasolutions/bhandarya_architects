---
import { img } from "../../consts";

const background = img("2026/05/Copy-of-01.webp");
---

<section
    class="interior-cta"
    style={`background-image:url('${background}')`}
>

    <div class="overlay"></div>
    <div class="grid"></div>
    <div class="glow"></div>

    <div class="container">

        <div class="cta-content">

            <span class="small-title">

                Let's Create Something Exceptional

            </span>

            <h2>

                Transform Your
                <br />
                Interior Into
                <br />
                A Timeless Space.

            </h2>

            <p>

                Whether you're designing a luxury residence,
                boutique hotel or a contemporary workplace,
                our team creates interiors that balance
                elegance, functionality and enduring
                craftsmanship.

            </p>

            <div class="cta-buttons">

                <a
                    href="/contact"
                    class="btn"
                >

                    Schedule Consultation

                </a>

                <a
                    href="https://wa.me/919876543210"
                    target="_blank"
                    class="btn secondary"
                >

                    WhatsApp Us

                </a>

            </div>

        </div>

    </div>

</section>

<style>

.interior-cta{

    position:relative;

    overflow:hidden;

    min-height:90vh;

    display:flex;

    align-items:center;

    background-size:cover;

    background-position:center;

    background-repeat:no-repeat;

}

/* ======================================== */

.overlay{

    position:absolute;

    inset:0;

    background:

        linear-gradient(
            90deg,
            rgba(10,10,10,.84),
            rgba(10,10,10,.48)
        ),

        linear-gradient(
            180deg,
            rgba(0,0,0,.15),
            rgba(0,0,0,.72)
        );

}

/* ======================================== */

.grid{

    position:absolute;

    inset:0;

    background-image:

        linear-gradient(rgba(255,255,255,.035) 1px,transparent 1px),

        linear-gradient(90deg,rgba(255,255,255,.035) 1px,transparent 1px);

    background-size:70px 70px;

    animation:gridMove 20s linear infinite;

    opacity:.35;

}

/* ======================================== */

.glow{

    position:absolute;

    width:900px;

    height:900px;

    right:-200px;

    top:-250px;

    border-radius:50%;

    background:

        radial-gradient(

            rgba(255,140,0,.22),

            transparent 70%

        );

    filter:blur(120px);

    animation:floatGlow 8s ease-in-out infinite alternate;

}

/* ======================================== */

.container{

    position:relative;

    z-index:5;

}

.cta-content{

    max-width:760px;

}

.cta-content .small-title{

    color:rgba(255,255,255,.82);

}

.cta-content h2{

    color:white;

    margin:22px 0 28px;

    font-size:clamp(56px,7vw,100px);

    line-height:.92;

    letter-spacing:-2px;

}

.cta-content p{

    color:rgba(255,255,255,.78);

    font-size:18px;

    line-height:1.9;

    max-width:620px;

}

/* ======================================== */

.cta-buttons{

    display:flex;

    flex-wrap:wrap;

    gap:20px;

    margin-top:50px;

}

/* Primary button uses your existing .btn */

.secondary{

    display:inline-flex;

    align-items:center;

    justify-content:center;

    padding:16px 34px;

    border:1px solid rgba(255,255,255,.25);

    border-radius:999px;

    color:white;

    text-decoration:none;

    font-weight:600;

    letter-spacing:2px;

    text-transform:uppercase;

    font-size:12px;

    backdrop-filter:blur(12px);

    transition:.4s;

}

.secondary:hover{

    background:white;

    color:#111;

    border-color:white;

}

/* ======================================== */

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:70px 70px;

    }

}

@keyframes floatGlow{

    from{

        transform:translateY(0);

    }

    to{

        transform:translateY(40px);

    }

}

/* ======================================== */

@media(max-width:991px){

    .interior-cta{

        min-height:75vh;

        padding:120px 0;

    }

}

@media(max-width:768px){

    .cta-content h2{

        font-size:48px;

    }

    .cta-content p{

        font-size:16px;

    }

    .cta-buttons{

        flex-direction:column;

        align-items:flex-start;

    }

}

</style>