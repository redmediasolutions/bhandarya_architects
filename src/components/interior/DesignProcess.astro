---
const process = [
  {
    step: "01",
    title: "Discovery",
    text: "Understanding your lifestyle, aspirations and how you want your spaces to feel."
  },
  {
    step: "02",
    title: "Space Planning",
    text: "Organising circulation, furniture layouts and functionality before aesthetics."
  },
  {
    step: "03",
    title: "Materials",
    text: "Selecting finishes, textures, colours and lighting to create a timeless palette."
  },
  {
    step: "04",
    title: "Detail Design",
    text: "Custom furniture, joinery, lighting and architectural detailing are refined."
  },
  {
    step: "05",
    title: "Execution",
    text: "Working closely with craftsmen to ensure every detail is built exactly as envisioned."
  }
];
---

<section class="interior-process">

    <div class="background-grid"></div>
    <div class="background-glow"></div>

    <div class="container">

        <div class="section-heading">

            <span class="small-title">

                Our Process

            </span>

            <h2>

                From Concept
                <br>
                To Completion

            </h2>

            <p>

                Every interior follows a carefully considered
                journey where design, craftsmanship and
                execution work together seamlessly.

            </p>

        </div>

        <div class="timeline">

            {
                process.map((item,index)=>(

                    <article
                        class="timeline-card"
                        style={`--delay:${index*.15}s`}
                    >

                        <div class="step">

                            {item.step}

                        </div>

                        <h3>

                            {item.title}

                        </h3>

                        <p>

                            {item.text}

                        </p>

                    </article>

                ))
            }

        </div>

    </div>

</section>

<style>

.interior-process{

    position:relative;

    overflow:hidden;

    background:#111;

    padding:140px 0;

}

/* ================================= */

.background-grid{

    position:absolute;

    inset:0;

    background-image:

        linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),

        linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);

    background-size:70px 70px;

    animation:gridMove 20s linear infinite;

}

.background-glow{

    position:absolute;

    width:900px;

    height:900px;

    right:-250px;

    top:-250px;

    border-radius:50%;

    background:
        radial-gradient(
            rgba(255,140,0,.18),
            transparent 70%
        );

    filter:blur(120px);

}

.container{

    position:relative;

    z-index:2;

}

/* ================================= */

.section-heading{

    max-width:760px;

    margin:0 auto 90px;

    text-align:center;

}

.section-heading h2{

    color:white;

    margin:18px 0;

}

.section-heading p{

    color:rgba(255,255,255,.7);

}

/* ================================= */

.timeline{

    display:grid;

    grid-template-columns:repeat(5,1fr);

    gap:26px;

    position:relative;

}

.timeline::before{

    content:"";

    position:absolute;

    top:55px;

    left:0;

    right:0;

    height:2px;

    background:rgba(255,255,255,.08);

}

/* ================================= */

.timeline-card{

    position:relative;

    padding:90px 35px 40px;

    border-radius:20px;

    background:rgba(255,255,255,.04);

    border:1px solid rgba(255,255,255,.06);

    backdrop-filter:blur(10px);

    transition:.45s;

    opacity:0;

    transform:translateY(60px);

}

.interior-process.visible .timeline-card{

    opacity:1;

    transform:none;

    transition-delay:var(--delay);

}

.timeline-card:hover{

    transform:translateY(-10px);

    border-color:rgba(255,140,0,.35);

    box-shadow:0 30px 70px rgba(0,0,0,.25);

}

/* ================================= */

.step{

    position:absolute;

    top:0;

    left:50%;

    transform:translate(-50%,-50%);

    width:90px;

    height:90px;

    border-radius:50%;

    display:flex;

    align-items:center;

    justify-content:center;

    background:#181818;

    border:2px solid var(--accent);

    color:var(--accent);

    font-size:28px;

    font-weight:700;

}

.timeline-card h3{

    color:white;

    margin-bottom:18px;

    text-align:center;

}

.timeline-card p{

    color:rgba(255,255,255,.68);

    text-align:center;

    line-height:1.8;

}

/* ================================= */

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:70px 70px;

    }

}

/* ================================= */

@media(max-width:1200px){

    .timeline{

        grid-template-columns:repeat(2,1fr);

    }

    .timeline::before{

        display:none;

    }

}

@media(max-width:768px){

    .timeline{

        grid-template-columns:1fr;

        gap:50px;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const section=document.querySelector(".interior-process");

    if(!section) return;

    const observer=new IntersectionObserver((entries)=>{

        if(entries[0].isIntersecting){

            section.classList.add("visible");

            observer.disconnect();

        }

    },{

        threshold:.2

    });

    observer.observe(section);

});

</script>