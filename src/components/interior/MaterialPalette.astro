---
const materials = [
    {
        title: "Natural Stone",
        image: "/images/materials/stone.webp",
        category: "Premium Finish",
        text: "Timeless marble and natural stone selected for warmth, elegance and durability.",
        uses: ["Flooring","Feature Walls","Countertops"]
    },
    {
        title: "Solid Timber",
        image: "/images/materials/wood.webp",
        category: "Natural Material",
        text: "Rich hardwood finishes that introduce warmth, texture and character.",
        uses: ["Furniture","Wall Panels","Ceilings"]
    },
    {
        title: "Brass & Metal",
        image: "/images/materials/brass.webp",
        category: "Accent",
        text: "Refined metallic details bringing sophistication through carefully crafted accents.",
        uses: ["Lighting","Hardware","Partitions"]
    },
    {
        title: "Glass & Light",
        image: "/images/materials/glass.webp",
        category: "Transparency",
        text: "Clear, fluted and textured glass balancing openness with privacy.",
        uses: ["Partitions","Doors","Screens"]
    }
];
---

<section class="material-palette section">

    <div class="grid-bg"></div>

    <div class="glow"></div>

    <div class="container">

        <div class="section-heading">

            <span class="small-title">

                Design Language

            </span>

            <h2>

                Materials That
                <br>
                Define Every Space

            </h2>

            <p>

                Every project begins with carefully selected
                materials that age beautifully and create
                interiors of lasting character.

            </p>

        </div>

        <div class="materials-grid">

            {
                materials.map((material,index)=>(

                    <article
                        class="material-card"
                        style={`--delay:${index*.15}s`}
                    >

                        <div class="image">

                            <img
                                src={material.image}
                                alt={material.title}
                            />

                        </div>

                        <div class="content">

                            <span>

                                {material.category}

                            </span>

                            <h3>

                                {material.title}

                            </h3>

                            <p>

                                {material.text}

                            </p>

                            <div class="uses">

                                {
                                    material.uses.map(item=>(

                                        <small>

                                            {item}

                                        </small>

                                    ))
                                }

                            </div>

                            <div class="line"></div>

                        </div>

                    </article>

                ))
            }

        </div>

    </div>

</section>

<style>

.material-palette{

    position:relative;

    overflow:hidden;

    background:#f9f7f4;

}

/* =============================== */

.grid-bg{

    position:absolute;

    inset:0;

    background-image:

        linear-gradient(rgba(0,0,0,.025) 1px,transparent 1px),

        linear-gradient(90deg,rgba(0,0,0,.025) 1px,transparent 1px);

    background-size:70px 70px;

    animation:gridMove 18s linear infinite;

}

.glow{

    position:absolute;

    left:-200px;

    top:-200px;

    width:850px;

    height:850px;

    border-radius:50%;

    background:

        radial-gradient(

            rgba(255,120,0,.10),

            transparent 70%

        );

    filter:blur(120px);

}

/* =============================== */

.container{

    position:relative;

    z-index:2;

}

.section-heading{

    text-align:center;

    max-width:760px;

    margin:0 auto 80px;

}

.section-heading h2{

    margin:18px 0;

}

/* =============================== */

.materials-grid{

    display:grid;

    grid-template-columns:repeat(4,1fr);

    gap:30px;

}

/* =============================== */

.material-card{

    position:relative;

    background:white;

    border-radius:22px;

    overflow:hidden;

    border:1px solid rgba(0,0,0,.06);

    transition:.45s;

    opacity:0;

    transform:translateY(60px);

}

.material-palette.visible .material-card{

    opacity:1;

    transform:none;

    transition-delay:var(--delay);

}

.material-card:hover{

    transform:translateY(-12px);

    box-shadow:

        0 35px 80px rgba(0,0,0,.08);

}

/* =============================== */

.material-card::after{

    content:"";

    position:absolute;

    inset:0;

    background-image:

        linear-gradient(rgba(0,0,0,.03) 1px,transparent 1px),

        linear-gradient(90deg,rgba(0,0,0,.03) 1px,transparent 1px);

    background-size:32px 32px;

    opacity:.25;

    pointer-events:none;

}

/* =============================== */

.image{

    overflow:hidden;

    aspect-ratio:1;

}

.image img{

    width:100%;

    height:100%;

    object-fit:cover;

    transform:scale(1.08);

    transition:2s;

}

.material-card:hover img{

    transform:scale(1.15);

}

/* =============================== */

.content{

    padding:34px;

}

.content span{

    color:var(--accent);

    text-transform:uppercase;

    letter-spacing:2px;

    font-size:11px;

}

.content h3{

    margin:16px 0;

    font-size:28px;

}

.content p{

    color:#666;

    line-height:1.8;

}

/* =============================== */

.uses{

    display:flex;

    flex-wrap:wrap;

    gap:10px;

    margin:26px 0;

}

.uses small{

    padding:8px 14px;

    border-radius:999px;

    background:#f3f3f3;

    font-size:11px;

    letter-spacing:1px;

    text-transform:uppercase;

}

/* =============================== */

.line{

    width:0;

    height:2px;

    background:var(--accent);

    transition:.45s;

}

.material-card:hover .line{

    width:90px;

}

/* =============================== */

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:70px 70px;

    }

}

/* =============================== */

@media(max-width:1200px){

    .materials-grid{

        grid-template-columns:repeat(2,1fr);

    }

}

@media(max-width:768px){

    .materials-grid{

        grid-template-columns:1fr;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const section=document.querySelector(".material-palette");

    if(!section) return;

    const observer=new IntersectionObserver((entries)=>{

        if(entries[0].isIntersecting){

            section.classList.add("visible");

            observer.disconnect();

        }

    },{

        threshold:.2

    });

    observer.observe(section);

});

</script>