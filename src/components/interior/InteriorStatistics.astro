---
const metrics = [
  {
    value: 85,
    suffix: "+",
    label: "Interior Projects",
    text: "Luxury homes, hospitality and commercial interiors."
  },
  {
    value: 2100000,
    suffix: "+",
    format: "million",
    label: "Sq.ft Designed",
    text: "Thoughtfully planned interior environments."
  },
  {
    value: 25,
    suffix: "+",
    label: "Years Experience",
    text: "Creating timeless interior spaces."
  },
  {
    value: 450,
    suffix: "+",
    label: "Custom Elements",
    text: "Furniture, joinery and bespoke details."
  }
];
---

<section class="interior-statistics">

    <div class="grid-bg"></div>
    <div class="glow glow-one"></div>
    <div class="glow glow-two"></div>

    <div class="container">

        <div class="section-heading">

            <span class="small-title">

                Interior Excellence

            </span>

            <h2>

                Every Detail
                <br>
                Counts

            </h2>

            <p>

                Behind every interior lies countless hours of
                planning, craftsmanship and thoughtful detailing.

            </p>

        </div>

        <div class="stats-grid">

            {
                metrics.map((item,index)=>(

                    <article
                        class="stat-card"
                        style={`--delay:${index*.12}s`}
                    >

                        <h3
                            class="counter"
                            data-value={item.value}
                            data-format={item.format || ""}
                            data-suffix={item.suffix}
                        >

                            0

                        </h3>

                        <h4>

                            {item.label}

                        </h4>

                        <p>

                            {item.text}

                        </p>

                        <div class="line"></div>

                    </article>

                ))
            }

        </div>

    </div>

</section>

<style>

.interior-statistics{

    position:relative;

    overflow:hidden;

    background:#f8f5f2;

    padding:140px 0;

}

/* =============================== */

.grid-bg{

    position:absolute;

    inset:0;

    background-image:

        linear-gradient(rgba(0,0,0,.02) 1px,transparent 1px),

        linear-gradient(90deg,rgba(0,0,0,.02) 1px,transparent 1px);

    background-size:70px 70px;

    animation:gridMove 18s linear infinite;

}

/* =============================== */

.glow{

    position:absolute;

    border-radius:50%;

    filter:blur(120px);

    pointer-events:none;

}

.glow-one{

    width:650px;

    height:650px;

    left:-180px;

    top:-180px;

    background:radial-gradient(rgba(255,170,80,.18),transparent 70%);

}

.glow-two{

    width:700px;

    height:700px;

    right:-220px;

    bottom:-220px;

    background:radial-gradient(rgba(255,120,0,.12),transparent 70%);

}

/* =============================== */

.container{

    position:relative;

    z-index:2;

}

.section-heading{

    max-width:760px;

    margin:0 auto 80px;

    text-align:center;

}

.section-heading h2{

    margin:18px 0;

}

.section-heading p{

    max-width:620px;

    margin:auto;

    color:#666;

}

/* =============================== */

.stats-grid{

    display:grid;

    grid-template-columns:repeat(4,1fr);

    gap:30px;

}

/* =============================== */

.stat-card{

    position:relative;

    overflow:hidden;

    padding:45px;

    border-radius:22px;

    background:rgba(255,255,255,.75);

    backdrop-filter:blur(18px);

    border:1px solid rgba(255,255,255,.65);

    transition:.45s;

    opacity:0;

    transform:translateY(60px);

}

.interior-statistics.visible .stat-card{

    opacity:1;

    transform:none;

    transition-delay:var(--delay);

}

.stat-card::before{

    content:"";

    position:absolute;

    inset:0;

    background:

        radial-gradient(

            circle at top right,

            rgba(255,140,0,.12),

            transparent 70%

        );

    opacity:0;

    transition:.45s;

}

.stat-card:hover{

    transform:translateY(-10px);

    box-shadow:

        0 30px 70px rgba(0,0,0,.08);

}

.stat-card:hover::before{

    opacity:1;

}

/* =============================== */

.counter{

    font-size:68px;

    line-height:1;

    color:var(--accent);

    margin-bottom:18px;

}

.stat-card h4{

    margin-bottom:18px;

}

.stat-card p{

    color:#666;

    line-height:1.8;

}

.line{

    width:0;

    height:2px;

    margin-top:28px;

    background:var(--accent);

    transition:.45s;

}

.stat-card:hover .line{

    width:90px;

}

/* =============================== */

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:70px 70px;

    }

}

/* =============================== */

@media(max-width:991px){

    .stats-grid{

        grid-template-columns:repeat(2,1fr);

    }

}

@media(max-width:768px){

    .stats-grid{

        grid-template-columns:1fr;

    }

    .stat-card{

        padding:35px;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const section=document.querySelector(".interior-statistics");

    if(!section) return;

    const counters=section.querySelectorAll(".counter");

    const observer=new IntersectionObserver((entries)=>{

        if(entries[0].isIntersecting){

            section.classList.add("visible");

            counters.forEach(counter=>{

                const target=parseInt(counter.dataset.value);

                const suffix=counter.dataset.suffix || "";

                const format=counter.dataset.format;

                let current=0;

                const increment=target/80;

                const update=()=>{

                    current+=increment;

                    if(current>=target){

                        if(format==="million"){

                            counter.textContent=(target/1000000).toFixed(1)+suffix;

                        }else{

                            counter.textContent=Math.round(target)+suffix;

                        }

                        return;

                    }

                    if(format==="million"){

                        counter.textContent=(current/1000000).toFixed(1)+suffix;

                    }else{

                        counter.textContent=Math.round(current)+suffix;

                    }

                    requestAnimationFrame(update);

                };

                update();

            });

            observer.disconnect();

        }

    },{

        threshold:.25

    });

    observer.observe(section);

});

</script>