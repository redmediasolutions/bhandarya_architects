---
const faqs = [
    {
        question: "Do you provide complete interior design services?",
        answer:
            "Yes. We offer end-to-end interior design services including concept development, space planning, material selection, lighting design, custom furniture, joinery detailing and site execution."
    },
    {
        question: "Can you design interiors for existing homes?",
        answer:
            "Absolutely. We work on both new construction and renovation projects, transforming existing spaces while respecting the architectural character of the home."
    },
    {
        question: "Do you offer custom furniture and joinery design?",
        answer:
            "Yes. We design bespoke furniture, wardrobes, kitchens, entertainment units, wall panelling and other custom elements tailored specifically for each project."
    },
    {
        question: "How are materials and finishes selected?",
        answer:
            "Materials are carefully chosen based on aesthetics, durability, maintenance, lighting conditions and your lifestyle. We prepare curated material palettes before execution begins."
    },
    {
        question: "Can you coordinate with contractors and craftsmen?",
        answer:
            "Yes. We closely collaborate with contractors, fabricators and skilled craftsmen throughout the construction process to ensure every detail is executed to the highest standards."
    },
    {
        question: "Do you undertake commercial interior projects?",
        answer:
            "Yes. Along with luxury residences, we design offices, retail spaces, hospitality interiors, educational institutions and other commercial environments."
    }
];
---

<section class="interior-faq section">

    <div class="grid-bg"></div>
    <div class="glow"></div>

    <div class="container">

        <div class="section-heading">

            <span class="small-title">

                Frequently Asked Questions

            </span>

            <h2>

                Interior Design
                <br />
                Questions

            </h2>

            <p>

                Everything you need to know before beginning
                your interior design journey with us.

            </p>

        </div>

        <div class="faq-list">

            {
                faqs.map((faq,index)=>(

                    <article
                        class="faq-item"
                        style={`--delay:${index*.08}s`}
                    >

                        <button class="faq-question">

                            <span>

                                {faq.question}

                            </span>

                            <span class="icon">

                                +

                            </span>

                        </button>

                        <div class="faq-answer">

                            <p>

                                {faq.answer}

                            </p>

                        </div>

                    </article>

                ))
            }

        </div>

    </div>

</section>

<style>

.interior-faq{

    position:relative;

    overflow:hidden;

    background:#faf8f5;

}

/* ============================ */

.grid-bg{

    position:absolute;

    inset:0;

    background-image:

        linear-gradient(rgba(0,0,0,.025) 1px,transparent 1px),

        linear-gradient(90deg,rgba(0,0,0,.025) 1px,transparent 1px);

    background-size:70px 70px;

    animation:gridMove 20s linear infinite;

    opacity:.45;

}

.glow{

    position:absolute;

    left:-180px;

    bottom:-180px;

    width:700px;

    height:700px;

    border-radius:50%;

    background:

        radial-gradient(

            rgba(255,140,0,.14),

            transparent 70%

        );

    filter:blur(120px);

}

/* ============================ */

.container{

    position:relative;

    z-index:2;

}

.section-heading{

    text-align:center;

    max-width:760px;

    margin:0 auto 70px;

}

.section-heading h2{

    margin:18px 0;

}

.section-heading p{

    max-width:620px;

    margin:auto;

    color:#666;

}

/* ============================ */

.faq-list{

    max-width:950px;

    margin:auto;

}

/* ============================ */

.faq-item{

    background:white;

    border-radius:18px;

    margin-bottom:22px;

    border:1px solid rgba(0,0,0,.06);

    overflow:hidden;

    box-shadow:

        0 15px 40px rgba(0,0,0,.04);

    transition:.35s;

}

.faq-item:hover{

    transform:translateY(-3px);

    box-shadow:

        0 20px 50px rgba(0,0,0,.08);

}

/* ============================ */

.faq-question{

    width:100%;

    display:flex;

    justify-content:space-between;

    align-items:center;

    padding:30px 34px;

    background:none;

    border:none;

    cursor:pointer;

    font-size:22px;

    font-weight:600;

    text-align:left;

    color:#222;

}

/* ============================ */

.icon{

    width:42px;

    height:42px;

    border-radius:50%;

    background:rgba(255,120,0,.08);

    color:var(--accent);

    display:flex;

    align-items:center;

    justify-content:center;

    font-size:28px;

    transition:.35s;

}

.faq-item.active .icon{

    transform:rotate(45deg);

    background:var(--accent);

    color:white;

}

/* ============================ */

.faq-answer{

    max-height:0;

    overflow:hidden;

    transition:max-height .45s ease;

}

.faq-answer p{

    padding:0 34px 34px;

    color:#666;

    line-height:1.9;

}

/* ============================ */

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:70px 70px;

    }

}

/* ============================ */

@media(max-width:768px){

    .faq-question{

        font-size:18px;

        padding:24px;

    }

    .faq-answer p{

        padding:0 24px 24px;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const items=document.querySelectorAll(".faq-item");

    items.forEach(item=>{

        const button=item.querySelector(".faq-question");
        const answer=item.querySelector(".faq-answer");

        button.addEventListener("click",()=>{

            const open=item.classList.contains("active");

            items.forEach(i=>{

                i.classList.remove("active");

                i.querySelector(".faq-answer").style.maxHeight=null;

            });

            if(!open){

                item.classList.add("active");

                answer.style.maxHeight=answer.scrollHeight+"px";

            }

        });

    });

});

</script>