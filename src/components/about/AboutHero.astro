---
import { img } from "../../consts";
---

<section class="about-hero">

    <div class="overlay"></div>

    <div class="glow"></div>

    <div class="draft-lines">

        <span></span>
        <span></span>
        <span></span>
        <span></span>

    </div>

    <div class="container">

        <div class="hero-content">

            <span class="small-title reveal delay-1">
                About Us
            </span>

            <h1>

                <span class="line reveal delay-2">
                    Building Dreams,
                </span>

                <span class="line reveal delay-3">
                    Shaping Futures
                </span>

                <span class="line accent reveal delay-4">
                    Since 1995
                </span>

            </h1>

            <p class="reveal delay-5">
                For over three decades, Bhandary Architects has been creating
                thoughtful residential, commercial and hospitality spaces rooted
                in timeless design, innovation and craftsmanship.
            </p>

        </div>

    </div>

</section>

<style>

.about-hero{

    position:relative;

    min-height:92vh;

    display:flex;

    align-items:center;

    overflow:hidden;

    background:#181818;

}

/* -------------------------------- */
/* Overlay */
/* -------------------------------- */

.overlay{

    position:absolute;

    inset:0;

    background:
    linear-gradient(
        90deg,
        rgba(0,0,0,.45),
        rgba(0,0,0,.15)
    );

}

/* -------------------------------- */
/* Glow */
/* -------------------------------- */

.glow{

    position:absolute;

    width:900px;

    height:900px;

    left:-350px;

    top:-300px;

    background:
    radial-gradient(
        circle,
        rgba(255,105,0,.08),
        transparent 70%
    );

    animation:glowMove 10s ease-in-out infinite alternate;

}

/* -------------------------------- */
/* Blueprint Lines */
/* -------------------------------- */

.draft-lines{

    position:absolute;

    inset:0;

    pointer-events:none;

    overflow:hidden;

}

.draft-lines span{

    position:absolute;

    width:1800px;

    height:1px;

    background:rgba(255,255,255,.08);

    transform:rotate(-45deg) scaleX(0);

    transform-origin:right;

    animation:drawLine 2s cubic-bezier(.19,1,.22,1) forwards;

}

.draft-lines span:nth-child(1){

    top:5%;
    right:-600px;

    animation-delay:.2s;

}

.draft-lines span:nth-child(2){

    top:28%;
    right:-350px;

    animation-delay:.5s;

}

.draft-lines span:nth-child(3){

    top:52%;
    right:-80px;

    animation-delay:.8s;

}

.draft-lines span:nth-child(4){

    top:76%;
    right:180px;

    animation-delay:1.1s;

}

.hero-content{

    position:relative;

    z-index:5;

    max-width:820px;

    padding:120px 0;

}

.small-title{

    color:var(--accent);

    font-size:15px;

    letter-spacing:4px;

    text-transform:uppercase;

    font-weight:600;

}

.hero-content h1{

    margin:28px 0 40px;

    line-height:.92;

}

.hero-content h1 .line{

    display:block;

    color:white;

    font-size:clamp(56px,7vw,96px);

    font-weight:700;

    letter-spacing:-3px;

}

.hero-content h1 .accent{

    color:var(--accent);

}

.hero-content p{

    max-width:700px;

    font-size:22px;

    line-height:1.8;

    color:rgba(255,255,255,.65);

}

/* -------------------------------- */
/* Reveal Animation */
/* -------------------------------- */

.reveal{

    opacity:0;

    transform:translateY(50px);

    animation:fadeUp .9s cubic-bezier(.19,1,.22,1) forwards;

}

.delay-1{

    animation-delay:.3s;

}

.delay-2{

    animation-delay:.55s;

}

.delay-3{

    animation-delay:.8s;

}

.delay-4{

    animation-delay:1.05s;

}

.delay-5{

    animation-delay:1.35s;

}

/* -------------------------------- */
/* Keyframes */
/* -------------------------------- */

@keyframes fadeUp{

    from{

        opacity:0;

        transform:translateY(50px);

    }

    to{

        opacity:1;

        transform:none;

    }

}

@keyframes drawLine{

    from{

        transform:rotate(-45deg) scaleX(0);

        opacity:0;

    }

    to{

        transform:rotate(-45deg) scaleX(1);

        opacity:1;

    }

}

@keyframes glowMove{

    from{

        transform:translate(0,0);

    }

    to{

        transform:translate(60px,-40px);

    }

}

/* -------------------------------- */
/* Responsive */
/* -------------------------------- */

@media(max-width:992px){

    .hero-content{

        max-width:650px;

    }

}

@media(max-width:768px){

    .about-hero{

        min-height:80vh;

    }

    .hero-content{

        padding:90px 0;

    }

    .hero-content h1 .line{

        font-size:46px;

        letter-spacing:-2px;

    }

    .hero-content p{

        font-size:18px;

    }

    .draft-lines{

        display:none;

    }

}

</style>