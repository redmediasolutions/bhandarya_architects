---
const values = [
  {
    title: "Excellence",
    text: "We pursue the highest standards in every project we undertake.",
  },
  {
    title: "Collaboration",
    text: "Working closely with clients to bring their vision to life through open communication and shared creativity.",
  },
  {
    title: "Innovation",
    text: "Embracing new technologies and sustainable design practices to create future-ready spaces.",
  },
  {
    title: "Passion",
    text: "Every design reflects our deep commitment to architectural excellence and thoughtful craftsmanship.",
  },
];
---

<section class="values section" id="values">

    <div class="background-grid"></div>
    <div class="ambient-light"></div>

    <div class="container">

        <div class="values-header">

            <span class="small-title">
                Our Values
            </span>

            <h2>
                The Principles That
                <br>
                Guide Every Project
            </h2>

            <p>
                Our work is shaped by thoughtful design,
                meaningful collaboration and a passion
                for creating spaces that enrich everyday life.
            </p>

        </div>

        <div class="values-grid">

            {
                values.map((value,index)=>(

                    <article
                        class="value-item"
                        style={`--delay:${index*0.15}s`}
                    >

                        <div class="accent-line"></div>

                        <span class="value-number">

                            {String(index+1).padStart(2,"0")}

                        </span>

                        <h3>{value.title}</h3>

                        <p>{value.text}</p>

                    </article>

                ))
            }

        </div>

    </div>

</section>

<style>

.values{

    position:relative;

    overflow:hidden;

    background:#101010;

    color:white;

}

/* ----------------------- */

.background-grid{

    position:absolute;

    inset:0;

    background-image:

        linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),

        linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);

    background-size:70px 70px;

    animation:gridMove 20s linear infinite;

}

/* ----------------------- */

.ambient-light{

    position:absolute;

    width:900px;

    height:900px;

    top:-300px;

    right:-200px;

    border-radius:50%;

    background:

        radial-gradient(circle,
        rgba(255,120,0,.16),
        transparent 70%);

    filter:blur(80px);

    animation:floatLight 10s ease-in-out infinite alternate;

}

/* ----------------------- */

.values .container{

    position:relative;

    z-index:2;

}

/* ----------------------- */

.values-header{

    max-width:760px;

    margin-bottom:90px;

}

.values-header h2{

    color:white;

    margin:18px 0 22px;

}

.values-header p{

    color:rgba(255,255,255,.68);

}

/* ----------------------- */

.values-grid{

    display:grid;

    grid-template-columns:repeat(4,1fr);

    gap:28px;

}

/* ----------------------- */

.value-item{

    position:relative;

    overflow:hidden;

    padding:42px;

    border-radius:24px;

    background:rgba(255,255,255,.04);

    border:1px solid rgba(255,255,255,.08);

    backdrop-filter:blur(16px);

    opacity:0;

    transform:none;

    transition:
        transform .5s,
        border-color .4s,
        box-shadow .4s,
        background .4s;

}

/* ----------------------- */

.values.animate .value-item{

    animation:cardReveal .9s cubic-bezier(.22,1,.36,1) forwards;

    animation-delay:var(--delay);

}

/* ----------------------- */

.accent-line{

    position:absolute;

    left:0;

    top:0;

    width:0;

    height:3px;

    background:linear-gradient(90deg,var(--accent),transparent);

    transition:.5s;

}

.value-item:hover .accent-line{

    width:100%;

}

/* ----------------------- */

.value-item:hover{

    transform:

        translateY(-12px);

    border-color:rgba(255,140,0,.5);

    background:rgba(255,255,255,.06);

    box-shadow:

        0 25px 60px rgba(0,0,0,.25),

        0 0 60px rgba(255,120,0,.12);

}

/* ----------------------- */

.value-number{

    display:block;

    font-size:64px;

    line-height:1;

    margin-bottom:28px;

    font-weight:700;

    color:rgba(255,255,255,.08);

    transition:.5s;

}

.value-item:hover .value-number{

    color:rgba(255,150,0,.18);

    transform:translateX(8px);

}

/* ----------------------- */

.value-item h3{

    margin-bottom:18px;

    color:white;

    font-size:28px;

}

.value-item p{

    color:rgba(255,255,255,.68);

    line-height:1.8;

}

/* ----------------------- */

@keyframes cardReveal{

    from{

        opacity:0;

        transform:

            translateY(60px)

            scale(.96);

    }

    to{

        opacity:1;

        transform:none;

    }

}

@keyframes floatLight{

    from{

        transform:

            translate(0,0);

    }

    to{

        transform:

            translate(-120px,80px);

    }

}

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:70px 70px;

    }

}

/* ----------------------- */

@media(max-width:991px){

.values-grid{

grid-template-columns:repeat(2,1fr);

}

}

@media(max-width:768px){

.values-grid{

grid-template-columns:1fr;

}

.values-header{

margin-bottom:60px;

}

}

</style>

<script is:inline>

const valuesSection = document.querySelector("#values");

if(valuesSection){

const observer=new IntersectionObserver((entries)=>{

if(entries[0].isIntersecting){

valuesSection.classList.add("animate");

observer.disconnect();

}

},{threshold:.25});

observer.observe(valuesSection);

}

/* Premium Tilt Effect */

document.querySelectorAll(".value-item").forEach(card=>{

card.addEventListener("mousemove",(e)=>{

const r=card.getBoundingClientRect();

const x=e.clientX-r.left;
const y=e.clientY-r.top;

const rx=((y/r.height)-0.5)*-8;
const ry=((x/r.width)-0.5)*8;

card.style.transform=`perspective(1000px) rotateX(${rx}deg) rotateY(${ry}deg) translateY(-8px)`;

});

card.addEventListener("mouseleave",()=>{

card.style.transform="";

});

});

</script>