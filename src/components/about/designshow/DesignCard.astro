---

interface Props {
    title: string;
    description: string;
    image: string;
    index: number;
}

const {
    title,
    description,
    image,
    index,
} = Astro.props;
---

<article
    class:list={["design-card", "slide", { active: index === 0 }]}
    data-index={index}
>

    <img
        src={image}
        alt={title}
        loading={index === 0 ? "eager" : "lazy"}
        decoding="async"
    />

    <div class="overlay"></div>

    <div class="content">

        <span class="eyebrow">

            {String(index + 1).padStart(2, "0")} — Designing With Purpose

        </span>

        <h3>

            {title}

        </h3>

        <p>

            {description}

        </p>

    </div>

</article>

<style>

.design-card{

    position:relative;

    flex:0 0 82vw;

    max-width:1600px;

    height:86vh;

    overflow:hidden;

    border-radius:14px;

    background:#ececec;

    opacity:.4;

    transform:scale(.94);

    transition:

        transform .8s cubic-bezier(.22,1,.36,1),

        opacity .8s cubic-bezier(.22,1,.36,1);

}

/* ----------------------------- */

.design-card.active{

    opacity:1;

    transform:scale(1);

}

/* ----------------------------- */

.design-card img{

    position:absolute;

    inset:0;

    width:100%;

    height:100%;

    object-fit:cover;

    object-position:center;

    transform:scale(1.06);

    transition:

        transform 7s ease,

        filter .6s ease;

    will-change:transform;

    filter:saturate(.96);

}

/* ----------------------------- */

.design-card.active img{

    transform:scale(1.1);

}

/* ----------------------------- */

.overlay{

    position:absolute;

    inset:0;

    background:

        linear-gradient(

            to bottom,

            rgba(0,0,0,.55),

            rgba(0,0,0,.05) 32%,

            transparent 55%

        );

}

/* ----------------------------- */

.content{

    position:absolute;

    left:48px;

    top:48px;

    right:48px;

    z-index:5;

    max-width:640px;

    color:white;

    opacity:0;

    transform:translateY(-24px);

    transition:

        opacity .8s ease,

        transform .8s cubic-bezier(.22,1,.36,1);

}

/* ----------------------------- */

.design-card.active .content{

    opacity:1;

    transform:none;

}

/* ----------------------------- */

.eyebrow{

    display:block;

    margin-bottom:22px;

    font-family: "Manrope", sans-serif;

    font-size:12px;

    font-weight:600;

    letter-spacing:3px;

    text-transform:uppercase;

    color:rgba(255,255,255,.75);

}

/* ----------------------------- */

.content h3{

    font-family: "Noto Serif", serif;

    font-style:italic;

    font-weight:500;

    font-size:clamp(40px,5.5vw,88px);

    line-height:1.02;

    letter-spacing:-.01em;

    margin-bottom:20px;

}

/* ----------------------------- */

.content p{

    font-family: "Manrope", sans-serif;

    font-size:16px;

    line-height:1.7;

    max-width:420px;

    color:rgba(255,255,255,.8);

}

/* ----------------------------- */

@media (max-width:991px){

    .design-card{

        flex:0 0 92vw;

        height:70vh;

        border-radius:10px;

    }

    .content{

        left:28px;

        top:28px;

        right:28px;

    }

    .content h3{

        font-size:34px;

    }

    .content p{

        font-size:15px;

    }

}

/* ----------------------------- */

@media (max-width:768px){

    .design-card{

        flex:0 0 100%;

        height:460px;

        transform:none;

        opacity:1;

    }

    .content{

        opacity:1;

        transform:none;

    }

    .content h3{

        font-size:30px;

    }

    .content p{

        font-size:14px;

        line-height:1.6;

    }

}

</style>