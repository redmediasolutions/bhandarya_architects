---

interface Props {
    total: number;
}

const { total } = Astro.props;
---

<div
    class="design-navigation"
    id="design-navigation"
>

    <div class="counter">

        <span
            id="design-current"
            class="current"
        >
            01
        </span>

        <div class="progress-track">

            <div
                class="progress-fill"
                id="design-progress"
            ></div>

        </div>

        <span class="total">

            {String(total).padStart(2, "0")}

        </span>

    </div>

</div>

<div class="design-arrows">

    <button
        type="button"
        class="arrow-btn"
        id="design-prev"
        aria-label="Previous slide"
    >

        <svg viewBox="0 0 24 24">

            <path
                d="M15 6l-6 6 6 6"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
            />

        </svg>

    </button>

    <button
        type="button"
        class="arrow-btn"
        id="design-next"
        aria-label="Next slide"
    >

        <svg viewBox="0 0 24 24">

            <path
                d="M9 6l6 6-6 6"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
            />

        </svg>

    </button>

</div>

<style>
.design-navigation{

    position:absolute;

    left:48px;

    bottom:40px;

    z-index:20;

    color:white;

}

/* ----------------------------- */

.counter{

    display:flex;

    align-items:center;

    gap:16px;

}

/* ----------------------------- */

.current{

    font-family: "Noto Serif", serif;

    font-style:italic;

    font-size:20px;

    font-weight:500;

}

/* ----------------------------- */

.total{

    font-family: "Manrope", sans-serif;

    font-size:12px;

    font-weight:500;

    letter-spacing:2px;

    color:rgba(255,255,255,.55);

}

/* ----------------------------- */

.progress-track{

    width:90px;

    height:1px;

    background:rgba(255,255,255,.25);

    overflow:hidden;

}

/* ----------------------------- */

.progress-fill{

    width:20%;

    height:100%;

    background:white;

    transition:width .45s ease;

}

/* ----------------------------- */
/* Arrow Buttons
/* ----------------------------- */

.design-arrows{

    position:absolute;

    right:48px;

    bottom:40px;

    z-index:20;

    display:flex;

    gap:12px;

}

/* ----------------------------- */

.arrow-btn{

    display:flex;

    align-items:center;

    justify-content:center;

    width:44px;

    height:44px;

    border:none;

    border-radius:50%;

    background:rgba(0,0,0,.35);

    color:white;

    cursor:pointer;

    transition:

        background .3s ease,

        transform .3s ease;

}

/* ----------------------------- */

.arrow-btn:hover{

    background:rgba(0,0,0,.55);

    transform:translateY(-2px);

}

/* ----------------------------- */

.arrow-btn:active{

    transform:translateY(0);

}

/* ----------------------------- */

.arrow-btn:disabled{

    opacity:.35;

    cursor:default;

    transform:none;

}

/* ----------------------------- */

.arrow-btn svg{

    width:18px;

    height:18px;

}

/* ----------------------------- */

@media(max-width:768px){

    .design-navigation,
    .design-arrows{

        display:none;

    }

}

</style>