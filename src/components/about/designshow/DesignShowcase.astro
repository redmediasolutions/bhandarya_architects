---

import DesignCard from "./DesignCard.astro";
import DesignNavigation from "./DesignNavigation.astro";

const slides = [

    {
        title: "Natural Light",

        description:
            "Every space is designed to maximise daylight and strengthen the connection between indoors and outdoors.",

        image: "/images/projects/kutira/Kuitra.webp",
    },

    {
        title: "Material Palette",

        description:
            "Honest materials chosen for warmth, texture and timeless beauty.",

        image: "/images/projects/samudra/samudra.webp",
    },

];
---

<section class="design-showcase">

    <div class="slider-wrapper">

        <div
            class="slider"
            id="design-slider"
        >

            {
                slides.map((slide, index) => (

                    <DesignCard

                        title={slide.title}

                        description={slide.description}

                        image={slide.image}

                        index={index}

                    />

                ))
            }

        </div>

        <DesignNavigation

            total={slides.length}

        />

    </div>

</section>

<script type="module">

    import "./designShowcase.ts";

</script>

<style>

.design-showcase{

    position:relative;

    height:1100px;

    background:#f5f4f1;

    overflow:hidden;

}

/* ------------------------------ */

.slider-wrapper{

    position:sticky;

    top:0;

    height:100vh;

    overflow:hidden;

    display:flex;

    align-items:center;

}

/* ------------------------------ */

.slider{

    position:absolute;

    top:50%;

    left:0;

    display:flex;

    gap:24px;

    padding:0 9vw;

    transform:translateY(-50%);

    will-change:transform;

}

/* ------------------------------ */

@media(max-width:991px){

    .design-showcase{

        height:auto;

        padding-bottom:60px;

    }

    .slider-wrapper{

        position:relative;

        height:auto;

        overflow:visible;

    }

    .slider{

        position:relative;

        transform:none !important;

        display:flex;

        flex-direction:column;

        gap:28px;

        padding:0 20px;

    }

}

</style>