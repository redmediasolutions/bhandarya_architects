---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {

    title?: string;

    images: ImageMetadata[];

}

const {
    title = "Project Gallery",
    images = [],
} = Astro.props;
---

<section class="project-gallery section">

    <div class="container">

        <div class="section-header">

            <span class="small-title">
                Completed Project
            </span>

            <h2>
                {title}
            </h2>

            <p>
                A collection of completed spaces capturing the
                architecture, interiors and craftsmanship of the
                residence.
            </p>

        </div>

        <div class="gallery-grid">

            {
                images.map((image, index) => (

                    <a
                        href={image.src}
                        class={`gallery-item item-${(index % 6) + 1}`}
                        data-pswp-width={image.width}
                        data-pswp-height={image.height}
                    >

                        <img

    src={image.src}

    width={image.width}

    height={image.height}

    alt={`${title} ${index + 1}`}

    loading="lazy"

/>

                        <div class="gallery-overlay">

                            <span>

                                View Image

                            </span>

                        </div>

                    </a>

                ))
            }

        </div>

    </div>

</section>

<style>

.project-gallery{

    position:relative;

    overflow:hidden;

    background:#faf8f5;

}

/* ====================================== */

.project-gallery::before{

    content:"";

    position:absolute;

    width:900px;

    height:900px;

    right:-300px;

    top:-250px;

    border-radius:50%;

    background:
        radial-gradient(
            rgba(255,120,0,.10),
            transparent 72%
        );

    filter:blur(120px);

}

/* ====================================== */

.section-header{

    max-width:760px;

    margin:0 auto 80px;

    text-align:center;

}

.section-header h2{

    margin:18px 0 20px;

}

.section-header p{

    max-width:620px;

    margin:auto;

}

/* ====================================== */

/* ====================================== */

.gallery-grid{

    display:grid;

    grid-template-columns:repeat(12,1fr);

    gap:22px;

}

/* ====================================== */

.gallery-item{

    position:relative;

    display:block;

    overflow:hidden;

    border-radius:20px;

    background:#ddd;

    box-shadow:
        0 20px 45px rgba(0,0,0,.08);

}

/* Masonry Layout */

.item-1{

    grid-column:span 7;

    aspect-ratio:16/10;

}

.item-2{

    grid-column:span 5;

    aspect-ratio:4/5;

}

.item-3{

    grid-column:span 4;

    aspect-ratio:1/1;

}

.item-4{

    grid-column:span 4;

    aspect-ratio:1/1;

}

.item-5{

    grid-column:span 4;

    aspect-ratio:1/1;

}

.item-6{

    grid-column:span 12;

    aspect-ratio:16/7;

}

/* ====================================== */

.gallery-item img{

    position:absolute;

    inset:0;

    width:100%;

    height:100%;

    object-fit:cover;

    display:block;

    transition:
        transform .8s cubic-bezier(.22,1,.36,1);

}

.gallery-item:hover img{

    transform:scale(1.08);

}

/* ====================================== */

.gallery-item::before{

    content:"";

    position:absolute;

    inset:0;

    background:
        linear-gradient(
            transparent,
            rgba(0,0,0,.65)
        );

    opacity:0;

    transition:.45s;

    z-index:2;

}

.gallery-item:hover::before{

    opacity:1;

}

/* ====================================== */

.gallery-item::after{

    content:"";

    position:absolute;

    inset:18px;

    border:1px solid rgba(255,255,255,.35);

    opacity:0;

    transform:scale(.94);

    transition:.45s;

    z-index:3;

}

.gallery-item:hover::after{

    opacity:1;

    transform:scale(1);

}

/* ====================================== */

.gallery-overlay{

    position:absolute;

    inset:0;

    display:flex;

    align-items:center;

    justify-content:center;

    opacity:0;

    transition:.45s;

    z-index:4;

}

.gallery-item:hover .gallery-overlay{

    opacity:1;

}

.gallery-overlay span{

    padding:16px 34px;

    border-radius:999px;

    backdrop-filter:blur(18px);

    background:rgba(255,255,255,.18);

    border:1px solid rgba(255,255,255,.35);

    color:#fff;

    text-transform:uppercase;

    letter-spacing:2px;

    font-size:12px;

}

/* ====================================== */

@media(max-width:991px){

    .gallery-grid{

        grid-template-columns:repeat(2,1fr);

    }

    .item-1,
    .item-2,
    .item-3,
    .item-4,
    .item-5,
    .item-6{

        grid-column:auto;

        aspect-ratio:4/3;

    }

}

@media(max-width:768px){

    .gallery-grid{

        grid-template-columns:1fr;

    }

    .gallery-item{

        aspect-ratio:4/3 !important;

    }

}

</style>

<script>

document.addEventListener("DOMContentLoaded", async () => {

    const { default: PhotoSwipeLightbox } = await import("photoswipe/lightbox");
    await import("photoswipe/style.css");

    const lightbox = new PhotoSwipeLightbox({

        gallery: ".gallery-grid",

        children: "a",

        pswpModule: () => import("photoswipe")

    });

    lightbox.init();

    const section = document.querySelector(".project-gallery");

    if(!section) return;

    const observer = new IntersectionObserver((entries)=>{

        if(entries[0].isIntersecting){

            section.classList.add("visible");

            observer.disconnect();

        }

    },{

        threshold:.2

    });

    observer.observe(section);

});

</script>