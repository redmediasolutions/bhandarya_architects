---
interface Download {

    title: string;

    description?: string;

    type: string;

    size?: string;

    file: string;

}

interface Props {

    downloads: Download[];

}

const { downloads = [] } = Astro.props;
---

{
    downloads.length > 0 && (

<section class="project-downloads section">

    <div class="container">

        <div class="downloads-header">

            <span class="small-title">

                Project Documentation

            </span>

            <h2>

                Available Downloads

            </h2>

            <p>

                Explore architectural drawings, presentation sheets and
                supporting project documents available for this residence.

            </p>

        </div>

        <div class="downloads-grid">

            {

                downloads.map((item)=>(

                    <a
                        href={item.file}
                        class="download-card"
                        download
                        target="_blank"
                        rel="noopener"
                    >

                        <div class="download-type">

                            {item.type}

                        </div>

                        <h3>

                            {item.title}

                        </h3>

                        {

                            item.description && (

                                <p>

                                    {item.description}

                                </p>

                            )

                        }

                        <div class="download-footer">

                            {

                                item.size && (

                                    <span>

                                        {item.size}

                                    </span>

                                )

                            }

                            <strong>

                                Download →

                            </strong>

                        </div>

                    </a>

                ))

            }

        </div>

    </div>

</section>

    )
}

<style>

.project-downloads{

    background:#faf8f5;

    position:relative;

    overflow:hidden;

}

/* ===================================== */

.downloads-header{

    text-align:center;

    max-width:760px;

    margin:0 auto 70px;

}

.downloads-header h2{

    margin:18px 0;

}

.downloads-header p{

    max-width:620px;

    margin:auto;

}

/* ===================================== */

.downloads-grid{

    display:grid;

    grid-template-columns:repeat(auto-fit,minmax(320px,1fr));

    gap:30px;

}

/* ===================================== */

.download-card{

    display:flex;

    flex-direction:column;

    padding:38px;

    border-radius:24px;

    background:#fff;

    border:1px solid rgba(0,0,0,.08);

    text-decoration:none;

    transition:.35s;

    box-shadow:

        0 20px 45px rgba(0,0,0,.06);

}

.download-card:hover{

    transform:translateY(-8px);

    box-shadow:

        0 35px 70px rgba(0,0,0,.12);

}

/* ===================================== */

.download-type{

    width:max-content;

    padding:8px 14px;

    border-radius:999px;

    background:rgba(255,120,0,.08);

    color:var(--accent);

    font-size:11px;

    font-weight:600;

    letter-spacing:2px;

    text-transform:uppercase;

    margin-bottom:24px;

}

.download-card h3{

    font-size:28px;

    margin:0 0 18px;

    color:#111;

}

.download-card p{

    color:#666;

    line-height:1.8;

    margin:0;

}

/* ===================================== */

.download-footer{

    margin-top:auto;

    padding-top:34px;

    display:flex;

    justify-content:space-between;

    align-items:center;

    border-top:1px solid rgba(0,0,0,.08);

}

.download-footer span{

    color:#999;

    font-size:14px;

}

.download-footer strong{

    color:var(--accent);

    font-weight:600;

}

/* ===================================== */

@media(max-width:768px){

    .downloads-grid{

        grid-template-columns:1fr;

    }

    .download-card{

        padding:30px;

    }

    .download-card h3{

        font-size:24px;

    }

}

</style>