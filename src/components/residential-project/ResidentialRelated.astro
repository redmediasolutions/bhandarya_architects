---
import projects from "../../content/residential";
import { getResidentialImages } from "../../lib/residentialImages";

interface Props {
    project: any;
}

const { project } = Astro.props;

/* ========================================= */
/* Related Projects */
/* ========================================= */

const relatedProjects = projects.filter((p) =>
    project.related.includes(p.slug)
);
---

<section class="related-projects section">

    <div class="container">

        <div class="section-heading">

            <span class="small-title">

                More Projects

            </span>

            <h2>

                Continue Exploring

            </h2>

            <p>

                Discover more projects crafted with the same attention
                to detail, timeless design and thoughtful planning.

            </p>

        </div>

        <div class="projects-grid">

            {
                relatedProjects.map((item, index) => {

                    const { hero } = getResidentialImages(item.folder);

                    return (

                        <a
                            href={`/projects/residences/${item.slug}`}
                            class="project-card"
                            style={`--delay:${index * .12}s`}
                        >

                            <img
                                src={hero.src}
                                alt={item.title}
                                loading="lazy"
                            />

                            <div class="overlay">

                                <span>

                                    {item.location}

                                </span>

                                <h3>

                                    {item.title}

                                </h3>

                                <div class="line"></div>

                                <div class="view-link">

                                    Explore Project →

                                </div>

                            </div>

                        </a>

                    );

                })
            }

        </div>

    </div>

</section>

<style>

.related-projects{

    position:relative;

    background:#faf8f5;

    overflow:hidden;

}

/* ===================================== */

.related-projects::before{

    content:"";

    position:absolute;

    width:900px;

    height:900px;

    right:-280px;

    bottom:-250px;

    border-radius:50%;

    background:

        radial-gradient(

            rgba(255,120,0,.10),

            transparent 72%

        );

    filter:blur(120px);

}

/* ===================================== */

.section-heading{

    max-width:720px;

    margin:0 auto 70px;

    text-align:center;

}

.section-heading h2{

    margin:18px 0;

}

/* ===================================== */

.projects-grid{

    display:grid;

    grid-template-columns:repeat(3,1fr);

    gap:30px;

}

/* ===================================== */

.project-card{

    position:relative;

    display:block;

    overflow:hidden;

    border-radius:22px;

    aspect-ratio:4/5;

    box-shadow:

        0 20px 50px rgba(0,0,0,.08);

    opacity:0;

    transform:translateY(60px);

    transition:

        opacity .8s,

        transform .8s,

        box-shadow .45s;

}

.related-projects.visible .project-card{

    opacity:1;

    transform:none;

    transition-delay:var(--delay);

}

.project-card img{

    width:100%;

    height:100%;

    object-fit:cover;

    display:block;

    transition:

        transform 2s cubic-bezier(.22,1,.36,1);

}

.project-card:hover img{

    transform:scale(1.08);

}

/* ===================================== */

.project-card::after{

    content:"";

    position:absolute;

    inset:20px;

    border:1px solid rgba(255,255,255,.35);

    opacity:0;

    transform:scale(.95);

    transition:.45s;

}

.project-card:hover::after{

    opacity:1;

    transform:scale(1);

}

/* ===================================== */

.overlay{

    position:absolute;

    inset:0;

    display:flex;

    flex-direction:column;

    justify-content:flex-end;

    padding:36px;

    background:

        linear-gradient(

            transparent,

            rgba(0,0,0,.85)

        );

}

.overlay span{

    color:rgba(255,255,255,.72);

    text-transform:uppercase;

    letter-spacing:2px;

    font-size:11px;

}

.overlay h3{

    margin:14px 0 18px;

    color:white;

    font-size:34px;

}

.line{

    width:0;

    height:2px;

    background:var(--accent);

    transition:.45s;

}

.project-card:hover .line{

    width:90px;

}

.view-link{

    margin-top:20px;

    color:var(--accent);

    text-transform:uppercase;

    letter-spacing:2px;

    font-size:12px;

    font-weight:600;

    transition:.35s;

}

.project-card:hover .view-link{

    letter-spacing:3px;

}

/* ===================================== */

@media(max-width:991px){

    .projects-grid{

        grid-template-columns:1fr;

    }

    .project-card{

        aspect-ratio:16/10;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const section=document.querySelector(".related-projects");

    if(!section)return;

    const observer=new IntersectionObserver(entries=>{

        if(entries[0].isIntersecting){

            section.classList.add("visible");

            observer.disconnect();

        }

    },{

        threshold:.2

    });

    observer.observe(section);

});

</script>