---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
    project: {
        title: string;
        category: string;
        location: string;
        year: string;
        area: string;
    };

    hero: ImageMetadata;
}

const { project, hero } = Astro.props;
---

<section class="project-hero">

    <div class="container">

        <div class="hero-header">

            <span class="small-title">

                {project.category}

            </span>

            <h1>

                {project.title}

            </h1>

        </div>

        <div class="hero-image">

            <Image
                src={hero}
                alt={project.title}
                loading="eager"
                class="hero-img"
            />

            <div class="hero-overlay"></div>

            <div class="project-info">

                <div>

                    <small>

                        Location

                    </small>

                    <strong>

                        {project.location}

                    </strong>

                </div>

                <div>

                    <small>

                        Built Up Area

                    </small>

                    <strong>

                        {project.area}

                    </strong>

                </div>

                <div>

                    <small>

                        Completed

                    </small>

                    <strong>

                        {project.year}

                    </strong>

                </div>

            </div>

        </div>

    </div>

</section>

<style>

.project-hero{

    padding:160px 0 90px;

    background:#faf8f5;

}

/* ===================================== */

.hero-header{

    text-align:center;

    max-width:900px;

    margin:0 auto 60px;

}

.hero-header h1{

    margin-top:18px;

    font-size:clamp(56px,7vw,110px);

    line-height:.92;

    letter-spacing:-2px;

}

.hero-header .small-title{

    letter-spacing:4px;

}

/* ===================================== */

.hero-image{

    position:relative;

    overflow:hidden;

    border-radius:26px;

    box-shadow:
        0 35px 90px rgba(0,0,0,.12);

}

.hero-img{

    display:block;

    width:100%;

    height:min(80vh,900px);

    object-fit:cover;

    transition:
        transform 2.4s cubic-bezier(.22,1,.36,1);

}

.hero-image:hover .hero-img{

    transform:scale(1.04);

}

.hero-overlay{

    position:absolute;

    inset:0;

    background:
        linear-gradient(
            transparent 45%,
            rgba(0,0,0,.75)
        );

}

/* ===================================== */

.project-info{

    position:absolute;

    left:50%;

    bottom:40px;

    transform:translateX(-50%);

    width:calc(100% - 80px);

    max-width:1100px;

    display:grid;

    grid-template-columns:repeat(3,1fr);

    gap:40px;

    padding:28px 36px;

    background:rgba(255,255,255,.92);

    backdrop-filter:blur(20px);

    border-radius:20px;

    box-shadow:
        0 20px 60px rgba(0,0,0,.18);

}

.project-info small{

    display:block;

    margin-bottom:10px;

    text-transform:uppercase;

    letter-spacing:2px;

    font-size:11px;

    color:#888;

}

.project-info strong{

    font-size:18px;

    font-weight:600;

    color:#111;

}

/* ===================================== */

@media(max-width:991px){

    .project-info{

        grid-template-columns:1fr;

        gap:22px;

        width:calc(100% - 40px);

    }

}

@media(max-width:768px){

    .project-hero{

        padding:120px 0 70px;

    }

    .hero-header{

        margin-bottom:40px;

    }

    .hero-header h1{

        font-size:52px;

    }

    .hero-img{

        height:60vh;

    }

    .project-info{

        position:relative;

        left:auto;

        bottom:auto;

        transform:none;

        width:100%;

        margin-top:-4px;

        border-radius:0 0 20px 20px;

    }

}

</style>