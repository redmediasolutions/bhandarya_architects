---
import residential from "../../content/residential";
import commercial from "../../content/commercial";
import interior from "../../content/interiors";
import educational from "../../content/educational";

import { getResidentialImages } from "../../lib/residentialImages";
import { getCommercialImages } from "../../lib/commercialImages";
import { getInteriorImages } from "../../lib/interiorImages";
import { getEducationalImages } from "../../lib/educationalImages";

const latestProjects = [
    ...residential.slice(0, 3).map(project => ({
        ...project,
        category: "Residential",
        href: `/projects/residences/${project.slug}`,
        image: getResidentialImages(project.folder).hero.src
    })),

    ...commercial.slice(0, 3).map(project => ({
        ...project,
        category: "Commercial",
        href: `/projects/commercial/${project.slug}`,
        image: getCommercialImages(project.folder).hero.src
    })),

    ...interior.slice(0, 3).map(project => ({
        ...project,
        category: "Interior",
        href: `/projects/interiors/${project.slug}`,
        image: getInteriorImages(project.folder).hero.src
    })),

    ...educational.slice(0, 3).map(project => ({
        ...project,
        category: "Educational",
        href: `/projects/educational/${project.slug}`,
        image: getEducationalImages(project.folder).hero.src
    }))
];
---

<section class="projects section">
    <div class="container">
        <div class="projects-header">
            <div>
                <span class="small-title">Featured Projects</span>
                <h2>Spaces Crafted with Purpose</h2>
            </div>
            <a href="/projects" class="text-link">
                View All Projects <span class="arrow">→</span>
            </a>
        </div>

       <div class="projects-grid">

    {
        latestProjects.map((project, index) => (

            <a
    href={project.href}
    class={`project-card ${
        index === 0
            ? "featured"
            : index % 3 === 0
            ? "wide"
            : index % 3 === 0
            ? "square"
            : "vertical"
    }`}
>

               <img
    src={project.image}
    alt={project.title}
    loading="lazy"
/>

                <div class="project-overlay">

                    <div class="project-meta">

                        <span class="project-category">

    {project.category}

</span>
                        <h3>

    {project.title}

</h3>

                        <div class="project-line"></div>

                    </div>

                </div>

            </a>

        ))
    }

</div>
    </div>
</section>

<style>
/* ================================================= */
/* PROJECTS SECTION */
/* ================================================= */

.projects{

    position:relative;

    overflow:hidden;

    background:#f8f8f6;

}

/* subtle architectural grid */

.projects::before{

    content:"";

    position:absolute;

    inset:0;

    background-image:
        linear-gradient(rgba(0,0,0,.035) 1px,transparent 1px),
        linear-gradient(90deg,rgba(0,0,0,.035) 1px,transparent 1px);

    background-size:80px 80px;

    opacity:.45;

    pointer-events:none;

}

/* orange glow */

.projects::after{

    content:"";

    position:absolute;

    width:700px;

    height:700px;

    right:-220px;

    top:-220px;

    border-radius:50%;

    background:

        radial-gradient(circle,

        rgba(255,120,0,.08),

        transparent 70%);

    filter:blur(70px);

    animation:ambientMove 16s ease-in-out infinite alternate;

}

.projects .container{

    position:relative;

    z-index:2;

}

/* ================================================= */

.projects-header{

    display:flex;

    justify-content:space-between;

    align-items:flex-end;

    gap:60px;

    margin-bottom:70px;

}

.projects-header h2{

    margin-top:18px;

}

.projects-header p{

    max-width:520px;

}

/* ================================================= */

.text-link{

    display:flex;

    align-items:center;

    gap:12px;

    text-decoration:none;

    color:var(--black);

    font-weight:600;

    letter-spacing:.5px;

}

.text-link .arrow{

    transition:

        transform .45s cubic-bezier(.22,1,.36,1);

}

.text-link:hover .arrow{

    transform:translateX(8px);

}

/* ================================================= */
/* GRID */
/* ================================================= */

.projects-grid{

    display:grid;

    grid-template-columns:repeat(12,minmax(0,1fr));

    grid-auto-rows:120px;

    gap:24px;

}

/* ------------------------- */

.project-card{

    position:relative;

    overflow:hidden;

    border-radius:14px;

    background:#111;

    cursor:pointer;

    isolation:isolate;

    box-shadow:

        0 20px 50px rgba(0,0,0,.08);

}

/* ------------------------- */
/* Layout */

.project-card.featured{

    grid-column:span 7;

    grid-row:span 6;

}

.project-card.vertical{

    grid-column:span 5;

    grid-row:span 3;

}

.project-card.square{

    grid-column:span 3;

    grid-row:span 3;

}

.project-card.wide{

    grid-column:span 6;

    grid-row:span 3;

}

/* ------------------------- */
/* Image */

.project-card img{

    width:100%;

    height:100%;

    object-fit:cover;

    display:block;

    transform:scale(1.08);

    transition:

        transform 1.8s cubic-bezier(.22,1,.36,1),

        filter .8s ease;

}

/* Featured gets continuous movement */

.project-card.featured img{

    animation:

        kenBurns 18s ease-in-out infinite alternate;

}

/* ------------------------- */
/* Overlay */

.project-overlay{

    position:absolute;

    inset:0;

    display:flex;

    align-items:flex-end;

    padding:34px;

    background:

        linear-gradient(

            180deg,

            transparent 20%,

            rgba(0,0,0,.25) 45%,

            rgba(0,0,0,.82) 100%

        );

    transition:

        background .6s ease;

}

/* ------------------------- */

.project-meta{

    width:100%;

}

/* ================================================= */
/* PREMIUM HOVER */
/* ================================================= */

.project-card::before{

    content:"";

    position:absolute;

    inset:-30%;

    background:

        radial-gradient(

            circle,

            rgba(255,120,0,.16),

            transparent 65%

        );

    opacity:0;

    transform:scale(.8);

    transition:

        opacity .8s ease,

        transform .8s ease;

    z-index:1;

}

/* Blueprint frame */

.project-card::after{

    content:"";

    position:absolute;

    inset:16px;

    border:1px solid rgba(255,140,0,.35);

    opacity:0;

    transform:scale(.95);

    transition:

        transform .6s cubic-bezier(.22,1,.36,1),

        opacity .6s ease;

    z-index:3;

    pointer-events:none;

}

/* ----------------------------- */

.project-category{

    display:block;

    font-size:11px;

    text-transform:uppercase;

    letter-spacing:3px;

    color:rgba(255,255,255,.72);

    margin-bottom:10px;

    transform:translateY(20px);

    opacity:0;

    transition:

        .55s cubic-bezier(.22,1,.36,1);

}

.project-overlay h3{

    color:white;

    margin:0;

    font-size:32px;

    line-height:1.2;

    transform:translateY(34px);

    transition:

        .65s cubic-bezier(.22,1,.36,1);

}

/* orange sketch line */

.project-line{

    width:0;

    height:2px;

    margin-top:18px;

    background:

        linear-gradient(

            90deg,

            var(--accent),

            rgba(255,170,90,.2)

        );

    transition:

        width .7s cubic-bezier(.22,1,.36,1);

}

/* ================================================= */
/* Hover */
/* ================================================= */

.project-card:hover img{

    transform:

        scale(1.12)

        translateY(-10px);

    filter:

        brightness(1.05)

        contrast(1.05)

        saturate(1.05);

}

.project-card:hover::before{

    opacity:1;

    transform:scale(1);

}

.project-card:hover::after{

    opacity:1;

    transform:scale(1);

}

.project-card:hover .project-overlay{

    background:

        linear-gradient(

            180deg,

            transparent,

            rgba(0,0,0,.92)

        );

}

.project-card:hover .project-category{

    opacity:1;

    transform:none;

}

.project-card:hover h3{

    transform:none;

}

.project-card:hover .project-line{

    width:95px;

}

/* subtle lift */

.project-card:hover{

    transform:

        translateY(-8px);

    box-shadow:

        0 35px 70px rgba(0,0,0,.18);

}


/* ================================================= */
/* SCROLL REVEAL */
/* ================================================= */

.project-card{

    opacity:0;

    transform:

        translateY(80px)

        scale(.96);

    transition:

        opacity .9s cubic-bezier(.22,1,.36,1),

        transform .9s cubic-bezier(.22,1,.36,1),

        box-shadow .45s ease;

}

/* Reveal */

.projects.visible .project-card{

    opacity:1;

    transform:none;

}

/* Stagger */

.projects.visible .project-card:nth-child(1){

    transition-delay:.10s;

}

.projects.visible .project-card:nth-child(2){

    transition-delay:.22s;

}

.projects.visible .project-card:nth-child(3){

    transition-delay:.34s;

}

.projects.visible .project-card:nth-child(4){

    transition-delay:.46s;

}

.projects.visible .project-card:nth-child(5){

    transition-delay:.58s;

}

.projects.visible .project-card:nth-child(6){

    transition-delay:.70s;

}

/* ================================================= */
/* KEN BURNS */
/* ================================================= */

@keyframes kenBurns{

    0%{

        transform:

            scale(1.06)

            translate(0,0);

    }

    50%{

        transform:

            scale(1.12)

            translate(-10px,-14px);

    }

    100%{

        transform:

            scale(1.08)

            translate(12px,8px);

    }

}

/* ================================================= */
/* Ambient Background Animation */
/* ================================================= */

@keyframes ambientMove{

    from{

        transform:

            translate(0,0)

            scale(1);

    }

    to{

        transform:

            translate(-120px,90px)

            scale(1.18);

    }

}

/* ================================================= */
/* Optional Floating Effect */
/* ================================================= */

.project-card.featured{

    animation:

        featuredFloat 10s ease-in-out infinite;

}

@keyframes featuredFloat{

    0%{

        transform:translateY(0);

    }

    50%{

        transform:translateY(-6px);

    }

    100%{

        transform:translateY(0);

    }

}

/* ================================================= */
/* RESPONSIVE */
/* ================================================= */

@media(max-width:1200px){

    .projects-grid{

        grid-template-columns:repeat(8,1fr);

    }

    .project-card.featured{

        grid-column:span 8;

        grid-row:span 5;

    }

    .project-card.vertical{

        grid-column:span 4;

    }

    .project-card.square{

        grid-column:span 4;

    }

    .project-card.wide{

        grid-column:span 8;

    }

}

/* ------------------------------------------------ */

@media(max-width:991px){

    .projects{

        padding:100px 0;

    }

    .projects-header{

        flex-direction:column;

        align-items:flex-start;

        gap:24px;

        margin-bottom:50px;

    }

    .projects-grid{

        grid-template-columns:repeat(2,1fr);

        grid-auto-rows:260px;

        gap:20px;

    }

    .project-card.featured{

        grid-column:1 / -1;

        grid-row:span 2;

    }

    .project-card.vertical{

        grid-column:auto;

        grid-row:span 1;

    }

    .project-card.square{

        grid-column:auto;

        grid-row:span 1;

    }

    .project-card.wide{

        grid-column:1 / -1;

        grid-row:span 1;

    }

    .project-overlay{

        padding:26px;

    }

    .project-overlay h3{

        font-size:26px;

    }

}

/* ------------------------------------------------ */

@media(max-width:768px){

    .projects{

        padding:80px 0;

    }

    .projects-grid{

        grid-template-columns:1fr;

        grid-auto-rows:280px;

    }

    .project-card{

        grid-column:auto !important;

        grid-row:auto !important;

    }

    .project-card.featured{

        min-height:420px;

    }

    .project-overlay{

        padding:22px;

    }

    .project-overlay h3{

        font-size:22px;

    }

    .project-category{

        font-size:10px;

        letter-spacing:2px;

    }

    .project-line{

        width:70px;

    }

    /* Better performance on phones */

    .project-card:hover{

        transform:none;

        box-shadow:

            0 20px 40px rgba(0,0,0,.12);

    }

    .project-card:hover img{

        transform:scale(1.05);

    }

}

/* ================================================= */
/* ACCESSIBILITY */
/* ================================================= */

@media (prefers-reduced-motion: reduce){

    .project-card,
    .project-card img,
    .project-overlay,
    .project-category,
    .project-line,
    .arrow{

        animation:none !important;

        transition:none !important;

    }

}
</style>

<script is:inline>

document.addEventListener("DOMContentLoaded", () => {

    const section = document.querySelector(".projects");

    if(!section) return;

    /* -------------------------------- */
    /* Reveal Animation */
    /* -------------------------------- */

    const observer = new IntersectionObserver((entries)=>{

        entries.forEach(entry=>{

            if(entry.intersectionRatio < 0.25) return;

            section.classList.add("visible");

            observer.disconnect();

        });

    },{

        threshold:[0,.25,.5]

    });

    observer.observe(section);

    /* -------------------------------- */
    /* Premium Parallax */
    /* -------------------------------- */

    const cards = [...section.querySelectorAll(".project-card")];

    let ticking = false;

    function updateParallax(){

        cards.forEach(card=>{

            const img = card.querySelector("img");

            const rect = card.getBoundingClientRect();

            const center = window.innerHeight / 2;

            const distance = rect.top + rect.height/2 - center;

            const translate = distance * -0.04;

            img.style.transform =

                `translate3d(0,${translate}px,0) scale(1.08)`;

        });

        ticking = false;

    }

    window.addEventListener("scroll",()=>{

        if(!ticking){

            requestAnimationFrame(updateParallax);

            ticking = true;

        }

    },{

        passive:true

    });

    updateParallax();

    /* -------------------------------- */
    /* Premium Mouse Tilt */
    /* -------------------------------- */

    cards.forEach(card=>{

        const img = card.querySelector("img");

        card.addEventListener("mousemove",(e)=>{

            const rect = card.getBoundingClientRect();

            const x = e.clientX - rect.left;

            const y = e.clientY - rect.top;

            const rotateY =

                ((x / rect.width) - .5) * 6;

            const rotateX =

                ((y / rect.height) - .5) * -6;

            card.style.transform =

                `perspective(1400px)
                 rotateX(${rotateX}deg)
                 rotateY(${rotateY}deg)
                 translateY(-8px)`;

            img.style.transform +=
                " scale(1.04)";

        });

        card.addEventListener("mouseleave",()=>{

            card.style.transform="";

            img.style.transform="";

        });

    });

});

</script>