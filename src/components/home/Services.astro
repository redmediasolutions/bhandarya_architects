---
const services = [
  {
    title: "Architectural Design",
    description:
      "Innovative residential, commercial and institutional architecture designed around context, functionality and timeless aesthetics.",
      icon: "▢",
  },
  {
    title: "Interior Design",
    description:
      "Elegant interiors that combine materiality, lighting and spatial planning to create refined living and working environments.",
      icon: "◫",
  },
  {
    title: "Master Planning",
    description:
      "Comprehensive planning solutions that optimise land use, circulation, sustainability and long-term development potential.",
      icon: "◎",
  },
  {
    title: "Landscape Design",
    description:
      "Outdoor environments that seamlessly integrate architecture, nature and lifestyle through thoughtful landscape planning.",
      icon: "✦",
  },
  {
    title: "Project Management",
    description:
      "End-to-end coordination from concept to completion, ensuring quality, timelines and cost efficiency throughout construction.",
      icon: "◇",
  },
  {
    title: "Renovation & Restoration",
    description:
      "Transforming existing spaces while preserving their character through modern interventions and meticulous craftsmanship.",
      icon: "◈",
  },
];
---

<section class="services section">

    <div class="container">

        <div class="services-heading">

            <span class="small-title">
                Our Services
            </span>

            <h2>
                Complete Architectural Solutions
            </h2>

            <p>
                We provide comprehensive architectural and interior design
                services that transform ideas into enduring spaces.
            </p>

        </div>

        <div class="services-grid">

            {
                services.map((service) => (

                    <article class="service-card">

                        <div class="service-icon">
                            {service.icon}
                        </div>

                        <h3>
                            {service.title}
                        </h3>

                        <p>
                            {service.description}
                        </p>

                        <a href="/services">
                            Learn More →
                        </a>

                    </article>

                ))
            }

        </div>

    </div>

</section>

<style>

.services{
    background:var(--white);
}

.services-heading{
    max-width:720px;
    margin-bottom:70px;
}

.services-heading h2{
    margin:20px 0;
}

.services-heading p{
    max-width:620px;
}

.services-grid{

    display:grid;

    grid-template-columns:repeat(3,1fr);

    gap:30px;

}

.service-card{

    padding:45px;

    border:1px solid var(--border);

    transition:var(--transition);

    background:var(--white);

}

.service-card:hover{

    transform:translateY(-8px);

    box-shadow:var(--shadow);

    border-color:var(--accent);

}

.service-icon{

    width:70px;

    height:70px;

    border:1px solid var(--border);

    display:flex;

    align-items:center;

    justify-content:center;

    border-radius:50%;

    font-size:28px;

    margin-bottom:30px;

    transition:var(--transition);

}

.service-card:hover .service-icon{

    background:var(--accent);

    border-color:var(--accent);

    color:white;

}

.service-card h3{

    margin-bottom:18px;

}

.service-card p{

    margin-bottom:28px;

}

.service-card a{

    font-size:13px;

    text-transform:uppercase;

    letter-spacing:2px;

    color:var(--accent);

    font-weight:600;

}

@media(max-width:991px){

    .services-grid{

        grid-template-columns:repeat(2,1fr);

    }

}

@media(max-width:768px){

    .services-grid{

        grid-template-columns:1fr;

    }

    .services-heading{

        margin-bottom:50px;

    }

    .service-card{

        padding:35px;

    }

}

</style>