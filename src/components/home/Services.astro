---
const services = [
  {
    title: "Commercial Architecture",
    description:
      "Innovative designs for corporate spaces that inspire productivity and reflect your brand identity.",
    image: "/images/slides/11.webp",
  },
  {
    title: "Residential Design",
    description:
      "Creating dream homes that blend functionality with aesthetic elegance for modern living.",
    image: "/images/slides/10.webp",
  },
  {
    title: "Interior Design",
    description:
      "Transforming interiors into masterpieces with attention to detail and timeless style.",
    image: "/images/slides/(9).webp",
  },
];
---

<section class="services section">
    <div class="container">
        <div class="services-heading">
            <span class="small-title">Our Services</span>
            <h2>Complete Architectural Solutions</h2>
            <p>
                We provide comprehensive architectural and interior design
                services that transform ideas into enduring spaces.
            </p>
        </div>

        <div class="services-grid">
            {
                services.map((service) => (
                    <article class="service-card">
                        <!-- Immersive Background Image Layer -->
                        <div class="shine"></div>
                        <div class="service-bg-wrap">
                            <img src={service.image} alt={service.title} class="service-bg-img" />
                        </div>
                        
                        <!-- Dark Cinematic Overlay -->
                        <div class="service-overlay"></div>

                        <!-- Content Container -->
                        <div class="service-content">
                            <h3>{service.title}</h3>
                            <div class="service-line"></div>
                            <p class="service-desc">{service.description}</p>
                            <span class="service-link">
                                Learn More <span class="arrow">→</span>
                            </span>
                        </div>
                    </article>
                ))
            }
        </div>
    </div>
</section>

<style>
/* --- Outer Section Canvas --- */
.services {
    background: var(--white);
    padding: 100px 0;
}

.services-heading {
    max-width: 720px;
    margin-bottom: 70px;
}

.services-heading h2 {
    margin: 20px 0;
    font-size: 2.5rem;
    font-weight: 600;
}

.services-heading p {
    max-width: 620px;
    opacity: 0.8;
    line-height: 1.6;
}

.services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
}

/* --- Premium Image-Based Box --- */
.service-card{

    position:relative;

    overflow:hidden;

    border-radius:18px;

    min-height:560px;

    cursor:pointer;

    isolation:isolate;

    background:#111;

    opacity:0;

    transform:translateY(80px);

    transition:

        transform .9s cubic-bezier(.22,1,.36,1),

        opacity .8s ease,

        box-shadow .5s ease;

}

.services.visible .service-card{

    opacity:1;

    transform:none;

}

.services.visible .service-card:nth-child(1){

    transition-delay:.15s;

}

.services.visible .service-card:nth-child(2){

    transition-delay:.3s;

}

.services.visible .service-card:nth-child(3){

    transition-delay:.45s;

}

.service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.35);
}

/* --- Background Image Architecture --- */
.service-bg-wrap {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
}

.service-bg-img{

    width:100%;

    height:100%;

    object-fit:cover;

    filter:

        grayscale(20%)

        brightness(.82)

        saturate(.75);

    transform:scale(1.08);

    transition:

        transform 2s cubic-bezier(.22,1,.36,1),

        filter .9s ease;

}

/* cinematic movement */

.service-bg-wrap{

    animation:

        kenBurns 18s ease-in-out infinite alternate;

}

.service-card:hover .service-bg-img{

    transform:

        scale(1.14);

    filter:

        grayscale(0)

        brightness(1)

        saturate(1);

}

.service-card:hover{

    transform:

        translateY(-10px);

    box-shadow:

        0 45px 90px rgba(0,0,0,.24);

}

/* --- Dark Glass/Gradient Overlay --- */
.service-overlay{

    position:absolute;

    inset:0;

    z-index:2;

    background:

        linear-gradient(

            180deg,

            rgba(0,0,0,.12) 0%,

            rgba(0,0,0,.28) 35%,

            rgba(0,0,0,.82) 100%

        );

    transition:.6s;

}

.service-card:hover .service-overlay{

    background:

        linear-gradient(

            180deg,

            rgba(0,0,0,.15) 0%,

            rgba(0,0,0,.45) 40%,

            rgba(0,0,0,.95) 100%

        );

}

.service-card:hover .service-overlay{

    background:

        linear-gradient(

            transparent,

            rgba(0,0,0,.94)

        );

}

.service-card::after{

    content:"";

    position:absolute;

    inset:16px;

    border:1px solid rgba(255,120,0,.35);

    opacity:0;

    transform:scale(.94);

    transition:.6s;

    z-index:5;

}

.service-card:hover::after{

    opacity:1;

    transform:scale(1);

}
.service-card::before{

    content:"";

    position:absolute;

    inset:-40%;

    background:

        radial-gradient(

            circle,

            rgba(255,120,0,.18),

            transparent 70%

        );

    opacity:0;

    transition:.8s;

}

.service-card:hover::before{

    opacity:1;

}

.service-card:hover .service-desc{

    opacity:.85;

    transform:none;

}

.service-line{

    width:60px;

    height:2px;

    margin:18px 0 22px;

    background:var(--accent);

    transition:

        width .7s cubic-bezier(.22,1,.36,1);

}

.service-card:hover .service-line{

    width:120px;

}


.service-card .shine{

    position:absolute;

    inset:0;

    background:

        linear-gradient(

            120deg,

            transparent 30%,

            rgba(255,255,255,.08),

            transparent 70%

        );

    transform:translateX(-180%);

    animation:

        shineMove 8s linear infinite;

}

@keyframes shineMove{

    to{

        transform:translateX(180%);

    }

}
.service-card:hover .service-overlay {
    /* Richer shadow backdrop on hover to pull text into high contrast */
    background: linear-gradient(
        to top,
        rgba(10, 10, 10, 0.98) 0%,
        rgba(10, 10, 10, 0.7) 60%,
        rgba(10, 10, 10, 0.4) 100%
    );
}

/* --- Content Layout --- */
.service-content{

    position:absolute;

    left:0;

    right:0;

    bottom:0;

    z-index:6;

    padding:42px;

    display:flex;

    flex-direction:column;

    justify-content:flex-end;

    color:#fff;

    transform:translateY(40px);

    transition:

        transform .7s cubic-bezier(.22,1,.36,1);

}

.service-card:hover .service-content {
    transform: translateY(0);
}

.service-card h3{

    margin:0;

    color:white;

    font-size:32px;

    font-weight:500;

    line-height:1.2;

}

.service-desc{

    color:rgba(255,255,255,.72);

    line-height:1.8;

    margin:0;

    max-height:0;

    overflow:hidden;

    opacity:0;

    transform:translateY(20px);

    transition:

        max-height .6s ease,

        opacity .45s ease,

        transform .45s ease,

        margin .45s ease;

}

.service-card:hover .service-desc{

    opacity:1;

    max-height:180px;

    transform:none;

    margin-top:10px;

}

.service-card:hover .service-desc {
    opacity: 0.85;
    max-height: 100px; /* Smooth transition expansion */
    margin-bottom: 30px;
}

/* Dynamic Interactive Link */
.service-link{

    margin-top:22px;

    display:inline-flex;

    align-items:center;

    gap:10px;

    text-transform:uppercase;

    letter-spacing:2px;

    font-size:11px;

    font-weight:600;

    color:var(--accent);

    opacity:0;

    transform:translateY(20px);

    transition:

        .45s ease;

}

.service-card:hover .service-link{

    opacity:1;

    transform:none;

}


.service-link .arrow {
    display: inline-block;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
}

.service-card:hover .service-link .arrow {
    transform: translateX(6px);
}

/* --- Responsive Layout Adjustments --- */
@media(max-width: 991px) {
    .services-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
    }
}

@media(max-width: 768px) {
    .services-grid {
        grid-template-columns: 1fr;
    }
    .services-heading {
        margin-bottom: 45px;
    }
    .service-card {
        min-height: 380px;
    }
    .service-content {
        padding: 35px;
        transform: none !important; /* Retain standard static layout on touch screens */
    }
    .service-desc {
        opacity: 0.85;
        max-height: none;
        margin-bottom: 30px;
    }
}
</style>

<script is:inline>

const services = document.querySelector(".services");

const observer = new IntersectionObserver((entries)=>{

    if(entries[0].isIntersecting){

        services.classList.add("visible");

        observer.disconnect();

    }

},{threshold:.25});

observer.observe(services);

</script>