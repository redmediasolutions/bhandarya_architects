---
const timeline = [
  {
    year: "1995",
    title: "The Beginning",
    description:
      "Bhandary Architects was founded with a vision to create thoughtful architecture rooted in functionality, craftsmanship and timeless design.",
  },
  {
    year: "2005",
    title: "Growing Beyond Homes",
    description:
      "Expanded into commercial and institutional projects, delivering spaces that balanced aesthetics with practical efficiency.",
  },
  {
    year: "2015",
    title: "Design Recognition",
    description:
      "Received recognition for innovative and sustainable architectural solutions across residential and mixed-use developments.",
  },
  {
    year: "2025",
    title: "Building the Future",
    description:
      "Continuing to shape modern living through architecture, interiors and planning while embracing sustainable design principles.",
  },
];
---

<section class="timeline section reveal-timeline">

    <div class="container">

        <div class="timeline-header">

            <span class="small-title">
                Our Journey
            </span>

            <h2>
                Building a Legacy
            </h2>

            <p>
                Every milestone represents our commitment to creating meaningful
                spaces that inspire communities and stand the test of time.
            </p>

        </div>

        <div class="timeline-grid">

            {
  timeline.map((item, index) => (

    <article
      class="timeline-item"
      style={`--delay:${index * 180}ms`}
    >

      <div class="timeline-dot"></div>

      <div class="timeline-year">
        {item.year}
      </div>

      <h3>{item.title}</h3>

      <p>{item.description}</p>

    </article>

  ))
}

        </div>

    </div>

</section>

<script>

const timelineSection = document.querySelector(".reveal-timeline");

if(timelineSection){

    const observer = new IntersectionObserver((entries)=>{

        entries.forEach(entry=>{

            if(entry.isIntersecting){

                entry.target.classList.add("visible");

                observer.disconnect();

            }

        });

    },{

        threshold:.25

    });

    observer.observe(timelineSection);

}

</script>

<style>

.timeline{
    background:var(--black);
    color:white;
}

.timeline h2{
    color:white;
    margin:20px 0;
}

.timeline-header{
    max-width:700px;
    margin-bottom:80px;
}

.timeline-header p{
    color:rgba(255,255,255,.65);
}

.timeline-grid{

    display:grid;

    grid-template-columns:repeat(4,1fr);

    gap:40px;

    position:relative;

}

.timeline-grid::before{

    content:"";

    position:absolute;

    left:0;

    right:0;

    top:8px;

    height:1px;

    background:rgba(255,255,255,.15);

}

.timeline-item{
    position:relative;
}

.timeline-dot{

    width:16px;

    height:16px;

    border-radius:50%;

    background:var(--accent);

    position:relative;

    z-index:2;

    margin-bottom:30px;

}

.timeline-year{

    font-size:52px;

    font-weight:300;

    color:rgba(255,255,255,.18);

    margin-bottom:18px;

}

.timeline-item h3{

    color:white;

    margin-bottom:18px;

}

.timeline-item p{

    color:rgba(255,255,255,.65);

}

@media(max-width:991px){

    .timeline-grid{

        grid-template-columns:repeat(2,1fr);

    }

    .timeline-grid::before{

        display:none;

    }

}

@media(max-width:768px){

    .timeline-grid{

        grid-template-columns:1fr;

        gap:50px;

    }

    .timeline-header{

        margin-bottom:50px;

    }

}

/* ================================================= */
/* Premium Timeline Animation */
/* ================================================= */

.timeline-grid::before{

    transform:scaleX(0);

    transform-origin:left;

    transition:transform 1.3s cubic-bezier(.22,1,.36,1);

}

/* ----------------------------- */

.timeline-item{

    opacity:0;

    transform:translateY(60px);

    transition:

        opacity .9s cubic-bezier(.22,1,.36,1),

        transform .9s cubic-bezier(.22,1,.36,1);

    transition-delay:var(--delay);

}

/* ----------------------------- */

.timeline-dot{

    transform:scale(0);

    transition:

        transform .5s cubic-bezier(.34,1.6,.64,1);

    transition-delay:calc(var(--delay) + 250ms);

}

/* ----------------------------- */

.timeline-year{

    opacity:0;

    transform:translateY(20px);

    transition:

        opacity .8s ease,

        transform .8s ease;

    transition-delay:calc(var(--delay) + 350ms);

}

/* ----------------------------- */

.reveal-timeline.visible .timeline-grid::before{

    transform:scaleX(1);

}

.reveal-timeline.visible .timeline-item{

    opacity:1;

    transform:none;

}

.reveal-timeline.visible .timeline-dot{

    transform:scale(1);

}

.reveal-timeline.visible .timeline-year{

    opacity:1;

    transform:none;

}

</style>