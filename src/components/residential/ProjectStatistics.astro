<section class="project-statistics">

    <div class="stats-overlay"></div>

    <div class="container">

        <div class="stats-heading">

            <span class="small-title">

                By The Numbers

            </span>

            <h2>

                Designing Homes
                That Last Generations

            </h2>

            <p>

                Every project represents years of collaboration,
                craftsmanship and thoughtful design.

            </p>

        </div>

        <div class="stats-grid">

            <div class="stat-card">

                <div class="number counter"
                    data-target="25">

                    0

                </div>

                <span>

                    Years Experience

                </span>

            </div>

            <div class="stat-card">

                <div class="number counter"
                    data-target="120">

                    0

                </div>

                <span>

                    Residential Projects

                </span>

            </div>

            <div class="stat-card">

                <div class="number counter"
                    data-target="3500000">

                    0

                </div>

                <span>

                    Sq.ft Designed

                </span>

            </div>

            <div class="stat-card">

                <div class="number counter"
                    data-target="98">

                    0

                </div>

                <span>

                    Client Satisfaction

                </span>

            </div>

        </div>

    </div>

</section>

<style>

.project-statistics{

    position:relative;

    overflow:hidden;

    padding:140px 0;

    background:#111;

}

.stats-overlay{

    position:absolute;

    inset:0;

    background:

        radial-gradient(

            circle at top right,

            rgba(255,120,0,.12),

            transparent 45%

        );

}

.stats-overlay::before{

    content:"";

    position:absolute;

    inset:0;

    background-image:

        linear-gradient(rgba(255,255,255,.05) 1px,transparent 1px),

        linear-gradient(90deg,rgba(255,255,255,.05) 1px,transparent 1px);

    background-size:70px 70px;

    animation:gridMove 20s linear infinite;

    opacity:.25;

}

.stats-heading{

    position:relative;

    z-index:2;

    max-width:760px;

    margin:0 auto 80px;

    text-align:center;

}

.stats-heading h2{

    color:white;

    margin:18px 0 24px;

}

.stats-heading p{

    color:rgba(255,255,255,.72);

}

.stats-grid{

    position:relative;

    z-index:2;

    display:grid;

    grid-template-columns:repeat(4,1fr);

    gap:30px;

}

.stat-card{

    text-align:center;

    padding:55px 35px;

    border:1px solid rgba(255,255,255,.08);

    background:rgba(255,255,255,.03);

    backdrop-filter:blur(10px);

    transition:.45s;

}

.stat-card:hover{

    transform:translateY(-8px);

    border-color:rgba(255,120,0,.45);

}

.number{

    font-size:64px;

    color:var(--accent);

    font-weight:700;

    line-height:1;

    margin-bottom:15px;

}

.stat-card span{

    color:rgba(255,255,255,.7);

    text-transform:uppercase;

    letter-spacing:2px;

    font-size:12px;

}

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:70px 70px;

    }

}

@media(max-width:991px){

    .stats-grid{

        grid-template-columns:repeat(2,1fr);

    }

}

@media(max-width:768px){

    .stats-grid{

        grid-template-columns:1fr;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const section=document.querySelector(".project-statistics");

    if(!section) return;

    const counters=section.querySelectorAll(".counter");

    const observer=new IntersectionObserver(entries=>{

        if(!entries[0].isIntersecting) return;

        counters.forEach(counter=>{

            const target=parseInt(counter.dataset.target);

            const duration=2200;

            const start=performance.now();

            function animate(now){

                const progress=Math.min((now-start)/duration,1);

                const eased=1-Math.pow(1-progress,3);

                let value=Math.floor(target*eased);

                if(target>100000){

                    counter.textContent=(value/1000000).toFixed(1)+"M+";

                }else if(target>99){

                    counter.textContent=value+"+";

                }else{

                    counter.textContent=value+"%";

                }

                if(progress<1){

                    requestAnimationFrame(animate);

                }

            }

            requestAnimationFrame(animate);

        });

        observer.disconnect();

    },{

        threshold:.35

    });

    observer.observe(section);

});

</script>