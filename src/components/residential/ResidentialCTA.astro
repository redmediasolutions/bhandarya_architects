---
const background = "/uploads/2026/05/0.webp";
---

<section
    class="residential-cta"
    style={`background-image:url('${background}')`}
>

    <div class="overlay"></div>

    <div class="grid"></div>

    <div class="container">

        <div class="cta-content">

            <span class="small-title">

                Let's Build Something Extraordinary

            </span>

            <h2>

                Your Dream Home
                <br />
                Begins With A
                <span>Conversation.</span>

            </h2>

            <p>

                Every remarkable residence begins with understanding your
                lifestyle, aspirations and vision. Let's create a home that
                reflects who you are and stands the test of time.

            </p>

            <div class="cta-buttons">

                <a
                    href="/contact"
                    class="btn"
                >
                    Start Your Project
                </a>

                <a
                    href="/projects"
                    class="btn-outline"
                >
                    View Portfolio
                </a>

            </div>

        </div>

    </div>

</section>

<style>

.residential-cta{

    position:relative;

    overflow:hidden;

    padding:180px 0;

    background-size:cover;

    background-position:center;

    background-attachment:fixed;

}

/* -------------------------------- */

.overlay{

    position:absolute;

    inset:0;

    background:

        linear-gradient(
            180deg,
            rgba(5,5,5,.55),
            rgba(5,5,5,.82)
        );

}

/* -------------------------------- */

.grid{

    position:absolute;

    inset:0;

    background-image:

        linear-gradient(rgba(255,255,255,.04) 1px,transparent 1px),

        linear-gradient(90deg,rgba(255,255,255,.04) 1px,transparent 1px);

    background-size:70px 70px;

    opacity:.3;

    animation:gridMove 18s linear infinite;

}

/* -------------------------------- */

.container{

    position:relative;

    z-index:5;

}

.cta-content{

    max-width:760px;

}

.cta-content h2{

    color:white;

    font-size:clamp(46px,6vw,84px);

    line-height:.95;

    margin:20px 0 28px;

}

.cta-content h2 span{

    color:var(--accent);

}

.cta-content p{

    max-width:620px;

    color:rgba(255,255,255,.78);

    font-size:18px;

    line-height:1.9;

}

/* -------------------------------- */

.cta-buttons{

    display:flex;

    gap:20px;

    margin-top:50px;

    flex-wrap:wrap;

}

/* -------------------------------- */

.btn-outline{

    display:inline-flex;

    align-items:center;

    justify-content:center;

    padding:16px 34px;

    border:1px solid rgba(255,255,255,.22);

    color:white;

    text-decoration:none;

    letter-spacing:1px;

    transition:.45s;

    backdrop-filter:blur(14px);

}

.btn-outline:hover{

    background:white;

    color:#111;

}

/* -------------------------------- */

.residential-cta::before{

    content:"";

    position:absolute;

    width:700px;

    height:700px;

    right:-180px;

    top:-220px;

    border-radius:50%;

    background:

        radial-gradient(

            rgba(255,120,0,.18),

            transparent 70%

        );

    filter:blur(80px);

    animation:floatGlow 8s ease-in-out infinite alternate;

}

/* -------------------------------- */

@keyframes floatGlow{

    from{

        transform:translateY(0);

    }

    to{

        transform:translateY(40px);

    }

}

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:70px 70px;

    }

}

/* -------------------------------- */

@media(max-width:768px){

    .residential-cta{

        padding:120px 0;

        background-attachment:scroll;

    }

    .cta-content h2{

        font-size:42px;

    }

    .cta-buttons{

        flex-direction:column;

    }

    .btn,

    .btn-outline{

        width:100%;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const section=document.querySelector(".residential-cta");

    if(!section) return;

    const observer=new IntersectionObserver(entries=>{

        if(entries[0].isIntersecting){

            section.animate([

                {

                    opacity:0,

                    transform:"translateY(60px)"

                },

                {

                    opacity:1,

                    transform:"translateY(0)"

                }

            ],{

                duration:1000,

                easing:"cubic-bezier(.22,1,.36,1)",

                fill:"forwards"

            });

            observer.disconnect();

        }

    },{

        threshold:.25

    });

    observer.observe(section);

});

</script>