---
import { img } from "../../consts";

const project = {
    title: "Samudra",
    category: "Luxury Residence",
    location: "Yermal, Karnataka",
    year: "2025",
    area: "6,400 sq.ft",
    image: img("2026/05/Copy-of-01.webp"),
    href: "/projects/samudra",
};
---

<section class="featured-residence section" id="featured">

    <div class="container">

        <div class="section-heading">

            <span class="small-title">

                Signature Residence

            </span>

            <h2>

                Featured Project

            </h2>

        </div>

        <div class="featured-grid">

            <!-- Image -->

            <a
                href={project.href}
                class="featured-image"
            >

                <img
                    src={project.image}
                    alt={project.title}
                />

                <div class="image-overlay"></div>

                <div class="image-label">

                    Featured Residence

                </div>

            </a>

            <!-- Content -->

            <div class="featured-content">

                <span class="project-category">

                    {project.category}

                </span>

                <h3>

                    {project.title}

                </h3>

                <div class="accent-line"></div>

                <p>

                    Samudra was envisioned as a tranquil coastal retreat
                    where timeless architecture meets contemporary
                    living. Inspired by colonial design principles,
                    generous verandahs, courtyards and natural materials
                    create a home deeply connected to its landscape.

                </p>

                <div class="project-meta">

                    <div>

                        <small>

                            Location

                        </small>

                        <strong>

                            {project.location}

                        </strong>

                    </div>

                    <div>

                        <small>

                            Built Area

                        </small>

                        <strong>

                            {project.area}

                        </strong>

                    </div>

                    <div>

                        <small>

                            Completed

                        </small>

                        <strong>

                            {project.year}

                        </strong>

                    </div>

                </div>

                <a
                    href={project.href}
                    class="btn"
                >

                    Explore Project

                </a>

            </div>

        </div>

    </div>

</section>

<style>

.featured-residence{

    position:relative;

    overflow:hidden;

    background:#0c0c0c;

    padding:140px 0;

}

/* ========================================= */
/* Background */
/* ========================================= */

.featured-residence::before{

    content:"";

    position:absolute;

    inset:0;

    background-image:

        linear-gradient(rgba(255,255,255,.025) 1px,transparent 1px),

        linear-gradient(90deg,rgba(255,255,255,.025) 1px,transparent 1px);

    background-size:70px 70px;

    opacity:.3;

    animation:gridMove 18s linear infinite;

}

.featured-residence::after{

    content:"";

    position:absolute;

    width:900px;

    height:900px;

    right:-180px;

    top:-220px;

    border-radius:50%;

    background:

        radial-gradient(

            rgba(255,120,0,.18),

            transparent 70%

        );

    filter:blur(130px);

    pointer-events:none;

}

.container{

    position:relative;

    z-index:2;

}

/* ========================================= */

.section-heading{

    text-align:center;

    margin-bottom:80px;

}

.section-heading .small-title{

    color:var(--accent);

}

.section-heading h2{

    color:#fff;

    margin-top:18px;

}

/* ========================================= */

.featured-grid{

    display:grid;

    grid-template-columns:1.3fr .9fr;

    gap:90px;

    align-items:center;

}

/* ========================================= */
/* Image */
/* ========================================= */

.featured-image{

    position:relative;

    display:block;

    overflow:hidden;

    border-radius:22px;

    isolation:isolate;

    box-shadow:

        0 45px 100px rgba(0,0,0,.45);

}

.featured-image img{

    width:100%;

    display:block;

    transform:scale(1.08);

    transition:

        transform 2.2s cubic-bezier(.22,1,.36,1),

        filter .6s;

}

.featured-image:hover img{

    transform:scale(1.14);

}

.featured-image::before{

    content:"";

    position:absolute;

    inset:-40px;

    background:

        radial-gradient(

            circle,

            rgba(255,120,0,.22),

            transparent 72%

        );

    z-index:-1;

    opacity:0;

    transition:.55s;

}

.featured-image:hover::before{

    opacity:1;

}

.image-overlay{

    position:absolute;

    inset:0;

    background:

        linear-gradient(

            transparent 20%,

            rgba(0,0,0,.72)

        );

}

.image-label{

    position:absolute;

    top:28px;

    left:28px;

    background:#fff;

    color:#111;

    padding:12px 22px;

    border-left:4px solid var(--accent);

    font-size:11px;

    text-transform:uppercase;

    letter-spacing:2px;

    font-weight:600;

}

.featured-image::after{

    content:"";

    position:absolute;

    inset:18px;

    border:1px solid rgba(255,255,255,.22);

    opacity:0;

    transform:scale(.96);

    transition:.55s;

}

.featured-image:hover::after{

    opacity:1;

    transform:scale(1);

}

/* ========================================= */
/* Content */
/* ========================================= */

.project-category{

    color:var(--accent);

    text-transform:uppercase;

    letter-spacing:3px;

    font-size:12px;

    font-weight:600;

}

.featured-content h3{

    color:#fff;

    margin:18px 0;

    font-size:clamp(42px,5vw,68px);

    line-height:1;

}

.accent-line{

    width:90px;

    height:2px;

    background:var(--accent);

    margin-bottom:34px;

}

.featured-content p{

    color:rgba(255,255,255,.72);

    line-height:1.9;

    margin-bottom:46px;

}

/* ========================================= */
/* Meta */
/* ========================================= */

.project-meta{

    display:grid;

    grid-template-columns:repeat(3,1fr);

    gap:28px;

    padding:34px 0;

    margin-bottom:40px;

    border-top:1px solid rgba(255,255,255,.08);

    border-bottom:1px solid rgba(255,255,255,.08);

}

.project-meta small{

    display:block;

    color:rgba(255,255,255,.45);

    margin-bottom:10px;

    text-transform:uppercase;

    letter-spacing:2px;

    font-size:11px;

}

.project-meta strong{

    color:#fff;

    font-size:18px;

    font-weight:600;

}

/* ========================================= */
/* Reveal */
/* ========================================= */

.featured-image{

    opacity:0;

    transform:translateX(-60px);

    transition:

        opacity .9s,

        transform .9s;

}

.featured-content{

    opacity:0;

    transform:translateX(60px);

    transition:

        opacity .9s,

        transform .9s;

}

.featured-residence.visible .featured-image,

.featured-residence.visible .featured-content{

    opacity:1;

    transform:none;

}

.featured-residence.visible .featured-content{

    transition-delay:.2s;

}

/* ========================================= */

@keyframes gridMove{

    from{

        background-position:0 0;

    }

    to{

        background-position:70px 70px;

    }

}

/* ========================================= */

@media(max-width:991px){

    .featured-grid{

        grid-template-columns:1fr;

        gap:60px;

    }

}

@media(max-width:768px){

    .project-meta{

        grid-template-columns:1fr;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const section=document.querySelector(".featured-residence");

    if(!section) return;

    const observer=new IntersectionObserver(entries=>{

        if(entries[0].isIntersecting){

            section.classList.add("visible");

            observer.disconnect();

        }

    },{

        threshold:.25

    });

    observer.observe(section);

});

</script>