---
const testimonials = [
  {
    quote:
      "Bhandary Architects transformed our vision into a home that perfectly reflects our lifestyle. Every space feels intentional, timeless and beautifully connected to nature.",
    name: "Mr. & Mrs. D'Souza",
    project: "Samudra Residence",
  },
  {
    quote:
      "Their attention to detail and ability to understand our family's needs made the entire journey effortless. The result exceeded every expectation.",
    name: "Mr. Fernandes",
    project: "Kutira",
  },
  {
    quote:
      "The design balances elegance with functionality. Even years later, the house continues to feel modern, comfortable and inspiring.",
    name: "Mrs. Rodrigues",
    project: "Private Residence",
  },
];
---

<section class="testimonials section">

    <div class="container">

        <div class="section-heading center">

            <span class="small-title">

                Client Stories

            </span>

            <h2>

                Homes Built On
                Trust & Relationships

            </h2>

        </div>

        <div class="testimonial-slider">

            {
                testimonials.map((item,index)=>(

                    <article
                        class={`testimonial ${index===0 ? "active" : ""}`}
                    >

                        <div class="quote-mark">

                            “

                        </div>

                        <blockquote>

                            {item.quote}

                        </blockquote>

                        <div class="author">

                            <strong>

                                {item.name}

                            </strong>

                            <span>

                                {item.project}

                            </span>

                        </div>

                    </article>

                ))
            }

        </div>

        <div class="testimonial-nav">

            {
                testimonials.map((_,index)=>(

                    <button
                        class={`dot ${index===0 ? "active" : ""}`}
                        data-index={index}
                    ></button>

                ))
            }

        </div>

    </div>

</section>

<style>

.testimonials{

    background:#fafafa;

    overflow:hidden;

}

.section-heading.center{

    text-align:center;

    margin-bottom:70px;

}

/* ---------------- */

.testimonial-slider{

    position:relative;

    max-width:900px;

    margin:auto;

    min-height:340px;

}

.testimonial{

    position:absolute;

    inset:0;

    text-align:center;

    opacity:0;

    transform:translateY(30px);

    pointer-events:none;

    transition:

        opacity .7s,

        transform .7s;

}

.testimonial.active{

    opacity:1;

    transform:none;

    pointer-events:auto;

}

.quote-mark{

    font-size:130px;

    color:var(--accent);

    opacity:.18;

    line-height:.6;

    font-family:serif;

}

blockquote{

    margin:20px auto 50px;

    max-width:760px;

    font-size:30px;

    line-height:1.7;

    font-weight:300;

    color:#222;

}

.author strong{

    display:block;

    font-size:20px;

    margin-bottom:8px;

}

.author span{

    color:#888;

    text-transform:uppercase;

    letter-spacing:2px;

    font-size:12px;

}

/* ---------------- */

.testimonial-nav{

    margin-top:40px;

    display:flex;

    justify-content:center;

    gap:14px;

}

.dot{

    width:12px;

    height:12px;

    border-radius:50%;

    border:none;

    cursor:pointer;

    background:#d7d7d7;

    transition:.35s;

}

.dot.active{

    width:40px;

    border-radius:20px;

    background:var(--accent);

}

/* ---------------- */

@media(max-width:768px){

    .testimonial-slider{

        min-height:420px;

    }

    blockquote{

        font-size:22px;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const testimonials=[

        ...document.querySelectorAll(".testimonial")

    ];

    const dots=[

        ...document.querySelectorAll(".dot")

    ];

    let current=0;

    function show(index){

        testimonials.forEach((item,i)=>{

            item.classList.toggle("active",i===index);

        });

        dots.forEach((dot,i)=>{

            dot.classList.toggle("active",i===index);

        });

        current=index;

    }

    dots.forEach((dot,index)=>{

        dot.addEventListener("click",()=>{

            show(index);

        });

    });

    setInterval(()=>{

        show((current+1)%testimonials.length);

    },6500);

});

</script>