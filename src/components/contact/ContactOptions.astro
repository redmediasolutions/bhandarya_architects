<section class="contact-options section">

    <div class="container">

        <div class="section-heading">

            <span class="small-title">

                Get In Touch

            </span>

            <h2>

                Choose How You'd Like
                <br>
                To Connect With Us

            </h2>

            <p>

                Whether you prefer a quick WhatsApp conversation or a
                detailed project enquiry, we're here to help bring your
                vision to life.

            </p>

        </div>

        <div class="options-grid">

            <!-- WhatsApp -->

            <a

                href="https://wa.me/919999999999"

                target="_blank"

                class="option-card whatsapp"

            >

                <div class="card-glow"></div>

                <div class="icon">

                    💬

                </div>

                <span class="label">

                    Instant Conversation

                </span>

                <h3>

                    Chat on
                    <br>
                    WhatsApp

                </h3>

                <p>

                    Need a quick discussion about your project?
                    Connect directly with our team for immediate
                    assistance.

                </p>

                <div class="card-footer">

                    <span>

                        Start Chat

                    </span>

                    <span class="arrow">

                        →

                    </span>

                </div>

            </a>

            <!-- Contact Form -->

            <a

                href="#contact-form"

                class="option-card"

            >

                <div class="card-glow"></div>

                <div class="icon">

                    ✉️

                </div>

                <span class="label">

                    Detailed Enquiry

                </span>

                <h3>

                    Start Your
                    <br>
                    Project

                </h3>

                <p>

                    Tell us about your project, location, budget and
                    expectations. We'll prepare a personalised response.

                </p>

                <div class="card-footer">

                    <span>

                        Open Form

                    </span>

                    <span class="arrow">

                        →

                    </span>

                </div>

            </a>

        </div>

    </div>

</section>

<style>

.contact-options{

    background:#fafafa;

    position:relative;

    overflow:hidden;

}

.section-heading{

    text-align:center;

    max-width:760px;

    margin:0 auto 80px;

}

.section-heading h2{

    margin:18px 0;

}

.section-heading p{

    max-width:620px;

    margin:auto;

}

.options-grid{

    display:grid;

    grid-template-columns:repeat(2,1fr);

    gap:36px;

}

.option-card{

    position:relative;

    overflow:hidden;

    padding:60px;

    background:#fff;

    border-radius:22px;

    text-decoration:none;

    color:inherit;

    isolation:isolate;

    border:1px solid rgba(0,0,0,.06);

    transition:

        transform .7s cubic-bezier(.22,1,.36,1),

        box-shadow .6s,

        border-color .5s;

}

.option-card:hover{

    transform:

        translateY(-12px);

    border-color:rgba(255,120,0,.25);

    box-shadow:

        0 40px 90px rgba(0,0,0,.10);

}

.card-glow{

    position:absolute;

    width:380px;

    height:380px;

    right:-160px;

    top:-160px;

    border-radius:50%;

    background:

        radial-gradient(

            rgba(255,120,0,.12),

            transparent 70%

        );

    opacity:0;

    transition:.8s;

}

.option-card:hover .card-glow{

    opacity:1;

}

.option-card::after{

    content:"";

    position:absolute;

    inset:16px;

    border:1px solid rgba(255,120,0,.25);

    opacity:0;

    transform:scale(.96);

    transition:.6s;

}

.option-card:hover::after{

    opacity:1;

    transform:scale(1);

}

.icon{

    width:78px;

    height:78px;

    border-radius:18px;

    display:grid;

    place-items:center;

    font-size:34px;

    background:#111;

    color:#fff;

    margin-bottom:34px;

    transition:

        transform .6s,

        background .5s;

}

.option-card:hover .icon{

    transform:

        rotate(-8deg)

        scale(1.08);

    background:var(--accent);

}

.whatsapp .icon{

    background:#25D366;

}

.label{

    display:block;

    text-transform:uppercase;

    letter-spacing:2px;

    font-size:11px;

    color:var(--accent);

    margin-bottom:18px;

}

.option-card h3{

    margin:0 0 20px;

    font-size:42px;

    line-height:1.08;

}

.option-card p{

    color:#666;

    line-height:1.8;

    margin-bottom:60px;

}

.card-footer{

    display:flex;

    justify-content:space-between;

    align-items:center;

    font-size:13px;

    text-transform:uppercase;

    letter-spacing:2px;

    font-weight:600;

}

.arrow{

    font-size:26px;

    transition:.45s;

}

.option-card:hover .arrow{

    transform:translateX(10px);

}

@media(max-width:991px){

    .options-grid{

        grid-template-columns:1fr;

    }

}

@media(max-width:768px){

    .option-card{

        padding:40px 30px;

    }

    .option-card h3{

        font-size:34px;

    }

}

</style>

<script is:inline>

document.addEventListener("DOMContentLoaded",()=>{

    const section=document.querySelector(".contact-options");

    if(!section) return;

    const cards=section.querySelectorAll(".option-card");

    const observer=new IntersectionObserver(entries=>{

        if(entries[0].isIntersecting){

            cards.forEach((card,index)=>{

                card.animate(

                    [

                        {

                            opacity:0,

                            transform:"translateY(70px)"

                        },

                        {

                            opacity:1,

                            transform:"translateY(0)"

                        }

                    ],

                    {

                        duration:900,

                        delay:index*180,

                        easing:"cubic-bezier(.22,1,.36,1)",

                        fill:"forwards"

                    }

                );

            });

            observer.disconnect();

        }

    },{

        threshold:.25

    });

    observer.observe(section);

});

</script>