<section class="contact-form-section section" id="contact-form">

    <div class="container">

        <div class="form-grid">

            <div class="form-intro">

                <span class="small-title">
                    Project Enquiry
                </span>

                <h2>
                    Tell Us About
                    <br>
                    Your Vision.
                </h2>

                <p>

                    Share a few details about your project and our
                    architects will get back to you with the next
                    steps. Every enquiry is reviewed personally.

                </p>

                <div class="info-card">

                    <h4>

                        What happens next?

                    </h4>

                    <ul>

                        <li>✓ Initial project review</li>

                        <li>✓ Consultation scheduling</li>

                        <li>✓ Site discussion</li>

                        <li>✓ Design proposal</li>

                    </ul>

                </div>

            </div>

            <form class="contact-form">

                <div class="field">

                    <input
                        type="text"
                        required
                        placeholder=" "
                    />

                    <label>

                        Full Name

                    </label>

                </div>

                <div class="field">

                    <input
                        type="email"
                        required
                        placeholder=" "
                    />

                    <label>

                        Email Address

                    </label>

                </div>

                <div class="field">

                    <input
                        type="tel"
                        placeholder=" "
                    />

                    <label>

                        Phone Number

                    </label>

                </div>

                <div class="field">

                    <select required>

                        <option value=""></option>

                        <option>Residential</option>

                        <option>Commercial</option>

                        <option>Interior Design</option>

                        <option>Renovation</option>

                    </select>

                    <label>

                        Project Type

                    </label>

                </div>

                <div class="field full">

                    <input
                        type="text"
                        placeholder=" "
                    />

                    <label>

                        Project Location

                    </label>

                </div>

                <div class="field">

                    <select>

                        <option value=""></option>

                        <option>Below ₹50 Lakhs</option>

                        <option>₹50L – ₹1Cr</option>

                        <option>₹1Cr – ₹3Cr</option>

                        <option>Above ₹3Cr</option>

                    </select>

                    <label>

                        Estimated Budget

                    </label>

                </div>

                <div class="field">

                    <select>

                        <option value=""></option>

                        <option>Immediately</option>

                        <option>1–3 Months</option>

                        <option>3–6 Months</option>

                        <option>6+ Months</option>

                    </select>

                    <label>

                        Timeline

                    </label>

                </div>

                <div class="field full">

                    <textarea
                        rows="6"
                        placeholder=" "
                    ></textarea>

                    <label>

                        Tell us about your project

                    </label>

                </div>

                <button
                    type="submit"
                    class="btn"
                >

                    Send Enquiry

                </button>

            </form>

        </div>

    </div>

</section>

<style>

.contact-form-section{

    background:#fff;

}

.form-grid{

    display:grid;

    grid-template-columns:420px 1fr;

    gap:80px;

    align-items:start;

}

.form-intro{

    position:sticky;

    top:120px;

}

.form-intro h2{

    margin:20px 0;

}

.info-card{

    margin-top:45px;

    padding:35px;

    background:#111;

    color:white;

    border-radius:16px;

}

.info-card h4{

    margin-bottom:20px;

    color:white;

}

.info-card ul{

    list-style:none;

    margin:0;

    padding:0;

}

.info-card li{

    padding:12px 0;

    color:rgba(255,255,255,.75);

}

.contact-form{

    display:grid;

    grid-template-columns:repeat(2,1fr);

    gap:28px;

}

.field{

    position:relative;

}

.field.full{

    grid-column:1/-1;

}

.field input,

.field select,

.field textarea{

