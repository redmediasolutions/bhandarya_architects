---
interface GallerySection {
  label?: string;
  images: string[];
  layout?: 'grid' | 'carousel';
}

interface Props {
  category: string;
  title: string;
  hero: string;
  overview: string[];
  features: string[][];
  galleryTitle?: string;
  galleries: GallerySection[];
  slides?: string[];
  team: { name: string; role: string }[];
  details: { label: string; value: string }[];
}

const {
  category,
  title,
  hero,
  overview,
  features,
  galleryTitle = 'Project Gallery',
  galleries,
  slides = [],
  team,
  details,
} = Astro.props;

const slug = title.toLowerCase().replace(/\s+/g, '-');
---
<section class="pd-hero" style={`background-image:url('${hero}')`}>
  <div class="pd-hero-overlay"></div>
  <div class="container pd-hero-content">
    <span class="chip">{category}</span>
    <h1>{title}</h1>
  </div>
</section>

<section class="section">
  <div class="container pd-layout">
    <div class="pd-main">
      <h2 class="pd-title">Project Overview</h2>
      {overview.map((para) => <p class="pd-para" set:html={para} />)}

      <h3 class="pd-label">Key Features</h3>
      <div class="pd-features">
        {features.map((list) => (
          <ul>
            {list.map((f) => (
              <li>
                <span class="dot"></span>
                {f}
              </li>
            ))}
          </ul>
        ))}
      </div>

      <h3 class="pd-label">{galleryTitle}</h3>
      {galleries.map((g, gi) => (
        <div class="pd-gallery-block">
          {g.label && <h4 class="pd-gallery-label">{g.label}</h4>}
          {g.layout === 'carousel' ? (
            <div class="pd-carousel" data-carousel>
              {g.images.map((src, i) => (
                <div class={`pd-c-slide${i === 0 ? ' active' : ''}`} style={`background-image:url('${src}')`}></div>
              ))}
              <button class="pd-c-nav pd-c-prev" aria-label="Previous image">‹</button>
              <button class="pd-c-nav pd-c-next" aria-label="Next image">›</button>
              <div class="pd-c-dots">
                {g.images.map((_, i) => (
                  <button class={`pd-c-dot${i === 0 ? ' active' : ''}`} data-index={i} aria-label={`Go to image ${i + 1}`}></button>
                ))}
              </div>
            </div>
          ) : (
            <div class="pd-gallery">
              {g.images.map((src, i) => (
                <img
                  src={src}
                  alt={`${title} — ${g.label ?? 'gallery'} image ${i + 1}`}
                  loading="lazy"
                  data-lightbox={`${slug}-${gi}`}
                  data-full={src}
                />
              ))}
            </div>
          )}
        </div>
      ))}

      {slides.length > 0 && (
        <div class="pd-slider" data-autoplay>
          {slides.map((src, i) => (
            <div class={`pd-slide${i === 0 ? ' active' : ''}`} style={`background-image:url('${src}')`}></div>
          ))}
          <button class="pd-s-nav pd-s-prev" aria-label="Previous slide">‹</button>
          <button class="pd-s-nav pd-s-next" aria-label="Next slide">›</button>
        </div>
      )}

      <h3 class="pd-label">Project Team</h3>
      <div class="pd-team">
        {team.map((m) => (
          <div class="pd-member">
            <span class="pd-member-icon">
              <svg viewBox="0 0 576 512" width="17" height="17" fill="currentColor" aria-hidden="true">
                <path d="M259.3 17.8L194 150.2 47.9 171.5c-26.2 3.8-36.7 36.1-17.7 54.6l105.7 103-25 145.5c-4.5 26.3 23.2 46 46.4 33.7L288 439.6l130.7 68.7c23.2 12.2 50.9-7.4 46.4-33.7l-25-145.5 105.7-103c19-18.5 8.5-50.8-17.7-54.6L382 150.2 316.7 17.8c-11.7-23.6-45.6-23.9-57.4 0z"/>
              </svg>
            </span>
            <div>
              <h4>{m.name}</h4>
              <p>{m.role}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <aside class="pd-side">
      <div class="pd-details">
        <h3>Project Details</h3>
        {details.map((d) => (
          <div class="pd-detail-row">
            <h4>{d.label}</h4>
            <p>{d.value}</p>
          </div>
        ))}
      </div>
    </aside>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('.pd-slider[data-autoplay]').forEach((slider) => {
    const slides = slider.querySelectorAll<HTMLElement>('.pd-slide');
    if (slides.length < 2) return;
    let cur = 0;
    let timer: ReturnType<typeof setInterval>;
    const go = (i: number) => {
      slides[cur].classList.remove('active');
      cur = (i + slides.length) % slides.length;
      slides[cur].classList.add('active');
    };
    const start = () => (timer = setInterval(() => go(cur + 1), 4000));
    start();
    slider.addEventListener('mouseenter', () => clearInterval(timer));
    slider.addEventListener('mouseleave', start);
    slider.querySelector('.pd-s-prev')?.addEventListener('click', () => go(cur - 1));
    slider.querySelector('.pd-s-next')?.addEventListener('click', () => go(cur + 1));
  });

  document.querySelectorAll<HTMLElement>('.pd-carousel[data-carousel]').forEach((carousel) => {
    const slides = carousel.querySelectorAll<HTMLElement>('.pd-c-slide');
    const dots = carousel.querySelectorAll<HTMLElement>('.pd-c-dot');
    if (slides.length < 2) return;
    let cur = 0;
    const go = (i: number) => {
      slides[cur].classList.remove('active');
      dots[cur]?.classList.remove('active');
      cur = (i + slides.length) % slides.length;
      slides[cur].classList.add('active');
      dots[cur]?.classList.add('active');
    };
    carousel.querySelector('.pd-c-prev')?.addEventListener('click', () => go(cur - 1));
    carousel.querySelector('.pd-c-next')?.addEventListener('click', () => go(cur + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => go(i)));
  });
</script>

<style>
  .pd-hero {
    position: relative;
    min-height: 71vh;
    display: flex;
    align-items: flex-end;
    background-size: cover;
    background-position: center;
  }
  .pd-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,1) 100%);
  }
  .pd-hero-content { position: relative; z-index: 2; padding-bottom: 46px; color: #fff; }
  .pd-hero-content h1 {
    font-size: clamp(34px, 5vw, 52px);
    font-weight: 600;
    margin-top: 12px;
  }

  .pd-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 52px;
    align-items: start;
  }
  .pd-title { font-size: 20px; font-weight: 600; color: var(--black); margin-bottom: 16px; }
  .pd-para { font-size: 15px; color: var(--dark); margin-bottom: 14px; }
  .pd-label { font-size: 16px; font-weight: 600; color: var(--black); margin: 30px 0 14px; }

  .pd-features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px 40px;
  }
  .pd-features ul { list-style: none; }
  .pd-features li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 16px;
    font-weight: 500;
    color: var(--dark);
    padding: 7px 0;
  }
  .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  .pd-gallery-label { font-size: 15px; font-weight: 600; color: var(--gray-2); margin: 16px 0 12px; }
  .pd-gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .pd-gallery img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    border-radius: 5px;
    transition: transform 0.35s ease, box-shadow 0.35s ease;
  }
  .pd-gallery img:hover { transform: scale(1.02); box-shadow: 0 10px 24px rgba(0,0,0,0.16); }

  .pd-carousel {
    position: relative;
    height: 560px;
    border-radius: 8px;
    overflow: hidden;
  }
  .pd-c-slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  .pd-c-slide.active { opacity: 1; }
  .pd-c-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: none;
    background: rgba(0,0,0,0.5);
    color: #fff;
    font-size: 22px;
    cursor: pointer;
    transition: background 0.25s;
  }
  .pd-c-nav:hover { background: var(--accent); }
  .pd-c-prev { left: 14px; }
  .pd-c-next { right: 14px; }
  .pd-c-dots {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    gap: 8px;
  }
  .pd-c-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,0.6);
    cursor: pointer;
    padding: 0;
    transition: background 0.25s, transform 0.25s;
  }
  .pd-c-dot.active { background: #fff; transform: scale(1.2); }

  .pd-slider {
    position: relative;
    height: 400px;
    border-radius: 8px;
    overflow: hidden;
    margin-top: 28px;
  }
  .pd-slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  .pd-slide.active { opacity: 1; }
  .pd-s-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: none;
    background: rgba(0,0,0,0.5);
    color: #fff;
    font-size: 22px;
    cursor: pointer;
    transition: background 0.25s;
  }
  .pd-s-nav:hover { background: var(--accent); }
  .pd-s-prev { left: 14px; }
  .pd-s-next { right: 14px; }

  .pd-team { display: flex; flex-direction: column; gap: 16px; }
  .pd-member { display: flex; align-items: center; gap: 15px; }
  .pd-member-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--gray);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .pd-member h4 { font-size: 16px; font-weight: 600; color: var(--black); }
  .pd-member p { font-size: 14px; color: var(--gray); }

  .pd-details {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 28px;
    position: sticky;
    top: 90px;
  }
  .pd-details h3 { font-size: 17px; font-weight: 600; color: var(--black); margin-bottom: 16px; }
  .pd-detail-row { padding: 10px 0; border-bottom: 1px solid var(--border); }
  .pd-detail-row:last-child { border-bottom: none; }
  .pd-detail-row h4 {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 14px;
    font-weight: 600;
    color: var(--gray-2);
  }
  .pd-detail-row h4::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
  }
  .pd-detail-row p { font-size: 16px; font-weight: 600; color: var(--ink); margin-top: 2px; padding-left: 17px; }

  @media (max-width: 1024px) {
    .pd-layout { grid-template-columns: 1fr; }
    .pd-details { position: static; }
  }
  @media (max-width: 640px) {
    .pd-gallery { grid-template-columns: 1fr; }
    .pd-features { grid-template-columns: 1fr; }
    .pd-gallery img { height: auto; }
    .pd-carousel { height: 320px; }
  }
</style>
