---
import Base from '../layouts/Base.astro';
import { img, STATS, CONTACT } from '../consts';

const heroSlides = ['2026/05/1.webp', '2026/05/2.webp', '2026/05/3.webp'].map(img);

const philosophy = [
  {
    title: 'Vision-Driven Design',
    text: 'We believe every project begins with a vision. Our role is to transform that vision into architectural reality that exceeds expectations.',
  },
  {
    title: 'Innovation & Tradition',
    text: 'Blending cutting-edge design techniques with timeless architectural principles to create spaces that are both contemporary and enduring.',
  },
  {
    title: 'Sustainable Future',
    text: 'Architecture that respects the environment and embraces sustainable practices, ensuring our designs benefit both people and planet.',
  },
  {
    title: 'Human-Centric Spaces',
    text: 'Every design decision is made with the end user in mind, creating spaces that enhance daily life and foster meaningful connections.',
  },
];

const featured = [
  {
    category: 'RESIDENTIAL',
    title: 'Samudra',
    year: '2024',
    image: img('2026/05/Copy-of-02.webp'),
    href: '/samudra',
  },
  {
    category: 'RESIDENTIAL',
    title: 'Kutira',
    year: '2025',
    image: img('2026/05/Copy-of-04.png'),
    href: '/kuitra',
  },
  {
    category: 'COMMERCIAL',
    title: 'Contemporary Office Complex',
    year: '2023',
    image: img('2026/05/Container-2.jpg'),
    href: null,
  },
];

const journey = ['2026/05/4.webp', '2026/05/5.webp', '2026/05/7.webp', '2026/05/8.webp', '2026/05/9.webp', '2026/05/10.webp', '2026/05/11.webp'].map(img);

const services = [
  {
    title: 'Commercial Architecture',
    text: 'Innovative designs for corporate spaces that inspire productivity and reflect your brand identity.',
  },
  {
    title: 'Residential Design',
    text: 'Creating dream homes that blend functionality with aesthetic elegance for modern living.',
  },
  {
    title: 'Interior Design',
    text: 'Transforming interiors into masterpieces with attention to detail and timeless style.',
  },
];
---
<Base>
  <!-- Hero -->
  <section class="hero">
    {heroSlides.map((src, i) => (
      <div class={`hero-slide${i === 0 ? ' active' : ''}`} style={`background-image:url('${src}')`}></div>
    ))}
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <h1>Bhandary Architects</h1>
      <p class="tagline">Curating timeless spaces that endure</p>
      <p class="estd">Estd. 1995</p>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats">
    <div class="container stats-grid">
      {STATS.map((s) => (
        <div class="stat reveal">
          <span class="stat-value" data-count={s.value}>0</span><span class="stat-suffix">{s.suffix}</span>
          <p class="stat-label">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Philosophy -->
  <section class="section philosophy">
    <div class="container">
      <h2 class="section-title">Our Philosophy</h2>
      <p class="section-sub">
        We believe great design begins with understanding you. For over 30 years, we've been shaping
        spaces that reflect individual lifestyles, creating experiences that are both meaningful and lasting.
      </p>
      <div class="philosophy-grid">
        {philosophy.map((p) => (
          <article class="phil-card reveal">
            <h3>{p.title}</h3>
            <p>{p.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Quote -->
  <section class="quote">
    <div class="container">
      <blockquote>
        <p><em>Good design shapes spaces. Great design creates belonging.</em></p>
        <cite>- BHANDARY ASSOCIATES</cite>
      </blockquote>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="section featured">
    <div class="container">
      <h2 class="section-title">Featured Projects</h2>
      <p class="section-sub">A showcase of our most distinguished work over three decades</p>
      <div class="featured-grid">
        {featured.map((f) => {
          const Card = f.href ? 'a' : 'div';
          return (
            <Card href={f.href ?? undefined} class="feat-card reveal">
              <div class="feat-img" style={`background-image:url('${f.image}')`}></div>
              <div class="feat-overlay">
                <span class="chip">{f.category}</span>
                <h3>{f.title}</h3>
                <p class="feat-year">{f.year}</p>
              </div>
            </Card>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Journey -->
  <section class="section journey">
    <div class="container">
      <h2 class="section-title">Our Journey</h2>
      <p class="section-sub">Three decades of milestones that shaped our legacy</p>
    </div>
    <div class="journey-slider" id="journey">
      <button class="j-nav j-prev" aria-label="Previous">‹</button>
      <div class="j-track">
        {journey.map((src, i) => (
          <img src={src} alt={`Milestone ${i + 1}`} loading="lazy" data-lightbox="journey" data-full={src} />
        ))}
      </div>
      <button class="j-nav j-next" aria-label="Next">›</button>
    </div>
  </section>

  <!-- Services -->
  <section class="section services">
    <div class="container">
      <h2 class="section-title">Our Services</h2>
      <p class="section-sub">Three decades of expertise across diverse architectural disciplines</p>
      <div class="services-grid">
        {services.map((s) => (
          <article class="service-card reveal">
            <span class="service-bar"></span>
            <h3>{s.title}</h3>
            <p>{s.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="section contact" id="contact">
    <div class="container">
      <h2 class="section-title contact-title">Get in touch</h2>
      <p class="section-sub contact-sub">Let's discuss how we can bring your architectural vision to life</p>
      <div class="contact-grid">
        <div class="contact-item reveal">
          <h3>PHONE</h3>
          <p><a href={`tel:${CONTACT.phone.replace(/\s/g, '')}`}>{CONTACT.phone}</a></p>
        </div>
        <div class="contact-item reveal">
          <h3>EMAIL</h3>
          <p><a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a></p>
        </div>
        <div class="contact-item reveal">
          <h3>LOCATION</h3>
          <p>{CONTACT.location}</p>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Hero slideshow
    const slides = document.querySelectorAll<HTMLElement>('.hero-slide');
    let cur = 0;
    if (slides.length > 1) {
      setInterval(() => {
        slides[cur].classList.remove('active');
        cur = (cur + 1) % slides.length;
        slides[cur].classList.add('active');
      }, 5000);
    }

    // Animated counters
    const counters = document.querySelectorAll<HTMLElement>('.stat-value');
    const cio = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        cio.unobserve(el);
        const target = Number(el.dataset.count || 0);
        const dur = 1600;
        const t0 = performance.now();
        const tick = (t: number) => {
          const p = Math.min((t - t0) / dur, 1);
          el.textContent = String(Math.round(target * (1 - Math.pow(1 - p, 3))));
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      });
    }, { threshold: 0.4 });
    counters.forEach((c) => cio.observe(c));

    // Journey slider
    const track = document.querySelector<HTMLElement>('.j-track');
    const step = () => (track?.querySelector('img')?.clientWidth ?? 300) + 16;
    document.querySelector('.j-prev')?.addEventListener('click', () => track?.scrollBy({ left: -step(), behavior: 'smooth' }));
    document.querySelector('.j-next')?.addEventListener('click', () => track?.scrollBy({ left: step(), behavior: 'smooth' }));
  </script>

  <style>
    /* Hero */
    .hero {
      position: relative;
      min-height: 92vh;
      display: flex;
      align-items: flex-end;
      overflow: hidden;
    }
    .hero-slide {
      position: absolute;
      inset: 0;
      background-size: cover;
      background-position: center;
      opacity: 0;
      transition: opacity 1.2s ease;
      transform: scale(1.02);
    }
    .hero-slide.active { opacity: 1; }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(0, 0, 0, 0.25) 0%, rgba(0, 0, 0, 0.85) 100%);
    }
    .hero-content {
      position: relative;
      z-index: 2;
      padding-bottom: 90px;
      color: #fff;
    }
    .hero h1 {
      font-size: clamp(38px, 6vw, 64px);
      font-weight: 600;
      line-height: 1.1;
    }
    .tagline {
      font-size: clamp(16px, 2.2vw, 22px);
      font-weight: 400;
      margin-top: 10px;
      color: #eee;
    }
    .estd {
      margin-top: 16px;
      color: var(--accent);
      font-weight: 600;
      letter-spacing: 2px;
    }

    /* Stats */
    .stats { background: var(--black); padding: 55px 0; }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;
      text-align: center;
    }
    .stat-value, .stat-suffix {
      font-size: 52px;
      font-weight: 700;
      color: var(--accent);
      line-height: 1;
    }
    .stat-label {
      color: #ddd;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 2px;
      margin-top: 10px;
    }

    /* Philosophy */
    .philosophy-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 26px;
    }
    .phil-card {
      border: 1px solid var(--border);
      border-top: 3px solid var(--accent);
      border-radius: 8px;
      padding: 30px;
      background: var(--panel-light);
      transition: transform 0.3s, box-shadow 0.3s;
    }
    .phil-card:hover { transform: translateY(-4px); box-shadow: 0 12px 28px rgba(0,0,0,0.08); }
    .phil-card h3 { font-size: 20px; font-weight: 600; color: var(--black); margin-bottom: 10px; }
    .phil-card p { color: var(--dark); font-size: 15px; }

    /* Quote */
    .quote { background: var(--black); padding: 70px 0; text-align: center; }
    .quote p {
      color: #fff;
      font-size: clamp(22px, 3.4vw, 32px);
      font-weight: 500;
      max-width: 860px;
      margin: 0 auto;
    }
    .quote cite {
      display: block;
      margin-top: 18px;
      color: var(--accent);
      font-style: normal;
      font-weight: 700;
      letter-spacing: 2px;
      font-size: 14px;
    }

    /* Featured */
    .featured-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .feat-card {
      position: relative;
      display: block;
      height: 380px;
      border-radius: 8px;
      overflow: hidden;
    }
    .feat-img {
      position: absolute;
      inset: 0;
      background-size: cover;
      background-position: center;
      transition: transform 0.6s ease;
    }
    .feat-card:hover .feat-img { transform: scale(1.07); }
    .feat-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      align-items: flex-start;
      gap: 6px;
      padding: 24px;
      background: linear-gradient(180deg, rgba(0,0,0,0) 35%, rgba(0,0,0,0.85) 100%);
      color: #fff;
    }
    .feat-overlay h3 { font-size: 22px; font-weight: 600; }
    .feat-year { color: #ccc; font-size: 14px; }

    /* Journey */
    .journey-slider { position: relative; padding: 0 56px; max-width: 1400px; margin: 0 auto; }
    .j-track {
      display: flex;
      gap: 16px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
    }
    .j-track::-webkit-scrollbar { display: none; }
    .j-track img {
      height: 320px;
      width: auto;
      border-radius: 8px;
      scroll-snap-align: start;
      object-fit: cover;
      flex-shrink: 0;
    }
    .j-nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 42px;
      height: 42px;
      border-radius: 50%;
      border: none;
      background: var(--black);
      color: #fff;
      font-size: 22px;
      cursor: pointer;
      z-index: 2;
      transition: background 0.25s;
    }
    .j-nav:hover { background: var(--accent); }
    .j-prev { left: 8px; }
    .j-next { right: 8px; }

    /* Services */
    .services { background: var(--panel); }
    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .service-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 34px 28px;
      transition: transform 0.3s, box-shadow 0.3s;
    }
    .service-card:hover { transform: translateY(-4px); box-shadow: 0 12px 28px rgba(0,0,0,0.08); }
    .service-bar {
      display: block;
      width: 44px;
      height: 3px;
      background: var(--accent);
      margin-bottom: 18px;
    }
    .service-card h3 { font-size: 19px; font-weight: 600; color: var(--black); margin-bottom: 10px; }
    .service-card p { font-size: 15px; color: var(--dark); }

    /* Contact */
    .contact { background: var(--black); }
    .contact-title { color: #fff; }
    .contact-sub { color: #bbb; }
    .contact-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;
      text-align: center;
    }
    .contact-item h3 {
      color: var(--accent);
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 2px;
      margin-bottom: 8px;
    }
    .contact-item p, .contact-item a { color: #eee; font-size: 17px; font-weight: 500; }
    .contact-item a:hover { color: var(--accent); }

    @media (max-width: 1024px) {
      .featured-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 767px) {
      .stats-grid, .philosophy-grid, .featured-grid, .services-grid, .contact-grid {
        grid-template-columns: 1fr;
      }
      .stat-value, .stat-suffix { font-size: 42px; }
      .journey-slider { padding: 0 20px; }
      .j-track img { height: 220px; }
      .hero-content { padding-bottom: 60px; }
    }
  </style>
</Base>
