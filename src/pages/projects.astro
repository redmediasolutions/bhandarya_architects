---
import Base from '../layouts/Base.astro';
import { img } from '../consts';

const projects = [
  {
    category: 'RESIDENTIAL',
    title: 'Samudra',
    location: 'Yermal, Karnataka',
    year: '2025',
    description:
      'Samudra was envisioned as a tranquil coastal retreat for an industrialist couple seeking timeless elegance blended with relaxed seaside living. Inspired by colonial architecture, the home features a strong, symmetrical presence while remaining deeply connected to its surroundings.',
    builtArea: '6400 sq.ft',
    image: img('2026/05/Copy-of-01.webp'),
    href: '/samudra',
    reverse: false,
  },
  {
    category: 'RESIDENTIAL',
    title: 'Kutria',
    location: 'Mangalore, Karnataka',
    year: '2024',
    description:
      'Kutira was designed for a client who approached the project with two clear expectations, strict adherence to Vastu principles and the freedom to experiment with design. The process evolved into a collaborative journey shaped by trust, refinement, and close attention to detail.',
    builtArea: '4200 sq.ft',
    image: img('2026/05/Copy-of-01.png'),
    href: '/kuitra',
    reverse: true,
  },
];
---
<Base title="Projects">
  <section class="page-hero" style={`background-image:url('${img('2026/03/Screenshot-2026-03-25-154852.png')}')`}>
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <h1>Our Projects</h1>
      <span class="divider"></span>
      <p>Spaces designed around people, not trends</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {projects.map((p) => (
        <article class={`project-row reveal${p.reverse ? ' reverse' : ''}`}>
          <a href={p.href} class="project-img" style={`background-image:url('${p.image}')`} aria-label={p.title}></a>
          <div class="project-info">
            <span class="chip">{p.category}</span>
            <h2>{p.title}</h2>
            <ul class="meta">
              <li>
                <svg viewBox="0 0 384 512" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M215.7 499.2C267 435 384 279.4 384 192 384 86 298 0 192 0S0 86 0 192c0 87.4 117 243 168.3 307.2 12.3 15.3 35.1 15.3 47.4 0zM192 128a64 64 0 1 1 0 128 64 64 0 1 1 0-128z"/></svg>
                {p.location}
              </li>
              <li>
                <svg viewBox="0 0 448 512" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M96 32V64H48C21.5 64 0 85.5 0 112v48H448V112c0-26.5-21.5-48-48-48H352V32c0-17.7-14.3-32-32-32s-32 14.3-32 32V64H160V32c0-17.7-14.3-32-32-32S96 14.3 96 32zM448 192H0V464c0 26.5 21.5 48 48 48H400c26.5 0 48-21.5 48-48V192z"/></svg>
                {p.year}
              </li>
            </ul>
            <p class="desc">{p.description}</p>
            <div class="area">
              <h3>Built Area</h3>
              <p>{p.builtArea}</p>
            </div>
            <a href={p.href} class="btn">Learn More</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <style>
    .page-hero {
      position: relative;
      min-height: 80vh;
      display: flex;
      align-items: flex-end;
      background-size: cover;
      background-position: center;
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.8) 100%);
    }
    .hero-content { position: relative; z-index: 2; padding-bottom: 70px; color: #fff; }
    .hero-content h1 { font-size: 46px; font-weight: 600; }
    .divider {
      display: block;
      width: 70px;
      height: 1px;
      background: var(--accent);
      margin: 12px 0;
    }
    .hero-content p { color: #eee; font-size: 17px; }

    .project-row {
      display: grid;
      grid-template-columns: 1.05fr 1fr;
      gap: 44px;
      align-items: center;
      padding: 40px 0;
    }
    .project-row + .project-row { border-top: 1px solid var(--border); }
    .project-row.reverse .project-img { order: 2; }
    .project-img {
      display: block;
      min-height: 350px;
      border-radius: 8px;
      background-size: cover;
      background-position: center;
      transition: transform 0.4s ease, box-shadow 0.4s ease;
    }
    .project-img:hover { transform: scale(1.015); box-shadow: 0 14px 34px rgba(0,0,0,0.18); }

    .project-info h2 { font-size: 36px; font-weight: 500; color: var(--black); margin: 12px 0 10px; }
    .meta {
      list-style: none;
      display: flex;
      gap: 22px;
      margin-bottom: 14px;
    }
    .meta li {
      display: flex;
      align-items: center;
      gap: 7px;
      font-size: 14px;
      font-weight: 600;
      color: var(--dark);
    }
    .meta svg { color: var(--accent); }
    .desc { font-size: 14px; color: var(--ink); margin-bottom: 18px; }
    .area h3 { font-size: 14px; font-weight: 600; color: var(--gray-2); }
    .area p { font-size: 16px; font-weight: 600; color: var(--ink); margin-bottom: 20px; }

    @media (max-width: 900px) {
      .project-row { grid-template-columns: 1fr; gap: 24px; }
      .project-row.reverse .project-img { order: 0; }
      .hero-content h1 { font-size: 36px; }
    }
  </style>
</Base>
