---
import Base from '../layouts/Base.astro';
import { img } from '../consts';

const values = [
  { title: 'Excellence', text: 'We pursue the highest standards in every project we undertake.' },
  { title: 'Collaboration', text: 'Working closely with clients to bring their vision to life.' },
  { title: 'Innovation', text: 'Embracing new technologies and sustainable design practices.' },
  { title: 'Passion', text: 'Every design reflects our deep commitment architectural excellence.' },
];

const team = [
  { name: 'Amarnath Bhandary', role: 'Principal Architect' },
  { name: 'Sarina Bhandary', role: 'Principal Architect' },
  { name: 'Anil Kumar', role: 'Project Manager' },
  { name: 'Meera Patel', role: 'Interior Designer' },
];
const teamBio = 'With over 30 years of experience, Ar. Amarnath leads our vision with innovative design solutions.';
const portrait = img('2026/03/photo-1506794778202-cad84cf45f1d.avif');
---
<Base title="About Us">
  <section class="page-hero" style={`background-image:url('${img('2026/03/Screenshot-2026-03-25-153944.png')}')`}>
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <span class="chip">About us</span>
      <h1>Building dreams, shaping futures for three decades</h1>
    </div>
  </section>

  <section class="section story">
    <div class="container story-inner">
      <h2 class="section-title">Our Story</h2>
      <span class="title-divider"></span>
      <p>
        Founded in 1995, Bhandary Associates has been at the forefront of architectural innovation for
        three decades. What started as a small practice with a vision for excellence has grown into one
        of the most respected architecture firms in the region.
      </p>
      <p>
        Our journey has been defined by a commitment to pushing boundaries while respecting tradition.
        We believe that great architecture doesn't just shelter people—it inspires them, connects them,
        and elevates their daily experiences.
      </p>
      <p>
        Today, our portfolio spans residential, commercial, and urban planning projects, each bearing
        the hallmark of our dedication to sustainable design, functional beauty, and client satisfaction.
        As we celebrate 30 years of excellence, we remain as passionate as ever about creating spaces
        that stand the test of time.
      </p>
    </div>
  </section>

  <section class="section values">
    <div class="container">
      <h2 class="section-title">Our Values</h2>
      <p class="section-sub">The principles that guide everything we do</p>
      <div class="values-grid">
        {values.map((v) => (
          <article class="value-card reveal">
            <h3>{v.title}</h3>
            <p>{v.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section team">
    <div class="container">
      <h2 class="section-title">Our team</h2>
      <p class="section-sub">Meet the talented professionals behind Bhandary Associates</p>
      <div class="team-grid">
        {team.map((m) => (
          <article class="team-card reveal">
            <img src={portrait} alt={m.name} loading="lazy" />
            <div class="team-body">
              <h3>{m.name}</h3>
              <p class="role">{m.role}</p>
              <p class="bio">{teamBio}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <style>
    .page-hero {
      position: relative;
      min-height: 70vh;
      display: flex;
      align-items: flex-end;
      background-size: cover;
      background-position: center;
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0.85) 100%);
    }
    .hero-content { position: relative; z-index: 2; padding-bottom: 70px; color: #fff; }
    .hero-content h1 {
      font-size: clamp(30px, 4.6vw, 46px);
      font-weight: 600;
      max-width: 760px;
      margin-top: 14px;
    }

    .story-inner { max-width: 820px; }
    .story .section-title { text-align: left; }
    .title-divider {
      display: block;
      width: 70px;
      height: 2px;
      background: var(--accent);
      margin: 14px 0 26px;
    }
    .story p { margin-bottom: 18px; font-size: 16px; color: var(--dark); }

    .values { background: var(--panel); }
    .values-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 22px;
    }
    .value-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 30px 24px;
      text-align: center;
      transition: transform 0.3s, box-shadow 0.3s;
    }
    .value-card:hover { transform: translateY(-4px); box-shadow: 0 12px 26px rgba(0,0,0,0.08); }
    .value-card h3 { color: var(--accent); font-size: 19px; font-weight: 600; margin-bottom: 8px; }
    .value-card p { font-size: 14px; color: var(--dark); }

    .team-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 22px;
    }
    .team-card {
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      background: var(--panel-light);
      transition: transform 0.3s, box-shadow 0.3s;
    }
    .team-card:hover { transform: translateY(-4px); box-shadow: 0 12px 26px rgba(0,0,0,0.1); }
    .team-card img {
      width: 100%;
      height: 260px;
      object-fit: cover;
      object-position: top;
    }
    .team-body { padding: 18px; }
    .team-body h3 { font-size: 17px; font-weight: 600; color: var(--black); }
    .role { color: var(--accent); font-size: 13px; font-weight: 600; margin: 3px 0 10px; }
    .bio { font-size: 13px; color: var(--gray); }

    @media (max-width: 1024px) {
      .values-grid, .team-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 600px) {
      .values-grid, .team-grid { grid-template-columns: 1fr; }
    }
  </style>
</Base>
