---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;

  image?: string;
  canonical?: string;
  keywords?: string;
  type?: "website" | "article";
  noindex?: boolean;
}

const {
  title,
  description,
  image = "/images/og-image.jpg",
  canonical = Astro.url.href,
  keywords = "Bhandary Architects, Architects in Mangalore, Architecture, Interior Design, Commercial Architecture, Residential Architecture, Master Planning",
  type = "website",
  noindex = false,
} = Astro.props;

const siteName = "Bhandary Architects";
const siteUrl = Astro.site?.toString() ?? "https://bhandaryarchitects.com";
const pageTitle = `${title} | ${siteName}`;

const imageUrl = image.startsWith("http")
  ? image
  : new URL(image, siteUrl).toString();
---

<!doctype html>

<html lang="en">

<head>

    <!-- Basic -->

    <meta charset="UTF-8" />

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1"
    />

    <title>{pageTitle}</title>

    <meta
        name="description"
        content={description}
    />

    <meta
        name="keywords"
        content={keywords}
    />

    <meta
        name="author"
        content="Bhandary Architects"
    />

    <meta
        name="robots"
        content={noindex ? "noindex,nofollow" : "index,follow"}
    />

    <meta
        name="theme-color"
        content="#FF6900"
    />

    <link
        rel="canonical"
        href={canonical}
    />

    <!-- Open Graph -->

    <meta property="og:type" content={type} />

    <meta property="og:title" content={pageTitle} />

    <meta
        property="og:description"
        content={description}
    />

    <meta
        property="og:url"
        content={canonical}
    />

    <meta
        property="og:site_name"
        content={siteName}
    />

    <meta
        property="og:image"
        content={imageUrl}
    />

    <!-- Twitter -->

    <meta
        name="twitter:card"
        content="summary_large_image"
    />

    <meta
        name="twitter:title"
        content={pageTitle}
    />

    <meta
        name="twitter:description"
        content={description}
    />

    <meta
        name="twitter:image"
        content={imageUrl}
    />

    <!-- Favicons -->

    <link
        rel="icon"
        href="/favicon.ico"
    />

    <link
        rel="apple-touch-icon"
        href="/apple-touch-icon.png"
    />

    <!-- Fonts -->

    <link
        rel="preconnect"
        href="https://fonts.googleapis.com"
    />

    <link
        rel="preconnect"
        href="https://fonts.gstatic.com"
        crossorigin
    />

    <link
        href="https://fonts.googleapis.com/css2?family=Montserrat+Alternates:wght@300;400;500;600;700&display=swap"
        rel="stylesheet"
    />

    <!-- Structured Data -->

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Architect",
      name: "Bhandary Architects",
      url: siteUrl,
      image: imageUrl,
      description,
      telephone: "+91-XXXXXXXXXX",
      email: "hello@bhandaryarchitects.com",
      address: {
        "@type": "PostalAddress",
        addressLocality: "Mangalore",
        addressRegion: "Karnataka",
        addressCountry: "IN"
      }
    })} />

</head>

<body>

    <slot />

</body>

</html>

<style is:global>

::selection{
    background:var(--accent);
    color:white;
}

html{
    scroll-behavior:smooth;
    overflow-x:clip;
}

body{
    overflow-x:clip;
}

main{
    display:block;
}

img{
    display:block;
    max-width:100%;
    user-select:none;
    -webkit-user-drag:none;
}

a,
button{
    transition:var(--transition);
}

</style>