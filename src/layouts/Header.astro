---
const navigation = [
  { name: "Home", href: "/" },
  { name: "About", href: "/about" },
  { name: "Projects", href: "/projects" },
  { name: "Contact", href: "/contact" },
];

const pathname = Astro.url.pathname;

interface Props {
  delayed?: boolean;
}

const { delayed = false } = Astro.props;
---

<header
    id="site-header"
    class:list={[
        "site-header",
        delayed && "delayed-header"
    ]}
>

    <div class="container navbar">

        <!-- Logo -->

        <a href="/" class="logo">

            <div class="logo-text">

                <span>Bhandary</span>

                <small>Architects</small>

            </div>

        </a>

        <!-- Navigation -->

        <nav class="nav-menu">

            {
                navigation.map((item) => (

                    <a
                        href={item.href}
                        class={pathname === item.href ? "active" : ""}
                    >
                        {item.name}
                    </a>

                ))
            }

        </nav>

        <!-- CTA -->

        <a
            href="/contact"
            class="btn header-btn"
        >
            Get In Touch
        </a>

        <!-- Mobile -->

        <button
            class="mobile-toggle"
            aria-label="Open Menu"
        >
            ☰
        </button>

    </div>

</header>

<script is:inline>

const header = document.getElementById("site-header");

if (header && header.classList.contains("delayed-header")) {

    function updateHeader() {

        if (window.scrollY <= 10) {

            header.classList.remove("visible");

        } else {

            header.classList.add("visible");

        }

    }

    updateHeader();

    window.addEventListener("scroll", updateHeader, {
        passive: true
    });

}

</script>

<style>

.site-header{

    position:fixed;

    top:0;

    left:0;

    right:0;

    width:100%;

    z-index:1000;

    background:rgba(255,255,255,.94);

    backdrop-filter:blur(14px);

    -webkit-backdrop-filter:blur(14px);

    border-bottom:1px solid var(--border);

    transition:

        opacity .7s cubic-bezier(.22,1,.36,1),

        transform .7s cubic-bezier(.22,1,.36,1),

        box-shadow .35s ease,

        background .35s ease;

}

/* -------------------------------- */

.delayed-header{

    opacity:0;

    transform:translateY(-100%);

    pointer-events:none;

}

/* -------------------------------- */

.delayed-header.visible{

    opacity:1;

    transform:translateY(0);

    pointer-events:auto;

    box-shadow:

        0 12px 40px rgba(0,0,0,.08);

}

/* -------------------------------- */

.navbar{

    height:90px;

    display:flex;

    align-items:center;

    justify-content:space-between;

}

/* -------------------------------- */

.logo{

    display:flex;

    align-items:center;

    text-decoration:none;

}

.logo-text{

    display:flex;

    flex-direction:column;

}

.logo-text span{

    font-size:20px;

    font-weight:600;

    letter-spacing:2px;

    text-transform:uppercase;

    color:var(--black);

}

.logo-text small{

    font-size:12px;

    letter-spacing:4px;

    text-transform:uppercase;

    color:var(--gray);

}

/* -------------------------------- */

.nav-menu{

    display:flex;

    gap:42px;

}

.nav-menu a{

    position:relative;

    font-size:13px;

    letter-spacing:2px;

    text-transform:uppercase;

    color:var(--gray);

    transition:.3s;

}

.nav-menu a:hover,

.nav-menu a.active{

    color:var(--accent);

}

.nav-menu a::after{

    content:"";

    position:absolute;

    left:0;

    bottom:-8px;

    width:0;

    height:2px;

    background:var(--accent);

    transition:.3s;

}

.nav-menu a:hover::after,

.nav-menu a.active::after{

    width:100%;

}

/* -------------------------------- */

.header-btn{

    padding:12px 24px;

    font-size:12px;

}

.mobile-toggle{

    display:none;

    background:none;

    border:none;

    cursor:pointer;

    font-size:28px;

}

/* -------------------------------- */

.header-space{

    height:90px;

}

/* -------------------------------- */

@media(max-width:991px){

    .nav-menu{

        display:none;

    }

    .header-btn{

        display:none;

    }

    .mobile-toggle{

        display:block;

    }

}

/* -------------------------------- */

@media(max-width:768px){

    .navbar{

        height:80px;

    }

    .header-space{

        height:80px;

    }

    .logo-text span{

        font-size:18px;

    }

    .logo-text small{

        font-size:10px;

    }

}

</style>